                  <SHORT-NAME>GptPredefTimer1usEnablingGrade</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Specifies the grade of enabling the GPT Predef Timers with 1?s tick duration.</L-2>
                  </DESC>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
