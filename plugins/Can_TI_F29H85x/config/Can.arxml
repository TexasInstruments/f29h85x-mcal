                    <ECUC-ENUMERATION-PARAM-DEF UUID="1db9b05a-63f1-45c4-beaf-9c945f46012c">
                      <SHORT-NAME>CanWakeupProcessing</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Enables / disables API Can_MainFunction_Wakeup() for handling wakeup events in polling mode.</L-2>
                      </DESC>
