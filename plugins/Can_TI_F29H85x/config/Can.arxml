                </ECUC-REFERENCE-DEF>
                <ECUC-REFERENCE-DEF UUID="c14c6766-9a4a-4a1f-ad46-059eb50677fc">
                  <SHORT-NAME>CanSupportTTCANRef</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">The parameter refers to CanIfSupportTTCAN parameter in the CAN Interface Module configuration.</L-2>
                  </DESC>
                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                  <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                  <SCOPE>ECU</SCOPE>
                  <ORIGIN>AUTOSAR_ECUC</ORIGIN>
