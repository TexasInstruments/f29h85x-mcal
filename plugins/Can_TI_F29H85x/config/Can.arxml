                  <MIN>1.0E-6</MIN>
                </ECUC-FLOAT-PARAM-DEF>
                <ECUC-BOOLEAN-PARAM-DEF UUID="9f9b8024-4664-45bc-89e3-b864a319c3eb">
                  <SHORT-NAME>CanVersionInfoApi</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Switches the Can_GetVersionInfo() API ON or OFF.</L-2>
                  </DESC>
