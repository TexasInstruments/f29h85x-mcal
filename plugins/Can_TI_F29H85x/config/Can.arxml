                    <ECUC-REFERENCE-DEF UUID="6eca41a4-53d0-475f-a7c6-0cbaed62a46f">
                      <SHORT-NAME>CanControllerDefaultBaudrate</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Reference to baudrate configuration container configured for the Can Controller.</L-2>
                      </DESC>
                      <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                      <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
