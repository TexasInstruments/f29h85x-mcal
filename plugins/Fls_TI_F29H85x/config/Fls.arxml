                      <SHORT-NAME>FLS_ISR_CAT2</SHORT-NAME>
                      <ORIGIN>Texas Instruments</ORIGIN>
                    </ECUC-ENUMERATION-LITERAL-DEF>
                  </LITERALS>
                </ECUC-ENUMERATION-PARAM-DEF>
                <ECUC-INTEGER-PARAM-DEF UUID="f3a3d982-bbf2-4802-9eb3-9971ebd877d9">
                  <SHORT-NAME>FlsDefaultOSCounterId</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">Default Os Counter Id if node reference to OsCounter ref FlsOsCounterRef is not set</L-2>
                  </DESC>
