                      <v:ctr name="CddSentSyncErrorInterrupts" type="IDENTIFIABLE">
                        <a:a name="DESC" value="EN: Valid data interrupts"/>
                        <a:a name="UUID" 
                             value="ECUC:a76e276f-cf22-4965-8557-edf5d9d2f01b"/>
                        <a:a name="TAB" value="CddSentInterruptSources"/>
                        <v:var name="Fast_Channel_Sync_Pulse_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: Indicates that the synchronization pulse varies by more than 25% from the expected 56 clock ticks"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Successive_Calibration_Pulse_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: The successive calibration pulses differ by greater than +1.5625 or less than -1.5625"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
