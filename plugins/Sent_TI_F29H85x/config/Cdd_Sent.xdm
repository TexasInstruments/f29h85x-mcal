                                   <mt:range>
                                      <mt:tst expr="&lt;=65535"/>
                                      <mt:tst expr="&gt;=0"/>
                                   </mt:range>
                              </a:a>
                           </v:var>
                           <v:var name="CddSentMessageID" type="INTEGER">
