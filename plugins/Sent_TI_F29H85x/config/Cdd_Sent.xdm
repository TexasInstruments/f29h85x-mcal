                              </a:da>
                            </v:var>
                            <v:ref name="CddSentPduID" type="REFERENCE">
                              <a:a name="DESC" 
                                   value="EN: This parameter will be used when CddSentIntegrationWithAsrComStackEnable is enabled. This Pdu identifier will be used in receive function callback to PduR to address the received Pdu from respective sensor. "/>
