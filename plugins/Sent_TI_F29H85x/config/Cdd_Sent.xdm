<?xml version='1.0'?>
<datamodel version="8.0" 
           xmlns="http://www.tresos.de/_projects/DataModel2/18/root.xsd" 
           xmlns:a="http://www.tresos.de/_projects/DataModel2/18/attribute.xsd" 
           xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd" 
           xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">

  <d:ctr type="AUTOSAR" factory="autosar" 
         xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd" 
         xmlns:ce="http://www.tresos.de/_projects/DataModel2/18/childenable.xsd" 
         xmlns:cd="http://www.tresos.de/_projects/DataModel2/08/customdata.xsd" 
         xmlns:f="http://www.tresos.de/_projects/DataModel2/14/formulaexpr.xsd" 
         xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd" 
         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"  
         xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TI_F29H85x" type="AR-PACKAGE">
        <d:lst type="TOP-LEVEL-PACKAGES">
          <d:ctr name="Cdd_Sent" type="AR-PACKAGE">
            <d:lst type="ELEMENTS">
              <d:chc name="Cdd" type="AR-ELEMENT" value="MODULE-DEF">
                <v:ctr type="MODULE-DEF">
                  <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                    <ad:ADMIN-DATA>
                      <ad:DOC-REVISIONS>
                        <ad:DOC-REVISION>
                          <ad:REVISION-LABEL>4.3.1</ad:REVISION-LABEL>
                          <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                        </ad:DOC-REVISION>
                      </ad:DOC-REVISIONS>
                    </ad:ADMIN-DATA>
                  </a:a>
                  <a:a name="DESC" 
                       value="EN: Configuration of the CddSent module"/>
                  <a:a name="LOWER-MULTIPLICITY" value="1"/>
                  <a:a name="POSTBUILDVARIANTSUPPORT" value="false"/>
                  <a:a name="RELEASE" value="asc:4.3.1"/>
                  <a:a name="UPPER-MULTIPLICITY" value="*"/>
                  <a:a name="UUID" value="8de76b7c-c31f-441c-a674-5819632fed2c"/>
                  <a:a name="API-SERVICE-PREFIX" value="Cdd_Sent"/>
                  <v:var name="IMPLEMENTATION_CONFIG_VARIANT" 
                         type="ENUMERATION">
                    <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="LABEL" value="Config Variant"/>
                    <a:a name="UUID" 
                         value="5b679a01-e0f7-4df9-96df-b99f40140b7a"/>
                    <a:da name="DEFAULT" value="VariantPreCompile"/>
                    <a:da name="RANGE">
                      <a:v>VariantPreCompile</a:v>
                    </a:da>
                  </v:var>
                  <v:ctr name="CddSentConfig" type="IDENTIFIABLE">
                    <a:a name="DESC" 
                         value="EN: This container contains the configuration parameters and sub containers of the CddSent module."/>
                    <a:a name="UUID" 
                         value="ECUC:b9ea6561-fd73-4381-bdb6-8e027a43ad62"/>
                    <v:lst name="CddSentController" type="MAP">
                      <a:da name="MIN" value="1"/>
                      <a:da name="MAX" value="6"/>
                      <v:ctr name="CddSentController" type="IDENTIFIABLE">
                        <a:a name="DESC" 
                             value="EN: This container contains the configuration parameters of the CddSent HW units."/>
                        <a:a name="UUID" 
                             value="ECUC:a79e276f-cf20-496c-8587-edf4d9d2f01b"/>
                        <v:var name="CddSentInstance" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: Selects CddSent HW unit Instance."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">                           
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE">
                            <a:v>SENT1</a:v>
                            <a:v>SENT2</a:v>
                            <a:v>SENT3</a:v>
                            <a:v>SENT4</a:v>
                            <a:v>SENT5</a:v>
                            <a:v>SENT6</a:v>
                          </a:da>
                          <a:da name="DEFAULT" value="SENT1"/>
                          <a:da name="INVALID" type="XPath">
                             <a:tst expr="text:uniq((../../..//*[@name='CddSentInstance']),node:value(.))" false="CddSentInstance selection has to be unique across all containers"/>
                          </a:da>
                        </v:var> 
                        <v:var name="CddSentBaseAddress" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: Specifies the CddSent HW unit base address."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=4294967295"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                          <a:a name="DEFAULT_RADIX" value="HEX"/>
                          <a:da name="DEFAULT" type="XPath">
                              <a:tst expr="node:fallback(&quot;->(num:inttohex((substring-after(node:value(../CddSentInstance),'SENT') - 1 )*4096+1611038720))&quot;,num:i(0))"   />
                          </a:da>
                          <a:da name="EDITABLE" value="false"/>
                        </v:var>
                        <v:var name="CddSentHWUnitId" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: This parameter provides the HW unit ID which is unique in a given CddSent Driver. The value for this parameter starts with 0 and continue without any gaps."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="ECU"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="0"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=5"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
						  <a:da name="INVALID" type="XPath">
                             <a:tst expr="text:uniq((../../..//*[@name='CddSentHWUnitId']),node:value(.))" false="CddSentHWUnitId selection has to be unique across all containers"/>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentClockTick" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: This parameter is for setting the clock tick for the CddSent in Use"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="ECU"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                         <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:value(concat(node:path(node:ref(../CddSentCpuClockRef)), '/McuClockReferencePointFrequency')) div (1000000) * 3 )&quot;,num:i(0))"/>
                         <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=600"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                         <a:da name="EDITABLE" value="false"/>
                        </v:var>
                        <v:var name="CddSentInteruptType" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: Defines the interrupt type."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <a:da name="DEFAULT" value="CDD_SENT_ISR_CAT2"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_ISR_CAT1_RTINT</a:v>
                                <a:v>CDD_SENT_ISR_CAT1_INT</a:v>
                                <a:v>CDD_SENT_ISR_CAT2</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentCRCType" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: CddSent CRC type selection."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="CDD_SENT_CRC_RECOMENDED_2010"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_CRC_LEGACY_2007</a:v>
                                <a:v>CDD_SENT_CRC_RECOMENDED_2010</a:v>
                                <a:v>CDD_SENT_CRC_NONE</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentCRCWidth" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: CddSent CRC Width selection."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="CDD_SENT_CRC_4_BIT"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_CRC_4_BIT</a:v>
                                <a:v>CDD_SENT_CRC_6_BIT</a:v>
                                <a:v>CDD_SENT_CRC_8_BIT</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentCRCWithStatus" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: Enable/Disable CRC with status.."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                           <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="CDD_SENT_CRC_WITH_STATUS"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_CRC_WITH_STATUS</a:v>
                                <a:v>CDD_SENT_CRC_WITHOUT_STATUS</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentDataNibblesCount" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: number of data nibbles expected"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="CDD_SENT_6_DATA_NIBBLES"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_1_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_2_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_3_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_4_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_5_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_6_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_7_DATA_NIBBLES</a:v>
                                <a:v>CDD_SENT_8_DATA_NIBBLES</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentFIFOTriggerLevel" type="ENUMERATION">
                          <a:a name="DESC" 
                               value="EN: FIFO trigger level expected"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="ENABLE" type="XPath" expr="(../CddSentMTP = 'false')"/>
                          <a:da name="DEFAULT" value="CDD_SENT_TRIGLEV6"/>
                            <a:da name="RANGE">
                                <a:v>CDD_SENT_TRIGDISABLE</a:v>
                                <a:v>CDD_SENT_TRIGLEV3</a:v>
                                <a:v>CDD_SENT_TRIGLEV4</a:v>
                                <a:v>CDD_SENT_TRIGLEV5</a:v>
                                <a:v>CDD_SENT_TRIGLEV6</a:v>
                                <a:v>CDD_SENT_TRIGLEV7</a:v>
                                <a:v>CDD_SENT_TRIGLEV8</a:v>
                                <a:v>CDD_SENT_TRIGLEV9</a:v>
                                <a:v>CDD_SENT_TRIGLEV10</a:v>
                                <a:v>CDD_SENT_TRIGLEV11</a:v>
                                <a:v>CDD_SENT_TRIGLEV12</a:v>
                                <a:v>CDD_SENT_TRIGLEV13</a:v>
                                <a:v>CDD_SENT_TRIGLEV14</a:v>
                                <a:v>CDD_SENT_TRIGLEV15</a:v>
                                <a:v>CDD_SENT_TRIGLEV16</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentUserCallbackFunction" type="FUNCTION-NAME">
                              <a:a name="DESC" 
                                        value="EN: Call back function for the data"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" value="true"/>
                              <a:da name="DEFAULT" value="NULL_PTR"/>
                              <a:da name="INVALID" type="XPath">
                                   <a:tst expr="../../../../CddSentGeneral/CddSentIntegrationWithAsrComStackEnable = 'true' or (node:value(.) != 'NULL_PTR' and not(node:empty(.)))" false="CddSentChannelType selection has to be unique across all containers"/>
                              </a:da>
                         </v:var>
                         <v:var name="CddSentUserErrorCallbackFunction" type="FUNCTION-NAME">
                              <a:a name="DESC" 
                                        value="EN: Call back function for the data"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" value="true"/>
                              <a:da name="DEFAULT" value="NULL_PTR"/>
                              <a:da name="INVALID" type="XPath">
                                   <a:tst expr="node:refexists(as:modconf('Cdd_Sent')[1]/CddSentDemEventParameterRefs/CDD_E_HARDWARE_ERROR) or node:value(.) != 'NULL_PTR' or not(node:empty(.))" false="CddSentChannelType selection has to be unique across all containers"/>
                              </a:da>
                         </v:var>
                        <v:var name="CddSentSyncTimeout" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: This parameter is for setting Timeout for receiving the synchronization pulse"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="ECU"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="0"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=255"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                        </v:var>
                         <v:var name="CddSentGlitchFilter" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: This parameter is for number of SYSCLKS that the received serial data input is filtered by"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="ECU"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="5"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=255"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                        </v:var>
                         <v:var name="CddSentMTP" type="BOOLEAN">
                          <a:a name="DESC" 
                               value="EN: Enable/disable MTP functionality."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>
                       <v:var name="CddSentGlobalWaitTime" type="INTEGER">
                          <a:a name="DESC" 
                               value="EN: This parameter is for delay time  between the last frame received to the new master trigger pulse to be generated"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="ECU"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="256"/>
                          <a:da name="ENABLE" type="XPath" expr="(../CddSentMTP = 'true')"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=65535"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                        </v:var>
                        <v:var name="CddSentAcceptErrorData" type="BOOLEAN">
                          <a:a name="DESC" 
                               value="EN: Accept error data or not."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>
                         <v:var name="CddSentEnableTimeStamp" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: Enable/disable Time stamping."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="true"/>
                         </v:var>
                        <v:ref name="CddSentCpuClockRef" type="REFERENCE">
                          <a:a name="DESC" 
                               value="EN: Reference to the CPU clock configuration, which is set in the MCU driver configuration"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="REF" 
                                value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Mcu/McuModuleConfiguration/McuClockSettingConfig/McuClockReferencePoint"/>
                        </v:ref>
                        <v:lst name="CddSentChannelObject" type="MAP">
                          <a:da name="MIN" value="1"/>
                          <v:ctr name="CddSentChannelObject" type="IDENTIFIABLE">
                            <a:a name="DESC" 
                                 value="EN: This container contains the configuration parameters of the CddSent channel object"/>
                            <a:a name="UUID" 
                                 value="ECUC:a69e276f-cf20-496c-8587-edf4d9d2f01b"/>
                            <a:da name="INVALID" type="XPath">
                                   <a:tst expr="text:uniq((../../../../CddSentController/*/CddSentChannelObject/*/@name),@name)" false="CddSentChannelObject selection has to be unique across all containers"/>
                            </a:da>
                              <v:var name="CddSentSensorType" type="ENUMERATION">
                                   <a:a name="DESC" 
                                        value="EN: selection of sensor types"/>
                                   <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                        type="IMPLEMENTATIONCONFIGCLASS">
                                   <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                   </a:a>
                                   <a:a name="ORIGIN" value="Texas Instruments"/>
                                   <a:a name="SCOPE" value="LOCAL"/>
                                   <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                   <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                   <a:da name="DEFAULT" value="CDD_SENT_CHANNEL_STANDARD_SENSOR"/>
                                   <a:da name="RANGE">
                                        <a:v>CDD_SENT_CHANNEL_STANDARD_SENSOR</a:v>
                                        <a:v>CDD_SENT_CHANNEL_SENSOR_1</a:v>
                                        <a:v>CDD_SENT_CHANNEL_SENSOR_2</a:v>
                                        <a:v>CDD_SENT_CHANNEL_SENSOR_3</a:v>
                                        <a:v>CDD_SENT_CHANNEL_SENSOR_4</a:v>
                                   </a:da>
                            </v:var> 
                            <v:var name="CddSentChannelType" type="ENUMERATION">
                              <a:a name="DESC" 
                                   value="EN: selection of channel types"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="CDD_SENT_CHANNEL_STANDARD_SENSOR_FAST_CHANNEL"/>
                                <a:da name="RANGE">
                                    <a:v>CDD_SENT_CHANNEL_STANDARD_SENSOR_FAST_CHANNEL</a:v>
                                    <a:v>CDD_SENT_CHANNEL_SENSOR_1_FAST_CHANNEL</a:v>
                                    <a:v>CDD_SENT_CHANNEL_SENSOR_2_FAST_CHANNEL</a:v>
                                    <a:v>CDD_SENT_CHANNEL_SENSOR_3_FAST_CHANNEL</a:v>
                                    <a:v>CDD_SENT_CHANNEL_SENSOR_4_FAST_CHANNEL</a:v>
                                    <a:v>SHORT_SERIAL_ENHANCED_SERIAL_12BIT_SLOW_CHANNEL</a:v>6
                                    <a:v>ENHANCED_SERIAL_16BIT_SLOW_CHANNEL</a:v>
                              </a:da>
                              <a:da name="INVALID" type="XPath">
                                   <a:tst expr="../CddSentChannelType = 'SHORT_SERIAL_ENHANCED_SERIAL_12BIT_SLOW_CHANNEL' or ../CddSentChannelType = 'ENHANCED_SERIAL_16BIT_SLOW_CHANNEL'or text:contains(node:value(.), node:value(../CddSentSensorType)) and text:uniq((../../..//*[@name='CddSentChannelType']),node:value(.))" false="CddSentChannelType selection has to be unique across all containers"/>
                              </a:da>
                            </v:var>
                            <v:ref name="CddSentPduID" type="REFERENCE">
                              <a:a name="DESC" 
                                   value="EN: This parameter will be used when CddSentIntegrationWithAsrComStackEnable is enabled. This Pdu identifier will be used in receive function callback to PduR to address the received Pdu from respective sensor. "/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" type="XPath" expr="(../../../../../../CddSentGeneral/CddSentIntegrationWithAsrComStackEnable = 'true')"/>
                              <a:da name="INVALID" type="XPath">
                                   <a:tst expr="text:uniq((../../../..//*[@name='CddSentPduID']),node:value(.)) and not(node:empty(.))" false="CddSentChannelType selection has to be unique across all containers"/>
                              </a:da>
                              <a:da name="REF" 
                                        value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Cdd/CddComStackContribution/CddPduRLowerLayerContribution/CddPduRLowerLayerRxPdu"/>
                            </v:ref>
                            <v:var name="CddSentChannelObjectID" type="INTEGER">
                              <a:a name="DESC" 
                                   value="EN: This parameter will be used when CddSentIntegrationWithAsrComStackEnable is disabled. This channel object identifier will be used in configured receive callback function to  address the received object from respective sensor. "/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="ECU"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" value="true"/>
                              <a:da name="EDITABLE" value="false"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;-> (num:i(count(preceding::CddSentChannelObjectID))) &quot;, num:i(0))"/>
                              <a:da name="INVALID" type="XPath">
                              <a:tst expr="text:uniq((../../../..//*[@name='CddSentChannelObjectID']),node:value(.))" false="CddSentChannelObjectID selection has to be unique across all containers"/>
                              </a:da>
                           </v:var>
                           <v:var name="CddSentMessageID" type="INTEGER">
                              <a:a name="DESC" 
                                   value="EN: This parameter is the message id"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="ECU"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" type="XPath" expr="(contains(node:value(../CddSentChannelType), 'CDD_SENT_CHANNEL_STANDARD_SENSOR_FAST_CHANNEL')) or (contains(node:value(../CddSentChannelType), 'CDD_SENT_CHANNEL_SENSOR_1_FAST_CHANNEL')) or (contains(node:value(../CddSentChannelType), 'CDD_SENT_CHANNEL_SENSOR_2_FAST_CHANNEL')) or (contains(node:value(../CddSentChannelType), 'CDD_SENT_CHANNEL_SENSOR_3_FAST_CHANNEL')) or (contains(node:value(../CddSentChannelType), 'CDD_SENT_CHANNEL_SENSOR_4_FAST_CHANNEL'))" true="false" false="true"/>
                              <a:da name="DEFAULT" value="1"/>
                              <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=255"/>
                              <a:tst expr="&gt;=1"/>
                              </a:da>
                              <a:da name="INVALID" type="XPath">
                                   <a:tst expr="text:uniq((../../..//*[@name='CddSentMessageID']),node:value(.))" false="CddSentChannelType selection has to be unique across all containers"/>
                              </a:da>
                           </v:var>
                          </v:ctr>
                        </v:lst>
                        <v:lst name="CddSentExternalDeviceConfig" type="MAP">
                          <a:da name="MIN" type="XPath" expr="node:fallback(&quot;->node:when(../CddSentMTP = 'true',1,0)&quot;,num:i(0))"/> 
