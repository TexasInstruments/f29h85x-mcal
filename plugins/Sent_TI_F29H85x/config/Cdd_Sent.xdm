                                   <a:da name="INVALID" type="XPath">
                                        <a:tst expr="text:uniq((../..//*[@name='CddSentMTPSensorPduID']),node:value(.)) and not(node:empty(.))" false="CddSentMTPSensorPduID selection has to be unique across all containers"/>
                                   </a:da>	
                                   <a:da name="REF" 
                                        value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Cdd/CddComStackContribution/CddPduRLowerLayerContribution/CddPduRLowerLayerTxPdu"/>
                              </v:ref>
                              <v:var name="CddSentExternalDeviceID" type="INTEGER">
                                   <a:a name="DESC" 
                                        value="EN: This parameter will be used when CddSentIntegrationWithAsrComStackEnable is disabled. This device identifier will be used in transmit function to address the respective sensor. "/>
                                   <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                        type="IMPLEMENTATIONCONFIGCLASS">
                                   <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                   <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                   </a:a>
                                   <a:a name="ORIGIN" value="Texas Instruments"/>
                                   <a:a name="SCOPE" value="ECU"/>
                                   <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                   <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                   <a:da name="ENABLE" type="XPath" expr="((../../../../../../CddSentGeneral/CddSentIntegrationWithAsrComStackEnable = 'false') and not(../CddSentMTPSensorType = 'CDD_SENT_CHANNEL_BROADCAST'))"/>
                                   <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;-> (num:i(count(preceding::CddSentExternalDeviceID))) &quot;, num:i(0))"/>
                                   <a:da name="INVALID" type="XPath">
                                        <a:tst expr="text:uniq((../..//*[@name='CddSentExternalDeviceID']),node:value(.))" false="CddSentExternalDeviceID selection has to be unique across all containers"/>
                                   </a:da>	
                              </v:var>
                          </v:ctr>
                        </v:lst> 
