                                   <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;-> (num:i(count(preceding::CddSentExternalDeviceID))) &quot;, num:i(0))"/>
                                   <a:a name="INVALID" type="Multi">
                                        <mt:xpath expr="text:uniq((../..//*[@name='CddSentExternalDeviceID']),node:value(.))" false="CddSentExternalDeviceID selection has to be unique across all containers"/>
                                        <mt:range>
                                             <mt:tst expr="&lt;=65535"/>
                                             <mt:tst expr="&gt;=0"/>
                                        </mt:range>
                                   </a:a>	
                              </v:var>
                          </v:ctr>
                        </v:lst> 
