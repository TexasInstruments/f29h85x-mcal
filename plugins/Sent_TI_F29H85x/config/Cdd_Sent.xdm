                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="d0009dbb-98ed-4748-a012-cc8db996c99b"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Sensor_3_Overflow_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: When the sensor 3 channel trigger pulse genarator recieves a trigger reuest while it is busy"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="98bf761b-3024-4f20-b109-e7a65c49550a"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Sensor_4_Overflow_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: When the sensor 4 channel trigger pulse genarator recieves a trigger reuest while it is busy"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="c2af5a27-77fa-4664-910a-1c6cc095c918"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                      </v:ctr>
                      <v:ctr name="CddSentSyncErrorInterrupts" type="IDENTIFIABLE">
                        <a:a name="DESC" value="EN: Valid data interrupts"/>
                        <a:a name="UUID" 
                             value="ECUC:a76e276f-cf22-4965-8557-edf5d9d2f01b"/>
                        <a:a name="TAB" value="CddSentInterruptSources"/>
                        <v:var name="Fast_Channel_Sync_Pulse_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: Indicates that the synchronization pulse varies by more than 25% from the expected 56 clock ticks"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="298338c9-1db2-4a85-b29a-a93d6bc10738"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Successive_Calibration_Pulse_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: The successive calibration pulses differ by greater than +1.5625 or less than -1.5625"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="2d1ca32f-8c0b-46a0-9caf-9ae6b9c39705"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Frequency_Drift_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: The ratio of the calibration pulse to the message length varies by greater than 1/64 or less than -1/64 from one message to another"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" 
                                   value="a154277f-111b-4d84-8a46-1e0ce9e145d8"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                      </v:ctr>
                      </v:ctr>
                    </v:lst>   
                  </v:ctr>
                  <v:ctr name="CddComStackContribution" type="IDENTIFIABLE">
                    <a:a name="DESC" 
                         value="EN: Contribution of COM Stack modules."/>
                    <a:a name="UUID" 
                         value="85434ef2-9333-4d6d-8f92-b48863de2ba6"/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                         type="IMPLEMENTATIONCONFIGCLASS">
                         <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:da name="ENABLE" type="XPath" expr="(../CddSentGeneral/CddSentIntegrationWithAsrComStackEnable = 'true')"/>
                    <v:ctr name="CddPduRLowerLayerContribution" 
                           type="IDENTIFIABLE">
                      <a:a name="DESC" 
                           value="EN: Parameters that are necessary for the configuration of a Complex Driver that serves as the LowerLayer of the Pdu Router module."/>
                      <a:a name="OPTIONAL" value="true"/>
                      <a:a name="UUID" 
                           value="81307b2f-8d32-4a0b-bf35-dba047828839"/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                         type="IMPLEMENTATIONCONFIGCLASS">
                         <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:da name="ENABLE" value="false"/>
                      <v:lst name="CddPduRLowerLayerRxPdu" type="MAP">
                        <a:da name="MIN" value="1"/>
                        <v:ctr name="CddPduRLowerLayerRxPdu" 
                               type="IDENTIFIABLE">
                          <a:a name="DESC" 
                               value="EN: This container specifies Rx PDUs that are exchanged between the CDD and the standardized BSW module."/>
                          <a:a name="UUID" 
                               value="c5138c30-b0c5-4bb2-a92a-6803d586582b"/>>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                           </a:a>
                          <v:var name="CddPduRApiType" type="ENUMERATION">
                            <a:a name="DESC" 
                                 value="EN: This parameter configures the type of the CDD interface (IF/TP)"/>
                            <a:a name="OPTIONAL" value="true"/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" 
                                 value="6e014dd1-7c1e-43f0-886e-92ab29104fe6"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                           <a:da name="ENABLE" value="false"/>
                           <a:da name="DEFAULT" value="IF"/>
                            <a:da name="EDITABLE" value="false"/>
                            <a:da name="RANGE">
                              <a:v>IF</a:v>
                            </a:da>
                          </v:var>
                          <v:var name="CddPduRLowerLayerHandleId" 
                                 type="INTEGER">
                            <a:a name="DESC" 
                                 value="EN: ECU wide unique, symbolic handle for the Pdu."/>
                            <a:a name="OPTIONAL" value="true"/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                            <a:a name="UUID" 
                                 value="d3f33021-fd40-4259-9ac9-ffc09a3ca5ba"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:da name="ENABLE" value="false"/>
                            <a:da name="DEFAULT" value="0"/>
                            <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=65535"/>
                              <a:tst expr="&gt;=0"/>
                            </a:da>
                          </v:var>
                          <v:ref name="CddPduRLowerLayerPduRef" 
                                 type="REFERENCE">
                            <a:a name="DESC" 
                                 value="EN: Reference to the &quot;global&quot; Pdu structure to allow harmonization of handle IDs in the COM-Stack."/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="UUID" 
                                 value="68d06eb7-c37c-4d31-84d6-27513d0674f4"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                             </a:a>
                            <a:da name="INVALID" type="XPath">
                                   <a:tst expr="text:uniq((../../..//*[@name='CddPduRLowerLayerPduRef']),node:value(.)) and not(node:empty(.))" false="CddPduRLowerLayerPduRef selection has to be unique across all containers"/>
                            </a:da>
                            <a:da name="REF" 
                                  value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/EcuC/EcucConfigSet/EcucPduCollection/Pdu"/>
                          </v:ref>
                          <v:var name="CddSentPduRHandle" 
                                 type="STRING">
                            <a:a name="DESC" 
                                 value="EN: CddSentPduRHandle is a symbolic name of the Pdu with which Cdd_Sent module invokes the receive indication for upper layer. User can modify this parameter to match with the symbolic name used by upper layer."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                             </a:a> 
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:da name="INVALID" type="XPath">
                               <a:tst expr="text:uniq((../../..//*[@name='CddSentPduRHandle']),node:value(.))" false="CddSentPduRHandle selection has to be unique."/>
                           </a:da>
                            <a:da name="ENABLE" type="XPath" expr="(../../../../../CddSentGeneral/CddSentIntegrationWithAsrComStackEnable = 'true')"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat(node:when(node:empty(../CddPduRLowerLayerPduRef), '', 'PduRConf_PduRSrcPdu_PduRSrcPdu_'),substring-after(node:value(../CddPduRLowerLayerPduRef), '/EcuC/EcuC/EcucConfigSet/EcucPduCollection/'))&quot;,'NULL')"/>
                            <a:a name="UUID" 
                                 value="39d05267-5b60-439c-892b-5fd3653154ee"/>
                          </v:var>
                        </v:ctr>
                      </v:lst>
                      <v:lst name="CddPduRLowerLayerTxPdu" type="MAP">
                        <a:da name="MIN" type="XPath" expr="node:fallback(&quot;->node:when(../../../CddSentConfig/CddSentController/*/CddSentMTP = 'true',1,0)&quot;,num:i(0))"/> 
                        <v:ctr name="CddPduRLowerLayerTxPdu" 
                               type="IDENTIFIABLE">
                          <a:a name="DESC" 
                               value="EN: This container specifies Tx PDUs that are exchanged between the CDD and the standardized BSW module."/>
                          <a:a name="UUID" 
                               value="323667fa-27f1-4855-afee-ad34bb9f401a"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <v:var name="CddPduRApiType" type="ENUMERATION">
                            <a:a name="DESC" 
                                 value="EN: This parameter configures the type of the CDD interface (IF/TP)"/>
                            <a:a name="OPTIONAL" value="true"/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" 
                                 value="f65cca90-c7f3-47be-b265-dbd84b7c4d15"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                             </a:a>
                            <a:da name="ENABLE" value="false"/>
                           <a:da name="DEFAULT" value="IF"/>
                            <a:da name="EDITABLE" value="false"/>
                            <a:da name="RANGE">
                              <a:v>IF</a:v>
                            </a:da>
                          </v:var>
                          <v:var name="CddPduRLowerLayerHandleId" 
                                 type="INTEGER">
                            <a:a name="DESC" 
                                 value="EN: ECU wide unique, symbolic handle for the Pdu."/>
                            <a:a name="OPTIONAL" value="true"/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                            <a:a name="UUID" 
                                 value="d02f209c-e443-444f-9835-971fa0eff972"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                             </a:a>
                            <a:da name="ENABLE" value="false"/>
                            <a:da name="DEFAULT" value="0"/>
                            <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=65535"/>
                              <a:tst expr="&gt;=0"/>
                            </a:da>
                          </v:var>
                          <v:ref name="CddPduRLowerLayerPduRef" 
                                 type="REFERENCE">
                            <a:a name="DESC" 
                                 value="EN: Reference to the &quot;global&quot; Pdu structure to allow harmonization of handle IDs in the COM-Stack."/>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="UUID" 
                                 value="1c6a253b-5a34-4388-8b1c-c0a2dd96c0a1"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                             </a:a>
                            <a:da name="INVALID" type="XPath">
                                   <a:tst expr="text:uniq((../../..//*[@name='CddPduRLowerLayerPduRef']),node:value(.))" false="CddPduRLowerLayerPduRef selection has to be unique across all containers"/>
                            </a:da>
                            <a:da name="REF" 
                                  value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/EcuC/EcucConfigSet/EcucPduCollection/Pdu"/>
                          </v:ref>
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:ctr>
                  <v:ctr name="CddSentGeneral" type="IDENTIFIABLE">
                    <a:a name="DESC" 
                         value="EN: Contains the general configuration parameters of the module."/>
                    <a:a name="UUID" 
                         value="e9825758-8bf4-4d92-bdeb-70878d8182fa"/>
                    <v:var name="CddInstanceId" type="INTEGER">
                      <a:a name="DESC" 
                           value="EN: Specifies the InstanceId of this module instance. If only one instance is present it shall have the Id 0."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" 
                           value="78621e5c-a1b1-4421-ba38-83b3f356fd02"/>
				  <a:da name="EDITABLE" value="false"/>
				  <a:da name="DEFAULT" value="0"/>
                      <a:da name="INVALID" type="Range">
                        <a:tst expr="&lt;=255"/>
                        <a:tst expr="&gt;=0"/>
                      </a:da>
                    </v:var>
                    <v:var name="CddSentDevErrorDetect" type="BOOLEAN">
                      <a:a name="DESC" 
                           value="EN: Switches the development error detection and notification on or off."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" 
                           value="dc0f650c-a827-4f5a-b798-91ecf97ad657"/>
                      <a:da name="DEFAULT" value="false"/>
                    </v:var>
                    <v:var name="CddSentVersionInfoApi" type="BOOLEAN">
                      <a:a name="DESC" 
                           value="EN: Adds / removes the service CddSent_GetVersionInfo() from the code."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" 
                           value="130cd397-4722-4985-a11c-614f12612105"/>
                      <a:da name="DEFAULT" value="false"/>
                    </v:var>
                    <v:var name="CddSentIntegrationWithAsrComStackEnable" type="BOOLEAN">
                      <a:a name="DESC" 
                           value="EN: This parameter is used to enable the integration of Cdd Sent module with Autosar Com Stack.
                                  0: Cdd Sent module is not integrated with Autosar Com stack. Transmission and Reception  will be handled via Application Cdd or wrapper. 
                                  1: Cdd Sent module is integrated as lower module to PduR in Autosar Com stack. Transmission and Reception  will be handled via Com Stack i.e. to and from PduR. 
                                 "/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" 
                           value="c6ba164f-ec52-4527-ae79-7e043eb59ec7"/>
                      <a:da name="DEFAULT" value="false"/>
                    </v:var>
                  </v:ctr>
                   <v:ctr name="CddSentDemEventParameterRefs" type="IDENTIFIABLE">
                    <a:a name="DESC"
                         value="EN: Container for the references to DemEventParameter elements which shall be invoked using the API Dem_SetEventStatus in case the corresponding error occurs. The EventId is taken from the referenced DemEventParameter&apos;s DemEventId symbolic value. The standardized errors are provided in this container and can be extended by vendor-specific error references."/>
                    <a:a name="OPTIONAL" value="true"/>
                    <a:a name="UUID" value="ddfb49cd-fc6d-4851-bf71-7b6e64407d85"/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                    <a:da name="ENABLE" value="false"/>
                    <v:ref name="CDD_SENT_E_HARDWARE_ERROR"
                           type="SYMBOLIC-NAME-REFERENCE">
                      <a:a name="DESC"
                           value="EN: Reference to configured DEM event to report &quot;Hardware failure&quot;."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="OPTIONAL" value="true"/>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="UUID"
                           value="acaa7683-7d07-4ba1-9900-939db2754e20"/>
                      <a:da name="ENABLE" value="false"/>
                      <a:da name="REF"
                            value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Dem/DemConfigSet/DemEventParameter"/>
					  <a:da name="INVALID" type="XPath" expr="node:refexists(node:value(.))" false="Dem event should be assigned and it should not be empty and invalid"/>
                    </v:ref>
                    </v:ctr>
                  <d:ref type="REFINED_MODULE_DEF" 
                         value="ASPath:/AUTOSAR/EcucDefs/Cdd"/>
                </v:ctr>
              </d:chc>
              <d:chc name="myEcuParameterDefinition" type="AR-ELEMENT" 
                     value="ECU_PARAMETER_DEFINITION">
                <d:ctr type="AR-ELEMENT">
                  <a:a name="DEF" 
                       value="ASPath:/AR_PACKAGE_SCHEMA/ECU_PARAMETER_DEFINITION"/>
			      <a:a name="UUID" value="ec1a88d2-9ddd-4f9f-ad80-fac712d0a166"/>
                  <d:lst name="MODULE_REF">
                    <d:ref type="MODULE_REF" 
                           value="ASPath:/TI_F29H85x/Cdd_Sent/Cdd"/>
                  </d:lst>
                </d:ctr>
              </d:chc>
            </d:lst>
          </d:ctr>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>

</datamodel>
