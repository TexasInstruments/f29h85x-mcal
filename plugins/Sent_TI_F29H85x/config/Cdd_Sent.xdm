                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                        </v:var>
                        <v:var name="Frequency_Drift_Error" type="BOOLEAN">
                              <a:a name="DESC" 
                                   value="EN: The ratio of the calibration pulse to the message length varies by greater than 1/64 or less than -1/64 from one message to another"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                   type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
