                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=4294967295"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                            </v:var>
                            <v:ref name="CddSentMTPSensorPduID" type="REFERENCE">
                                   <a:a name="DESC" 
                                        value="EN: This parameter will be used when CddSentIntegrationWithAsrComStackEnable is enabled. This Pdu identifier will be used in transmit function to address the respective sensor. "/>
                                   <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                        type="IMPLEMENTATIONCONFIGCLASS">
                                   <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                   <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
