                            <ECUC-BOOLEAN-PARAM-DEF UUID="e0e7a44c-814e-4cf9-846e-cf4a228e6414">
                              <SHORT-NAME>Fast_Channel_Sync_Pulse_Error</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Indicates that the synchronization pulse varies by more than 25% from the expected 56 clock ticks</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
