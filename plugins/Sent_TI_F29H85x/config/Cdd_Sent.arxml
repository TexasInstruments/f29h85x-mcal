            <ECUC-MODULE-DEF UUID="8de76b7c-c31f-441c-a674-5819632fed2c">
              <SHORT-NAME>Cdd</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Configuration of the CddSent module</L-2>
              </DESC>
