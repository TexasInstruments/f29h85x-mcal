                    <ECUC-BOOLEAN-PARAM-DEF UUID="65211f7b-5779-4167-8a53-297d80117664">
                      <SHORT-NAME>CddSentIntegrationWithAsrComStackEnable</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">This parameter is used to enable the integration of Cdd Sent module with Autosar Com Stack.                                   0: Cdd Sent module is not integrated with Autosar Com stack. Transmission and Reception  will be handled via Application Cdd or wrapper.                                    1: Cdd Sent module is integrated as lower module to PduR in Autosar Com stack. Transmission and Reception  will be handled via Com Stack i.e. to and from PduR.                                   </L-2>
                      </DESC>
                      <SCOPE>LOCAL</SCOPE>
                      <ORIGIN>Texas Instruments</ORIGIN>
                      <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
