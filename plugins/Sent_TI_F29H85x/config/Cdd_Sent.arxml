                <ECUC-PARAM-CONF-CONTAINER-DEF UUID="ECUC:b9ea6561-fd73-4381-bdb6-8e027a43ad62">
                  <SHORT-NAME>CddSentConfig</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">This container contains the configuration parameters and sub containers of the CddSent module.</L-2>
