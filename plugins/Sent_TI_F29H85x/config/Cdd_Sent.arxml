                              <SHORT-NAME>Successive_Calibration_Pulse_Error</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">The successive calibration pulses differ by greater than +1.5625 or less than -1.5625</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
