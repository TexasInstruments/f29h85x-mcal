                              <DEFAULT-VALUE>false</DEFAULT-VALUE>
                            </ECUC-BOOLEAN-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="28b0e71f-2de1-4986-a1d1-123ae3bed94c">
                              <SHORT-NAME>Frequency_Drift_Error</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">The ratio of the calibration pulse to the message length varies by greater than 1/64 or less than -1/64 from one message to another</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
