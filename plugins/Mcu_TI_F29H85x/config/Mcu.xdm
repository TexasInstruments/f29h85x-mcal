                          <a:a name="UUID" 
                               value="e1823c43-d924-415e-8802-19330a6b34b3"/>
                          <a:da name="DEFAULT" value="true"/>
                        </v:var>
                        <v:var name="MCU_PERIPH_CLK_SENT6" type="BOOLEAN">
                          <a:a name="DESC" value="EN: SENT6 Clock Enable Bit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
