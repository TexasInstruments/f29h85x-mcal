                          <a:a name="UUID" 
                               value="ea715715-da81-4c2f-b520-918d9701bf2a"/>
                          <a:da name="DEFAULT" value="true"/>
                        </v:var>
                      </v:ctr>
                      <v:ctr name="McuPeripheralClock32" type="IDENTIFIABLE">
                        <a:a name="DESC" value="EN: Device specific Peripheral Clock settings - WADI"/>
                        <a:a name="UUID" 
                             value="e1baba35-a0b0-469e-8c12-a24bdcc99285"/>
                        <a:a name="TAB" value="McuPeripheralClkConfig1"/>
                        <v:var name="MCU_PERIPH_CLK_WADI1" type="BOOLEAN">
                          <a:a name="DESC" value="EN: WADI1 Clock Enable Bit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" 
                               value="1f767690-bcd2-4c24-b244-e67f73197b87"/>
                          <a:da name="DEFAULT" value="true"/>
                        </v:var>
                        <v:var name="MCU_PERIPH_CLK_WADI2" type="BOOLEAN">
                          <a:a name="DESC" value="EN: WADI2 Clock Enable Bit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
