<?xml version='1.0'?>
<datamodel version="8.0"
           xmlns="http://www.tresos.de/_projects/DataModel2/18/root.xsd"
           xmlns:a="http://www.tresos.de/_projects/DataModel2/18/attribute.xsd"
           xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd"
           xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">

  <d:ctr type="AUTOSAR" factory="autosar"
         xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd"
         xmlns:ce="http://www.tresos.de/_projects/DataModel2/18/childenable.xsd"
         xmlns:cd="http://www.tresos.de/_projects/DataModel2/08/customdata.xsd"
         xmlns:f="http://www.tresos.de/_projects/DataModel2/14/formulaexpr.xsd"
         xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd"
         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"
         xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TI_F29H85x" type="AR-PACKAGE">
        <a:a name="UUID" value="59d0c860-31ea-4817-b5ec-924da6304cd9"/>
        <d:lst type="ELEMENTS">
          <d:chc name="Mcu" type="AR-ELEMENT" value="MODULE-DEF">
            <v:ctr type="MODULE-DEF">
              <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                <ad:ADMIN-DATA>
                  <ad:DOC-REVISIONS>
                    <ad:DOC-REVISION>
                      <ad:REVISION-LABEL>4.3.1</ad:REVISION-LABEL>
                      <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                    </ad:DOC-REVISION>
                  </ad:DOC-REVISIONS>
                </ad:ADMIN-DATA>
              </a:a>
              <a:a name="DESC"
                   value="EN: Configuration of the Mcu (Microcontroller Unit) module."/>
              <a:a name="LOWER-MULTIPLICITY" value="1"/>
              <a:a name="POSTBUILDVARIANTSUPPORT" value="true"/>
              <a:a name="RELEASE" value="asc:4.3.1"/>
              <a:a name="UPPER-MULTIPLICITY" value="1"/>
              <a:a name="UUID" value="59d0c860-31ea-4817-b5ec-924da6304dc9"/>
              <v:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION">
                <a:a name="IMPLEMENTATIONCONFIGCLASS"
                     type="IMPLEMENTATIONCONFIGCLASS">
                  <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                </a:a>
                <a:a name="LABEL" value="Config Variant"/>
                <a:a name="UUID" value="7d987555-b981-439c-96eb-1cb2aad9e777"/>
                <a:da name="DEFAULT" value="VariantPostBuild"/>
                <a:da name="RANGE">
                  <a:v>VariantPostBuild</a:v>
                  <a:v>VariantPreCompile</a:v>
                </a:da>
              </v:var>
              <v:ctr name="McuGeneralConfiguration" type="IDENTIFIABLE">
                <a:a name="DESC"
                     value="EN: This container contains the configuration (parameters) of the MCU driver."/>
                <a:a name="UUID" value="9fc20e0c-35b4-4f58-834f-2413df677af3"/>
                <v:var name="McuDevErrorDetect" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: Switches the development error detection and notification on or off."/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="b23de9eb-4979-4b3b-bc31-f2b8f1d1d518"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
                <v:var name="McuGetRamStateApi" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: Pre-processor switch to enable/disable the API Mcu_GetRamState."/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="b473f85f-d019-42eb-a2be-e2f0211ed3a9"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <v:var name="McuInitClock" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: If this parameter is set to FALSE, the clock initialization has to be disabled from the MCU driver. This concept applies when there are some write once clock registers and a bootloader is present. If this parameter is set to TRUE, the MCU driver is responsible of the clock initialization."/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="36d63278-dab4-473a-911d-ee776916a764"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <v:var name="McuNoPll" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: This parameter shall be set True, if the H/W does not have a PLL or the PLL circuitry is enabled after the power on without S/W intervention. In this case MCU_DistributePllClock has to be disabled and  MCU_GetPllStatus has to return MCU_PLL_STATUS_UNDEFINED. Otherwise this parameters has to be set False"/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="5faa2aa7-df4e-47cd-b4e6-c57d9186d49d"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <v:var name="McuPerformResetApi" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: Pre-processor switch to enable / disable the use of the function Mcu_PerformReset()"/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="4d8ee4b3-d1f8-488f-89d8-32ea2facaffa"/>
                  <a:da name="DEFAULT" value="true"/>
                </v:var>
                <v:var name="McuVersionInfoApi" type="BOOLEAN">
                  <a:a name="DESC"
                       value="EN: Pre-processor switch to enable / disable the API to read out the modules version information."/>
                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                       type="IMPLEMENTATIONCONFIGCLASS">
                    <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                  </a:a>
                  <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                  <a:a name="SCOPE" value="LOCAL"/>
                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                  <a:a name="UUID" value="1a50876a-4fa4-4f98-9951-15411b993c4f"/>
                  <a:da name="DEFAULT" value="false"/>
                </v:var>
              </v:ctr>
              <v:lst name="McuModuleConfiguration" type="MULTIPLE-CONFIGURATION-CONTAINER">
                <a:da name="MIN" value="1"/>
                <v:ctr name="McuModuleConfiguration" type="MULTIPLE-CONFIGURATION-CONTAINER">
                  <a:a name="DESC"
                       value="EN: This container contains the configuration (parameters) of the MCU driver"/>
                  <a:a name="UUID" value="5eb0df1b-e149-40ec-aa3d-7d3fd1c9bdfa"/>
                  <v:var name="McuClockSrcFailureNotification" type="ENUMERATION">
                    <a:a name="DESC"
                         value="EN: Enables/Disables clock failure notification. In case this feature is not supported by HW the setting should be disabled."/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="7f35a273-edab-4b99-b3cf-cc1f8c09c580"/>
                    <a:da name="DEFAULT" value="DISABLED"/>
                    <a:da name="RANGE">
                      <a:v>DISABLED</a:v>
                      <a:v>ENABLED</a:v>
                    </a:da>
                  </v:var>
                  <v:var name="McuNumberOfMcuModes" type="INTEGER">
                    <a:a name="DESC"
                         value="EN: This parameter shall represent the number of Modes available for the MCU."/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="823392a2-1a5e-4596-bb9a-5d93de6391c9"/>
                    <a:da name="DEFAULT" value="1"/>
                    <a:da name="INVALID" type="Range">
                      <a:tst expr="&lt;=255"/>
                      <a:tst expr="&gt;=1"/>
                    </a:da>
                  </v:var>
                  <v:var name="McuRamSectors" type="INTEGER">
                    <a:a name="DESC"
                         value="EN: This parameter shall represent the number of RAM sectors available for the MCU."/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                    <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="ffd9f3d9-ae1b-437e-b93a-2e4291b2b711"/>
                    <a:da name="DEFAULT" value="0"/>
                    <a:da name="INVALID" type="Range">
                      <a:tst expr="&lt;=4294967295"/>
                      <a:tst expr="&gt;=0"/>
                    </a:da>
                  </v:var>
                  <v:var name="McuResetSetting" type="INTEGER">
                    <a:a name="DESC"
                         value="EN: This parameter relates to the MCU specific reset configuration. This applies to the function Mcu_PerformReset, which performs a microcontroller reset using the hardware feature of the microcontroller."/>
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                      <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="OPTIONAL" value="true"/>
                    <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                    <a:a name="SCOPE" value="LOCAL"/>
                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                    <a:a name="UUID" value="0912db63-9529-4f23-a8bc-6608f804e339"/>
                    <a:da name="ENABLE" value="false"/>
                    <a:da name="DEFAULT" value="1"/>
                    <a:da name="INVALID" type="Range">
                      <a:tst expr="&lt;=255"/>
                      <a:tst expr="&gt;=1"/>
                    </a:da>
                  </v:var>
                  <v:lst name="McuClockSettingConfig" type="MAP">
                    <a:da name="MIN" value="1"/>
                    <v:ctr name="McuClockSettingConfig" type="IDENTIFIABLE">
                      <a:a name="DESC"
                           value="EN: This container contains the configuration (parameters) for the Clock settings of the MCU.  Please see MCU031 for more information on the MCU clock settings."/>
                      <a:a name="UUID"
                           value="12f74ca9-646b-48f0-ba34-733254136656"/>
                      <v:var name="McuClockSettingId" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: The Id of this McuClockSettingConfig to be used as argument for the API call &quot;Mcu_InitClock&quot;."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                        <a:a name="UUID"
                             value="5ebff19c-241a-493a-86b3-7574da008997"/>
                        <a:da name="DEFAULT" value="0"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=255"/>
                          <a:tst expr="&gt;=0"/>
                        </a:da>
                      </v:var>
                      <v:lst name="McuClockReferencePoint" type="MAP">
                        <a:da name="MIN" value="1"/>
                        <v:ctr name="McuClockReferencePoint" type="IDENTIFIABLE">
                          <a:a name="DESC"
                               value="EN: This container defines a reference point in the Mcu Clock tree. It defines the frequency which then can be used by other modules as an input value. Lower multiplicity is 1, as even in the simplest case (only one frequency is used), there is one frequency to be defined."/>
                          <a:a name="UUID"
                               value="0463be10-4ccb-4bf4-a6c9-90ce10f4158c"/>
                          <v:var name="McuClockReferencePointFrequency"
                                 type="FLOAT">
                            <a:a name="DESC"
                                 value="EN: This is the frequency for the specific instance of the McuClockReferencePoint container. It shall be given in Hz."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                            <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                            <a:a name="SCOPE" value="ECU"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID"
                                 value="39ab3639-f00e-4666-ac1a-57dea120597d"/>
                            <a:da name="DEFAULT" value="2.0E8"/>
                            <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=Infinity"/>
                              <a:tst expr="&gt;=0.0"/>
                            </a:da>
                          </v:var>
                        </v:ctr>
                      </v:lst>
                      <v:ctr name="McuClkConfig" type="IDENTIFIABLE">
                        <a:a name="DESC"
                             value="EN: Device specific clock settings"/>
                        <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                        <v:var name="McuClockSource" type="ENUMERATION">
                          <a:a name="DESC"
                               value="EN: Configures the clock source."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: Select Clock Source"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="MCU_CLKSRC_XTAL"/>
                          <a:da name="RANGE">
                            <a:v>MCU_CLKSRC_OSC2</a:v>
                            <a:v>MCU_CLKSRC_OSC1</a:v>
                            <a:v>MCU_CLKSRC_XTAL</a:v>
                            <a:v>MCU_CLKSRC_XTAL_SE</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="McuExternalClkFreq" type="INTEGER">
                          <a:a name="DESC"
                               value="EN: Frequency of the external clock source (XTAL) in Hz."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: External Clock Frequency"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="ENABLE" type="XPath" expr="(../McuClockSource != 'MCU_CLKSRC_OSC2') or (../McuClockSource != 'MCU_CLKSRC_OSC1')"/>
                          <a:da name="DEFAULT" value="20000000"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=25000000"/>
                            <a:tst expr="&gt;=10000000"/>
                          </a:da>
                        </v:var>
                        <v:var name="McuSysClkDiv" type="INTEGER">
                          <a:a name="DESC"
                               value="EN: Configures the System Clock Divider. Value should be 1 or even value up to 64."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: System Clock Divider"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="1"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=64"/>
                            <a:tst expr="&gt;=1"/>
                          </a:da>
                        </v:var>
                        <v:var name="McuHsmClkDiv" type="ENUMERATION">
                          <a:a name="DESC"
                               value="EN: Configures the HSM Clock Divider. Value should be 1 or even value up to 16."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: HSM Clock Divider"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="MCU_HSMCLK_DIV_16"/>
                          <a:da name="RANGE">
                            <a:v>MCU_HSMCLK_DIV_1</a:v>
                            <a:v>MCU_HSMCLK_DIV_2</a:v>
                            <a:v>MCU_HSMCLK_DIV_4</a:v>
                            <a:v>MCU_HSMCLK_DIV_8</a:v>
                            <a:v>MCU_HSMCLK_DIV_16</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="McuEpwmClkDiv" type="ENUMERATION">
                          <a:a name="DESC"
                               value="EN: Configures the EPWM Clock Divider. Value should be 1 or 2."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: EPWM Clock Divider"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="MCU_EPWMCLK_DIV_2"/>
                          <a:da name="RANGE">
                            <a:v>MCU_EPWMCLK_DIV_1</a:v>
                            <a:v>MCU_EPWMCLK_DIV_2</a:v>
                          </a:da>
                        </v:var>
                        <v:var name="McuEmifClkDiv" type="ENUMERATION">
                          <a:a name="DESC"
                               value="EN: Configures the EMIF Clock Divider. Value should be 1 or 2 or 4."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                               type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="LONG-NAME" value="EN: EMIF Clock Divider"/>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="MCU_EMIFCLK_DIV_2"/>
                          <a:da name="RANGE">
                            <a:v>MCU_EMIFCLK_DIV_1</a:v>
                            <a:v>MCU_EMIFCLK_DIV_2</a:v>
                            <a:v>MCU_EMIFCLK_DIV_4</a:v>
                          </a:da>
                        </v:var>
                      </v:ctr>
                      <v:lst name="McuLinClkConfig" type="MAP">
                        <a:da name="MIN" value="1"/>
                        <a:da name="MAX" value="2"/>
                        <v:ctr name="McuLinClkConfig" type="IDENTIFIABLE">
                          <a:a name="DESC"
                               value="EN: Device specific Lin clock settings"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <v:var name="McuLinInstance" type="ENUMERATION">
                            <a:a name="DESC"
                                 value="EN: Configures the Instance ID for Lin module."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="LONG-NAME" value="EN: Select Lin Instance ID"/>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <a:da name="INVALID" type="XPath" expr="text:uniq((../../..//*[@name='McuLinInstance']),node:value(.))" false="Lin Instance Id should be unique "/>
                            <a:da name="DEFAULT" value="MCU_LIN_A"/>
                            <a:da name="RANGE">
                              <a:v>MCU_LIN_A</a:v>
                              <a:v>MCU_LIN_B</a:v>
                            </a:da>
                          </v:var>
