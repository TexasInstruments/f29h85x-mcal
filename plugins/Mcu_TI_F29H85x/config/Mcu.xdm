                      <v:ctr name="McuPeripheralClock30" type="IDENTIFIABLE">
                        <a:a name="DESC" value="EN: Device specific Peripheral Clock settings - SENT"/>
                        <a:a name="UUID" 
                             value="ecbc9cf8-26fe-4666-88d0-e736cfbea5ce"/>
                        <a:a name="TAB" value="McuPeripheralClkConfig1"/>
