                        </v:var>
                      </v:ctr>
                    </v:ctr>
                  </v:lst>
                  <v:ctr name="McuDemEventParameterRefs" type="IDENTIFIABLE">
                    <a:a name="DESC"
                         value="EN: Container for the references to DemEventParameter elements which shall be invoked using the API Dem_SetEventStatus in case the corresponding error occurs. The EventId is taken from the referenced DemEventParameter&apos;s DemEventId symbolic value. The standardized errors are provided in this container and can be extended by vendor-specific error references."/>
                    <a:a name="OPTIONAL" value="true"/>
                    <a:a name="UUID" value="eaf38473-275f-4538-99f6-c3b4df6a06e7"/>
                    <a:da name="ENABLE" value="false"/>
                    <v:ref name="MCU_E_CLOCK_FAILURE"
                           type="SYMBOLIC-NAME-REFERENCE">
                      <a:a name="DESC"
                           value="EN: Reference to configured DEM event to report &quot;Clock source failure&quot;."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                        <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="OPTIONAL" value="true"/>
                      <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="UUID"
                           value="567d173b-4e56-401d-9d81-a034f4f2bb94"/>
                      <a:da name="ENABLE" value="false"/>
                      <a:da name="REF"
                            value="ASPathDataOfSchema:/AUTOSAR/EcucDefs/Dem/DemConfigSet/DemEventParameter"/>
					  <a:da name="INVALID" type="XPath" expr="node:refexists(node:value(.))" false="Dem event should be assigned and it should not be empty and invalid"/>
                    </v:ref>
                  </v:ctr>
                  <v:lst name="McuModeSettingConf" type="MAP">
                    <a:da name="MIN" value="1"/>
                    <a:da name="MAX" value="2"/>
                    <v:ctr name="McuModeSettingConf" type="IDENTIFIABLE">
                      <a:a name="DESC"
                           value="EN: This container contains the configuration (parameters) for the Mode setting of the MCU.  Please see MCU035 for more information on the MCU mode settings."/>
                      <a:a name="UUID"
                           value="91d79876-630b-4dd0-a0e9-92ae3a892351"/>
                      <v:var name="McuMode" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: The parameter represents the MCU Mode settings. IDLE Mode :0, STANDBY mode :1"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PreCompile">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                        <a:a name="UUID"
                             value="b17981d7-aaf9-4ad6-bbd4-3be913a6520a"/>  
                        <a:da name="DEFAULT" value="0"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=1"/>
                          <a:tst expr="&gt;=0"/>
                        </a:da>
                      </v:var>
                      <v:var name="McuQualPeriod" type="INTEGER">
                        <a:a name="DESC" value="EN: The number of OSCCLK clock cycles used to qualify the selected inputs when waking from STANDBY mode."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="Texas Instruments"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" 
                             value="1002bca3-8957-4a1c-a451-8c7baec92626"/>
                        <a:da name="DEFAULT" value="2"/>
                        <a:da name="ENABLE" type="XPath" expr="../McuMode = '1'"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=65"/>
                          <a:tst expr="&gt;=2"/>
                        </a:da>
                      </v:var>
                      <v:var name="McuEnableWDWakeup" type="BOOLEAN">
                        <a:a name="DESC" value="EN: Enable/Disable using watchdog to wakeup from standby or halt mode"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="Texas Instruments"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID" 
                             value="1037f0fc-4703-456e-95bf-0b3c8a3fe1d5"/>
                        <a:da name="DEFAULT" value="false"/>
                        <a:da name="ENABLE" type="XPath" expr="../McuMode = '1'"/>
                      </v:var>
                    </v:ctr>
                  </v:lst>
                  <v:lst name="McuRamSectorSettingConf" type="MAP">
                    <v:ctr name="McuRamSectorSettingConf" type="IDENTIFIABLE">
                      <a:a name="DESC"
                           value="EN: This container contains the configuration (parameters) for the RAM Sector setting. Please see MCU030 for more information on RAM sec-tor settings."/>
                      <a:a name="UUID"
                           value="7d61465c-ab26-45c0-95a3-54c705d32c5f"/>
                      <v:var name="McuRamDefaultValue" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: This parameter shall represent the Data pre-setting to be initialized"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID"
                             value="f3ea71b0-e082-4217-b381-01ea42cc5ad6"/>
                        <a:da name="DEFAULT" value="0"/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=255"/>
                          <a:tst expr="&gt;=0"/>
                        </a:da>
                      </v:var>
                      <v:var name="McuRamSectionBaseAddress" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: This parameter shall represent the MCU RAM section base address"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID"
                             value="84a431c3-86b2-4039-a426-99a18869b2b8"/>
                        <a:da name="DEFAULT" value="0"/>
                        <a:da name="INVALID" type="XPath" expr=" ((node:value(.) mod (../McuRamSectionWriteSize)) = 0 )" false="McuRamSectionBaseAddress should be aligned to byte boundary as mentioned in McuRamSectionWriteSize "/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=4294967295"/>
                          <a:tst expr="&gt;=0"/>
                        </a:da>
                      </v:var>
                      <v:var name="McuRamSectionSize" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: This parameter represents the MCU RAM Section size in bytes."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID"
                             value="311aad3b-e574-49a9-90a2-56ed745ce784"/>
                        <a:da name="DEFAULT" value="0"/>
                        <a:da name="INVALID" type="XPath" expr=" ((node:value(.) mod (../McuRamSectionWriteSize)) = 0 and (node:value(.) &gt;= ../McuRamSectionWriteSize) )" false="McuRamSectionSize should be multiple of McuRamSectionWriteSize and should not be less than McuRamSectionWriteSize "/>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=4294967295"/>
                          <a:tst expr="&gt;=0"/>
                        </a:da>
                      </v:var>
                      <v:var name="McuRamSectionWriteSize" type="INTEGER">
                        <a:a name="DESC"
                             value="EN: This parameter shall define the size in bytes of data which can be written into RAM at once."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS"
                             type="IMPLEMENTATIONCONFIGCLASS">
                          <icc:v vclass="PostBuild">VariantPostBuild</icc:v>
                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                        <a:a name="POSTBUILDVARIANTVALUE" value="true"/>
                        <a:a name="SCOPE" value="LOCAL"/>
                        <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                        <a:a name="UUID"
                             value="2fa95053-5c5f-48fb-9975-d03ba1bc9ddf"/>
                        <a:da name="DEFAULT" value="1"/>
                        <a:da name="RANGE">
                          <a:v>1</a:v>
                          <a:v>2</a:v>
                          <a:v>4</a:v>
                          <a:v>8</a:v>
                        </a:da>
                        <a:da name="INVALID" type="Range">
                          <a:tst expr="&lt;=8"/>
                          <a:tst expr="&gt;=1"/>
                        </a:da>                        
                      </v:var>
                    </v:ctr>
                  </v:lst>
                </v:ctr>
              </v:lst>
              <v:ctr name="McuPublishedInformation" type="IDENTIFIABLE">
                <a:a name="DESC"
                     value="EN: Container holding all MCU specific published information parameters"/>
                <a:a name="UUID" value="f85a6677-e794-4955-9f83-e4421e6f9c86"/>
                <v:lst name="McuResetReasonConf" type="MAP">
                  <a:da name="MIN" value="1"/>
                  <a:da name="MAX" value="7"/>
                  <v:ctr name="McuResetReasonConf" type="IDENTIFIABLE">
                    <a:a name="DESC"
                         value="EN: This container contains the configuration for the different type of reset reason that can be retrieved from Mcu_GetResetReason Api."/>
                    <a:a name="UUID"
                         value="8c2b3d9d-d29b-4cdf-9315-d3eb4f9273fd"/>
                    <v:var name="McuResetReason" type="INTEGER">
                      <a:a name="DESC"
                           value="EN: The parameter represents the different type of reset that a Micro supports. This parameter is referenced by the parameter EcuMResetReason in the ECU State manager module."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                           type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PublishedInformation">VariantPostBuild</icc:v>
                        <icc:v vclass="PublishedInformation">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="AUTOSAR_ECUC"/>
                      <a:a name="SCOPE" value="ECU"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="true"/>
                      <a:a name="UUID"
                           value="cf8d6a03-0723-4d4e-a807-650a11e14087"/>
                      <a:da name="DEFAULT" type="XPath"
                            expr="node:fallback(&quot;-> (./@index) &quot;,'0')"/>
                      <a:da name="INVALID" type="Range">
                        <a:tst expr="&lt;=6"/>
                        <a:tst expr="&gt;=0"/>
                      </a:da>
                    </v:var>
                  </v:ctr>
                </v:lst>
              </v:ctr>
              <d:ref type="REFINED_MODULE_DEF"
                     value="ASPath:/AUTOSAR/EcucDefs/Mcu"/>
            </v:ctr>
          </d:chc>
          <d:chc name="myEcuParameterDefinition" type="AR-ELEMENT"
                 value="ECU_PARAMETER_DEFINITION">
            <d:ctr type="AR-ELEMENT">
              <a:a name="DEF"
                   value="ASPath:/AR_PACKAGE_SCHEMA/ECU_PARAMETER_DEFINITION"/>
			  <a:a name="UUID" value="26b944a1-07de-4703-9f25-3b6bcd717321"/>
              <d:lst name="MODULE_REF">
                <d:ref type="MODULE_REF" value="ASPath:/TI_F29H85x/Mcu"/>
              </d:lst>
            </d:ctr>
          </d:chc>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>

</datamodel>
