              </DESC>
              <SUB-CONTAINERS>
                <ECUC-PARAM-CONF-CONTAINER-DEF UUID="8c2b3d9d-d29b-4cdf-9315-d3eb4f9273fd">
                  <SHORT-NAME>McuResetReasonConf</SHORT-NAME>
                  <DESC>
