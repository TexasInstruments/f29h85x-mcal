                          <CONFIG-CLASS>PUBLISHED-INFORMATION</CONFIG-CLASS>
                          <CONFIG-VARIANT>VARIANT-POST-BUILD</CONFIG-VARIANT>
                        </ECUC-VALUE-CONFIGURATION-CLASS>
                        <ECUC-VALUE-CONFIGURATION-CLASS>
                          <CONFIG-CLASS>PUBLISHED-INFORMATION</CONFIG-CLASS>
                          <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                        </ECUC-VALUE-CONFIGURATION-CLASS>
                      </VALUE-CONFIG-CLASSES>
                      <SYMBOLIC-NAME-VALUE>true</SYMBOLIC-NAME-VALUE>
                      <!-- @Calculated /TI_F29H85x/Mcu/McuPublishedInformation/McuResetReasonConf/McuResetReason: DEFAULT(XPath: string(text:split(&apos;0 1 2 3 4 5 6&apos;)[var:set(&apos;idx&apos;,position()) and normalize-space(text:split(&apos;MCU_POWER_ON_RESET MCU_EXTERNAL_RESET MCU_ESM_NMI_WATCHDOG_RESET MCU_WATCHDOG_RESET MCU_SW_RESET MCU_ESM_RESET MCU_RESET_UNDEFINED&apos;)[position() = $idx]) = name(node:fallback(node:current()/..,&apos;&apos;))]))-->
                      <MAX>6</MAX>
                      <MIN>0</MIN>
                    </ECUC-INTEGER-PARAM-DEF>
                  </PARAMETERS>
                </ECUC-PARAM-CONF-CONTAINER-DEF>
              </SUB-CONTAINERS>
            </ECUC-PARAM-CONF-CONTAINER-DEF>
          </CONTAINERS>
        </ECUC-MODULE-DEF>
