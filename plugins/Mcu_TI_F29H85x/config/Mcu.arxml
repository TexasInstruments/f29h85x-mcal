                    <ECUC-INTEGER-PARAM-DEF UUID="311aad3b-e574-49a9-90a2-56ed745ce784">
                      <SHORT-NAME>McuRamSectionSize</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">This parameter represents the MCU RAM Section size in bytes.</L-2>
                      </DESC>
