            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="891615c4-8b90-4f02-b220-bcb2d3fe75ea">
              <SHORT-NAME>McuPublishedInformation</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Container holding all MCU specific published information parameters</L-2>
              </DESC>
