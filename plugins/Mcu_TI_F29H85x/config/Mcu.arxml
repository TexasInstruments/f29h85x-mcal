                          </DESC>
                          <!-- @Calculated /TI_F29H85x/Mcu/McuModuleConfiguration/McuClockSettingConfig/McuClkConfig/McuExternalClkFreq: ENABLE(XPath: (../McuClockSource != &apos;MCU_CLKSRC_OSC2&apos;) or (../McuClockSource != &apos;MCU_CLKSRC_OSC1&apos;))-->
