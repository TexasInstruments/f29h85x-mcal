                              <SHORT-NAME>CddAdcPpbEventInterruptNotification</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Callback function for each PPB that generaterd the event interrupt</L-2>
                              </DESC>
                              <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
