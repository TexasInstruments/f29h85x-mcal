                          <SHORT-NAME>CDD_ADC_TEST_NODE_VSSA</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_VREFLOA</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_VREFLOB</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_CDAC1H</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
