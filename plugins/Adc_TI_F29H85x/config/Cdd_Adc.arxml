                        <ECUC-INTEGER-PARAM-DEF UUID="315d27d8-412e-4f3c-aa0a-4ea693c16b06">
                          <SHORT-NAME>CddAdcInterruptCycleoffset</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">This parameter defines the delay from the fall edge of the SOC and the interrupt to be generated in SYSCLK cycles .</L-2>
                          </DESC>
