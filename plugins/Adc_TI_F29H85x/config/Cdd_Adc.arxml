                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_CDAC3H</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_CDAC3L</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
                          <SHORT-NAME>CDD_ADC_TEST_NODE_CDAC4H</SHORT-NAME>
                          <ORIGIN>Texas Instruments</ORIGIN>
                        </ECUC-ENUMERATION-LITERAL-DEF>
                        <ECUC-ENUMERATION-LITERAL-DEF>
