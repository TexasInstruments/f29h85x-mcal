                            <ECUC-BOOLEAN-PARAM-DEF UUID="8837d989-3b5f-46e6-8955-0c17ab4ac738">
                              <SHORT-NAME>CddAdcPpbEnableTwosComplement</SHORT-NAME>
                              <DESC>
