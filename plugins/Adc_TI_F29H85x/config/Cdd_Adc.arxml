                          <DEFAULT-VALUE>0</DEFAULT-VALUE>
                          <MAX>4294967295</MAX>
                          <MIN>0</MIN>
                        </ECUC-INTEGER-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="914d50e7-7bc1-4766-aff4-145fc2731d66">
                          <SHORT-NAME>CddAdcGroupConversionMode</SHORT-NAME>
                          <DESC>
