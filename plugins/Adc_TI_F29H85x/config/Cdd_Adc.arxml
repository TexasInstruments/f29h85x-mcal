                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF UUID="5e21c7d0-f903-415c-988c-54b5b18caf8e">
                              <SHORT-NAME>CddAdcPpbTripHighLimit</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">High limit - used for limit checking for all types of PB results.                                  When comparing to an ADCPPBxRESULT register, the upper bits will be ignored:TRIPHI[23:17] will be ignored in 16 bit mode and                                  TRIPHI[23:13] will be ignored in 12 bit mode</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <MAX>8388607</MAX>
                              <MIN>-8388608</MIN>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="d9c5c4c0-898a-4931-ab64-a1111a434bb5">
                              <SHORT-NAME>CddAdcPpbExtendedTripLowEnable</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">This parameters configures the extended trip limit low.This value can be used to compare any PPBRESULT.                                                 This is non-editable It is always enabled</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
