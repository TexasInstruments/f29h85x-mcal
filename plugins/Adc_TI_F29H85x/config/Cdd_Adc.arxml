                            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="f1412057-72f6-4233-ac1a-0fa52eaae32d">
                              <SHORT-NAME>CddAdcTripFilterConfig</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">This container contains the channel configuration (parameters) depending on the hardware capability.</L-2>
                              </DESC>
                              <!-- @Calculated /TI_F29H85x/Cdd_Adc/Cdd/CddAdcConfigSet/CddAdcHwUnit/CddAdcPpbConfig/CddAdcTripFilterConfig: ENABLE(XPath: (../CddAdcPpbTripFilterEnable = &apos;true&apos;))-->
