                          <DEFAULT-VALUE>false</DEFAULT-VALUE>
                        </ECUC-BOOLEAN-PARAM-DEF>
                        <ECUC-BOOLEAN-PARAM-DEF UUID="09f9f9dc-292f-4fc5-a525-e24ea7658b7c">
                          <SHORT-NAME>CddAdcPpbTripHighInterruptEnable</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Enabling this allows the corresponding rising trip high flag in the PPB to activate the event signal to the PIE.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
