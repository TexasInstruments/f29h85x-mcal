                              <DEFAULT-VALUE>false</DEFAULT-VALUE>
                            </ECUC-BOOLEAN-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="4262d13a-f457-4b61-ad3d-48fdf29a3419">
                              <SHORT-NAME>CddAdcPpbCompareSource</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">This parameters configures the PPB result type used for the zero-crossing detect logic and threshold compare.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
