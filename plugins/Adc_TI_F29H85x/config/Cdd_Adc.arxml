                          <SHORT-NAME>CddAdcPpbTripLowInterruptEnable</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Enabling this allows the corresponding rising trip low flag in the PPB to activate the event signal to the PIE.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
