                      <REFERENCES>
                        <ECUC-REFERENCE-DEF UUID="4373826d-5557-455c-9673-99ceb99fd686">
                          <SHORT-NAME>CddAdcClockReference</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Reference to a container of the type McuClockReferencePoint, to select an input clock.</L-2>
                          </DESC>
