                            </ECUC-FUNCTION-NAME-DEF>
                            <ECUC-INTEGER-PARAM-DEF UUID="ae91d0b5-0bca-48cf-934d-53fd33e31194">
                              <SHORT-NAME>CddAdcPpbAccumulationCountLimit</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">This parameters defines the oversampling limit Defines the number of conversion to accumulate before PSUM is automatically loaded into SUM.                                           The minimum allowed value is zero. The maximum value allowed is the StreamingSamples value of the corresonding channel group.                                           If the hardware unit is configured in 16-bit resolution mode with CddAdcPpbAccumulationCountLimit exceeding 128, it results in overflow in PPB partial sum register</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <MAX>1024</MAX>
                              <MIN>0</MIN>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF UUID="2b827ff9-260a-49e9-94cd-6e1b2cf58ba6">
                              <SHORT-NAME>CddAdcPpbRightShift</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">The parameter defines the number of bits to right shift partial ppb result(PSUM) before writing to the final PPB result register(SUM).                                         For 0, no right shit.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>0</DEFAULT-VALUE>
                              <MAX>10</MAX>
                              <MIN>0</MIN>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="bd217f88-981c-4e7a-8b00-7bc50e5bd536">
