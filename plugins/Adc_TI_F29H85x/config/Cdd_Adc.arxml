                              <SHORT-NAME>ISR_CAT2_INT</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-FUNCTION-NAME-DEF UUID="be951f86-c031-468c-82ca-997fa1e67336">
                          <SHORT-NAME>CddAdcGroupNotification</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Callback function for each group</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
