                            <a:da name="ENABLE" type="XPath" expr="(../CddAdcCheckerResultType = 'CDD_ADC_SAFETY_CHECKER_INPUT_PPB' or ../CddAdcCheckerResultType = 'CDD_ADC_SAFETY_CHECKER_INPUT_PPBSUM')"/>
                            <a:da name="WARNING" type="XPath">
