                              <mt:tst expr="&lt;=2" false="Maximum allowed Interrupt event Instance ID is 2"/>
                              <mt:tst expr="&gt;=0" false="Minimum allowed Interrupt event Instance ID is 0"/>
                            </mt:range>
                            <mt:xpath expr="node:fallback(&quot;->text:uniq(../.././/*[@name='CddAdcIntEvtId'],node:value(.))&quot;,num:i(0))" false="ID should be unique"/>
                          </a:da>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:pos(../.)&quot;,num:i(0))"/>
                        </v:var>
