                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <a:da name="ENABLE" value="true"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_CheckerResType')&quot;,'CDD_ADC_SAFETY_CHECKER_INPUT_SOC')"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_CheckerResType')[2]&quot;,'CDD_ADC_SAFETY_CHECKER_INPUT_SOC')"/>
                            <a:da name="WARNING" type="XPath" expr="(../../CddAdcSelResConfig1/CddAdcCheckerResultType = .)" false="Result type is different for both checker results."/>                          
                          </v:var>
                          <v:ref name="CddAdcChannelReference" type="REFERENCE">
                            <a:a name="DESC" 
                              value="EN: Reference to the channel whose result is to be compared."/>
