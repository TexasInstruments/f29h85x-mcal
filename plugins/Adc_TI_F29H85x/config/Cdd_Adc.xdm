                                <a:tst expr="text:uniq(../.././/*[@name='CddAdcSafetyCheckerInstance'],node:value(.))" false="Reference to the safety checker unit should be unique for a single interrupt event instance"/>
                                <a:tst expr="not(node:empty(.) = 'true')" false="Reference must be provided to configure interrupt and event flags"/>
                              </a:a> 
