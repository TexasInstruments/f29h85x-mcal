                      <a:da name="INVALID" type="XPath">
                        <a:tst expr="node:when((. = 'true'),(num:i(count(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcConfigSet/CddAdcGlobalSwTrigger/*)) > 0),'true')" false="When CddAdcEnableGlobalSoftwareTrigger is enabled then atleast one shild container should be present in the CddAdcGlobalSwTrigger container."/>
                        <a:tst expr="node:when((. = 'false'),(num:i(count(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcConfigSet/CddAdcGlobalSwTrigger/*)) = 0),'true')" false="If CddAdcEnableGlobalSoftwareTrigger is disabled no child container of CddAdcGlobalSwTrigger should be added."/>
                      </a:da>
