                        <v:var name="CddAdcIntEvtId" type="INTEGER">
                          <a:a name="DESC" 
                                value="EN: Numeric ID of the interrupt event instance.This ID should be unique."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                            type="IMPLEMENTATIONCONFIGCLASS">                                                          
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
