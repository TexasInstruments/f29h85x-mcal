                    <v:lst name="CddAdcCheckerIntEvtConfig" type="MAP">
                      <a:da name="MIN" value="0"/>
                      <a:da name="MAX" value="3"/>
                      <v:ctr name="CddAdcCheckerIntEvtConfig" type="IDENTIFIABLE">
                        <a:a name="DESC" 
                              value="EN: This container configures the triggers for interrupts and events from the safety checker units."/>
