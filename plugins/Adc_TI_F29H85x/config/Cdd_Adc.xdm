                  <v:ctr name="CddAdcGeneral" type="IDENTIFIABLE">
                    <a:a name="DESC" 
                          value="EN: General configuration (parameters) of the ADC Driver software module."/>
                    <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    <v:var name="CddAdcDeInitApi" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Adds / removes the service Cdd_Adc_DeInit() from the code."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                        type="IMPLEMENTATIONCONFIGCLASS">                                                          
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:da name="DEFAULT" value="true"/>                      
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    </v:var>
                    <v:var name="CddAdcDevErrorDetect" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Switches the development error detection and notification on or off."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                        type="IMPLEMENTATIONCONFIGCLASS">                                                          
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="DEFAULT" value="false"/>
                    </v:var>
                    <v:var name="CddAdcEnableStartStopGroupApi" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Adds / removes the services Cdd_Adc_StartGroupConversion() and Cdd_Adc_StopGroupConversion() from the code."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                        type="IMPLEMENTATIONCONFIGCLASS">                                                          
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:da name="DEFAULT" value="true"/>                      
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    </v:var>
                    <v:var name="CddAdcEnableGlobalSoftwareTrigger" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Adds / removes the services Cdd_Adc_StartGlobalSwTrig() and Cdd_Adc_StopGlobalSwTrig() from the code."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                        type="IMPLEMENTATIONCONFIGCLASS">                                                          
