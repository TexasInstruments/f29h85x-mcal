                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="INVALID" type="XPath">
                        <a:tst expr="node:when((. = 'true'),(num:i(count(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcConfigSet/CddAdcHwUnit/*/CddAdcPpbConfig/*)) > 0),'true')" false="If CddAdcPpbEnable is enabled atleast one PPB child container of CddAdcPpbConfig should be present in atleast one of the CddAdcHwUnit containers."/>
                        <a:tst expr="node:when((. = 'false'),(num:i(count(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcConfigSet/CddAdcHwUnit/*/CddAdcPpbConfig/*)) = 0),'true')" false="If CddAdcPpbEnable is disabled no PPB child container of CddAdcPpbConfig should be added."/>
                      </a:da>
                    </v:var>
                    <v:var name="CddAdcReadGroupApi" type="BOOLEAN">
