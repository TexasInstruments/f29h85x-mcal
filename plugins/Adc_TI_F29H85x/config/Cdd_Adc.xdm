<?xml version='1.0'?>
<datamodel version="8.0" 
           xmlns="http://www.tresos.de/_projects/DataModel2/18/root.xsd" 
           xmlns:a="http://www.tresos.de/_projects/DataModel2/18/attribute.xsd" 
           xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd" 
           xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">

  <d:ctr type="AUTOSAR" factory="autosar" 
         xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd" 
         xmlns:ce="http://www.tresos.de/_projects/DataModel2/18/childenable.xsd" 
         xmlns:cd="http://www.tresos.de/_projects/DataModel2/08/customdata.xsd" 
         xmlns:f="http://www.tresos.de/_projects/DataModel2/14/formulaexpr.xsd" 
         xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd" 
         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"  
         xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TI_F29H85x" type="AR-PACKAGE">
        <a:a name="UUID" type="XPath" expr="as:uuid()"/>
        <d:lst type="TOP-LEVEL-PACKAGES">
          <d:ctr name="Cdd_Adc" type="AR-PACKAGE">
            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
            <d:lst type="ELEMENTS">
              <d:chc name="Cdd" type="AR-ELEMENT" value="MODULE-DEF">
                <v:ctr type="MODULE-DEF">
                  <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    <ad:ADMIN-DATA>
                      <ad:DOC-REVISIONS>
                        <ad:DOC-REVISION>
                          <ad:REVISION-LABEL>4.3.1</ad:REVISION-LABEL>
                          <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                        </ad:DOC-REVISION>
                      </ad:DOC-REVISIONS>
                    </ad:ADMIN-DATA>
                  </a:a>
                  <a:a name="DESC" 
                      value="EN: Configuration of the CDD(Complex Device Driver) Adc(Analog Digital Conversion) module."/>
                  <a:a name="LOWER-MULTIPLICITY" value="0"/>
                  <a:a name="UPPER-MULTIPLICITY" value="1"/>
                  <a:a name="RELEASE" value="asc:4.3.1"/>
                  <a:a name="UUID" value="176aad71-7a67-42cf-8fa2-a08a838d2fc8"/>
                  <v:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION">
                    <a:a name="LABEL" value="Config Variant"/>
                    <a:a name="UUID" value="23bcc308-45d2-48dd-a882-41ae2a5ac7be"/>
                    <a:da name="DEFAULT" value="VariantPreCompile"/>
                    <a:da name="RANGE">
                      <a:v>VariantPreCompile</a:v>
                    </a:da>
                  </v:var>
                  <v:ctr name="CddAdcConfigSet" type="IDENTIFIABLE">
                    <a:a name="DESC" 
                          value="EN: This container contains the configuration parameters and sub containers of the Cdd Adc module."/>
                    <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    <v:var name="CddAdcEnableTemperatureSensor" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Enables/Disables the temperature sensor."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                        type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="DEFAULT" value="false"/>
                    </v:var>                     
                    <v:var name="CddAdcLockTemperatureSensor" type="BOOLEAN">
                      <a:a name="DESC" 
                            value="EN: Locks the temperature sensor configuration register When enabled .This is editable only when the temperature sensor is enabled."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                          
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="DEFAULT" value="false"/>
                      <a:da name="EDITABLE" type="XPath" expr="(../CddAdcEnableTemperatureSensor)"/>
                      <a:da name="INVALID" type="XPath" expr="not(. = 'true' and ../CddAdcEnableTemperatureSensor = 'false')" false="This parameter is only enabled only when the temperature sensor is enabled."/>
                    </v:var>                    
                    <v:var name="CddAdcInternalTestInput" type="ENUMERATION">
                      <a:a name="DESC" 
                            value="EN: Selects the input source for the internal test nodes for the ADC hardware unit."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                        type="IMPLEMENTATIONCONFIGCLASS">                                                          
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_InternalTestInput')&quot;,'CDD_ADC_TEST_NODE_NO_CONN')"/>
                      <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_InternalTestInput')[1]&quot;,'CDD_ADC_TEST_NODE_NO_CONN')"/>
                    </v:var>
                    <v:var name="CddAdcHwUnitAnalogRefABVoltageMode" type="ENUMERATION">
                      <a:a name="DESC" 
                            value="EN: This parameter defines the voltage reference mode for ADC A and B hardware instances."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="RANGE">
                          <a:v>CDD_ADC_REFERENCE_INTERNAL</a:v>
                          <a:v>CDD_ADC_REFERENCE_EXTERNAL</a:v>
                      </a:da>
                      <a:da name="DEFAULT" value="CDD_ADC_REFERENCE_INTERNAL"/>
                    </v:var>
                    <v:var name="CddAdcHwUnitAnalogRefABVoltage" type="ENUMERATION">
                      <a:a name="DESC" 
                            value="EN:This parameter defines the reference voltage for A and B instances of the ADC. This paramter is applicable only when the voltage reference mode is INTERNAL."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="RANGE">
                          <a:v>CDD_ADC_REFERENCE_3_3V</a:v>
                          <a:v>CDD_ADC_REFERENCE_2_5V</a:v>
                      </a:da>
                      <a:da name="DEFAULT" value="CDD_ADC_REFERENCE_2_5V"/>
                      <a:da name="EDITABLE" type="XPath" expr="(../CddAdcHwUnitAnalogRefABVoltageMode = 'CDD_ADC_REFERENCE_INTERNAL')"/>
                    </v:var>
                    <v:var name="CddAdcHwUnitAnalogRefCDEVoltageMode" type="ENUMERATION">
                      <a:a name="DESC" 
                            value="EN: This parameter defines the voltage reference mode for C,D and E instances of the ADC."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="RANGE">
                          <a:v>CDD_ADC_REFERENCE_INTERNAL</a:v>
                          <a:v>CDD_ADC_REFERENCE_EXTERNAL</a:v>
                      </a:da>
                      <a:da name="DEFAULT" value="CDD_ADC_REFERENCE_INTERNAL"/>
                    </v:var>
                    <v:var name="CddAdcHwUnitAnalogRefCDEVoltage" type="ENUMERATION">
                      <a:a name="DESC" 
                            value="EN:This parameter defines the reference voltage for C,D and E instances of the ADC.This paramter is applicable only when the voltage reference mode is INTERNAL."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="ORIGIN" value="Texas Instruments"/>
                      <a:a name="SCOPE" value="LOCAL"/>
                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="RANGE">
                          <a:v>CDD_ADC_REFERENCE_3_3V</a:v>
                          <a:v>CDD_ADC_REFERENCE_2_5V</a:v>
                      </a:da>
                      <a:da name="DEFAULT" value="CDD_ADC_REFERENCE_3_3V"/>
                      <a:da name="EDITABLE" type="XPath" expr="(../CddAdcHwUnitAnalogRefCDEVoltageMode = 'CDD_ADC_REFERENCE_INTERNAL')"/>
                    </v:var>
                    <v:lst name="CddAdcHwUnit" type="MAP">
                      <a:da name="MIN" value="1"/>
                      <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Cdd_Adc_F29H85x_HwInstances')&quot;,num:i(5))"/>
                      <v:ctr name="CddAdcHwUnit" type="IDENTIFIABLE">
                        <a:a name="DESC" 
                              value="EN: This container contains the driver configuration (parameters) for the ADC Hardware Unit"/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>
                        <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                        <v:var name="CddAdcHwInstance" type="ENUMERATION">
                          <a:a name="DESC" 
                                value="EN: This parameter describes the ADC HW Unit instance."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_HwUnitId')&quot;,'CDD_ADCA')"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_HwUnitId')[1]&quot;,'CDD_ADCA')"/>
                          <a:da name="INVALID" type="XPath">
                            <a:tst expr="text:uniq(../.././/*[@name = 'CddAdcHwInstance'],node:value(.))"
                                  false="Every hardware instance must have different hardware unit IDs."/>
                          </a:da> 
                        </v:var>
                        <v:var name="CddAdcHwUnitId" type="INTEGER">
                          <a:a name="DESC" 
                                value="EN: This parameter indicates harware unit index among all the configured hardware units."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:pos(../.)&quot;,num:i(0))"/>
                          <a:da name="EDITABLE" value="false"/>                          
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=4"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                        </v:var>
                        <v:var name="CddAdcSocPriorityMode" type="INTEGER">
                          <a:a name="DESC" 
                                value="This parameter defines the SOC priority of the ADC hardware unit.
                                If the selected priority is 0 then all SOCs are handled in round robin mode,for any other 
                              value channels with SOC number below the Priority value are handled in high priority mode and 
                                the rest of the SOCs will be handled in round robin mode.
                                By default round robin mode is configured."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=32"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                          <a:da name="DEFAULT" value="0"/>
                        </v:var>
                        <v:var name="CddAdcHwUnitResolution" type="ENUMERATION">
                          <a:a name="DESC" 
                                value="EN: This parameter defines the resolution of the hardware unit assigned to the group(in bits)."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE">
                            <a:v>CDD_ADC_RESOLUTION_12BIT</a:v>
                            <a:v>CDD_ADC_RESOLUTION_16BIT</a:v>
                          </a:da>
                          <a:da name="EDITABLE" type="XPath" expr="((../CddAdcHwInstance = 'CDD_ADCA') or (../CddAdcHwInstance = 'CDD_ADCB'))"/>                          
                          <a:da name="DEFAULT" value="CDD_ADC_RESOLUTION_12BIT"/>
                          <a:da name="INVALID" type="XPath">
                            <a:tst expr="not(node:value(../../../CddAdcHwUnitAnalogRefABVoltage) = 'CDD_ADC_REFERENCE_3_3V' and  node:value(../../../CddAdcHwUnitAnalogRefABVoltageMode) = 'CDD_ADC_REFERENCE_INTERNAL' and node:value(.) = 'CDD_ADC_RESOLUTION_16BIT')"
                                  false="1.65V internal reference mode is not supported when the ADC is configured for 16-bit resolution mode."/>
                            <a:tst expr="not(((../CddAdcHwInstance = 'CDD_ADCC') or (../CddAdcHwInstance = 'CDD_ADCD') or (../CddAdcHwInstance = 'CDD_ADCE')) and (. = 'CDD_ADC_RESOLUTION_16BIT'))" false="16-bit resolution is not supported for ADCC,ADCD and ADCE hardware instances"/>
                          </a:da>                         
                        </v:var>
                        <v:var name="CddAdcHwUnitSignalMode" type="ENUMERATION">
                          <a:a name="DESC" 
                              value="EN: This parameter defines the signal mode of the group.Differential mode is supported only for ADC instances A and B."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                              type="IMPLEMENTATIONCONFIGCLASS">                            
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE">
                              <a:v>CDD_ADC_MODE_SINGLE_ENDED</a:v>
                              <a:v>CDD_ADC_MODE_DIFFERENTIAL</a:v>
                          </a:da>
                          <a:da name="EDITABLE" type="XPath" expr="(../CddAdcHwInstance = 'CDD_ADCA') or (../CddAdcHwInstance = 'CDD_ADCB')" />
                          <a:da name="DEFAULT" value="CDD_ADC_MODE_SINGLE_ENDED"/>    
                        </v:var>
                        <v:ref name="CddAdcClockReference" type="REFERENCE">
                          <a:a name="DESC" value="EN: Reference to a container of the type McuClockReferencePoint, to select an input clock."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="REF" value="ASPathDataOfSchema:/TI_F29H85x/Mcu/McuModuleConfiguration/McuClockSettingConfig/McuClockReferencePoint"/>
                        </v:ref>
                        <v:var name="CddAdcHwUnitClockPrescale" type="ENUMERATION">
                          <a:a name="DESC"
                                value="EN: This enum describes the clock prescale factor for the ADC Hardware unit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Prescale')&quot;,'CDD_ADC_CLK_DIV_3_5')"/> 
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Prescale')[5]&quot;,'CDD_ADC_CLK_DIV_3_5')"/>
                        </v:var>
                        <v:var name="CddAdcClock" type="FLOAT">
                          <a:a name="DESC" value="EN: This parameter describes the ADC clock after the clock prescale factor for the ADC Hardware unit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:f(node:value(concat(node:path(node:ref(../CddAdcClockReference)),'/McuClockReferencePointFrequency'))) div num:f(text:replace(substring-after(node:value(../CddAdcHwUnitClockPrescale),'CDD_ADC_CLK_DIV_'),'_','.'))&quot;,num:f('5.0E7'))"/>
                          <a:da name="EDITABLE" value="false"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=6.0E7" false="60MHz is the maximum clock frequency supported by ADC "/>
                            <a:tst expr="&gt;=5.0E6" false="5MHz is the minimum clock frequency required for the ADC hardware unit"/>
                          </a:da>
                        </v:var>
                        <v:var name="CddAdcHwExternalMuxSelect" type="BOOLEAN">
                          <a:a name="DESC" 
                                value="EN: This parameter determines whether the external mux channel is enabled for the ADC hardware unit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="false"/> 
                        </v:var>
                        <v:var name="CddAdcHwExternalMuxPreselectEnable" type="BOOLEAN">
                          <a:a name="DESC" 
                                value="EN: This parameter determines whether the external mux preset is enabled for the ADC hardware unit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                        
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="false"/>
                          <a:da name="ENABLE" type="XPath" expr="(../CddAdcHwExternalMuxSelect = 'true')"/> 
                        </v:var>                        
                        <v:var name="CddAdcInterruptPulseMode" type="ENUMERATION">
                          <a:a name="DESC" 
                              value="EN: This enumeration defines the interrupt pulse mode of the ADc hardware unit."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                            type="IMPLEMENTATIONCONFIGCLASS">                                                          
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_InterruptPulseMode')&quot;,'CDD_ADC_PULSE_END_OF_CONV')"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_InterruptPulseMode')[2]&quot;,'CDD_ADC_PULSE_END_OF_CONV')"/>
                        </v:var>
                        <v:var name="CddAdcInterruptCycleoffset" type="INTEGER">
                          <a:a name="DESC" 
                              value="EN: This parameter defines the delay from the fall edge of the SOC and the interrupt to be generated in SYSCLK cycles ."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                            type="IMPLEMENTATIONCONFIGCLASS">                                                          
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>                   
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="EDITABLE" type="XPath" expr="(../CddAdcInterruptPulseMode = 'CDD_ADC_PULSE_END_OF_ACQ_WIN')"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=65535"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                          <a:da name="DEFAULT" value="0"/>
                        </v:var>
                        <v:var name="CddAdcOpenShortDetectMode" type="ENUMERATION">
                          <a:a name="DESC" 
                              value="EN: This parameter defines the opens/shorts detection circuit mode ."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                            type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>                   
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_OSDetectMode')&quot;,'CDD_ADC_OSDETECT_MODE_DISABLED')"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_OSDetectMode')[1]&quot;,'CDD_ADC_OSDETECT_MODE_DISABLED')"/>
                        </v:var>
                        <v:lst name="CddAdcGroup" type="MAP">
                          <a:da name="MIN" value="1"/>
                          <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Cdd_Adc_F29H85x_IntCntPerHw')&quot;,num:i(4))"/>
                          <v:ctr name="CddAdcGroup" type="IDENTIFIABLE">
                            <a:a name="DESC" 
                                  value="EN: This container contains the Group configuration (parameters)."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <v:var name="CddAdcGroupId" type="INTEGER">
                              <a:a name="DESC"
                                    value="EN: Numeric ID of the group. This parameter is the symbolic name to be used on the API. This symbolic name allows accessing Channel Group data. This value will be assigned to the symbolic name derived of the CddAdcGroup container shortName."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                              
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:pos(../.))&quot;,num:i(0))"/>
                              <a:da name="EDITABLE" value="false"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=3"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                            </v:var>
                            <v:var name="CddAdcGroupPriority" type="ENUMERATION">
                              <a:a name="DESC"
                                    value="EN: Priority of the group."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                              
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_HIGH_PRIORITY</a:v>
                                <a:v>CDD_ADC_ROUND_ROBIN</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_ROUND_ROBIN"/>
                            </v:var>
                            <v:var name="CddAdcGroupSocMask" type="INTEGER">
                              <a:a name="DESC"
                                    value="EN: SOC mask of the Adc hardware unit of the group."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                              
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(num:sum(node:foreach(../CddAdcChannel/*/CddAdcSocNumber,'val','num:i(bit:bitset(0,num:i($val)))')))&quot;,num:i('0'))"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=4294967295"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="EDITABLE" value="false"/>
                            </v:var>
                            <v:var name="CddAdcGroupConversionMode" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: This parameter defines the type of conversion mode for the group."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_CONV_MODE_CONTINUOUS</a:v>
                                <a:v>CDD_ADC_CONV_MODE_ONESHOT</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_CONV_MODE_ONESHOT"/>
                            </v:var>
                            <v:var name="CddAdcGroupTrigSrcType" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: Type of source event that starts a group conversion."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_TRIGG_SRC_HW</a:v>
                                <a:v>CDD_ADC_TRIGG_SRC_SW</a:v>
                              </a:da>
                              <a:da name="EDITABLE" type="XPath" expr="(../CddAdcGroupConversionMode != 'CDD_ADC_CONV_MODE_CONTINUOUS')"/>
                              <a:da name="DEFAULT" value="CDD_ADC_TRIGG_SRC_SW"/>
                            </v:var>
                            <v:var name="CddAdcGroupTrigSrc" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: Source of the trigger that triggers the start of the conversion of all the channels in the group."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->node:when((../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_SW'),ecu:list('Cdd_Adc_F29H85x_SOC_SwTrigger'),ecu:list('Cdd_Adc_F29H85x_SOC_HwTrigger'))&quot;,'CDD_ADC_TRIGGER_SW_ONLY')"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:when((../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_SW'),ecu:list('Cdd_Adc_F29H85x_SOC_SwTrigger')[1],ecu:list('Cdd_Adc_F29H85x_SOC_HwTrigger')[1])&quot;,'CDD_ADC_TRIGGER_SW_ONLY')"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="not(../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_SW'  and . != 'CDD_ADC_TRIGGER_SW_ONLY')" false="When the trigger source type is SW only SW trigger source should be selected."/>
                                <a:tst expr="not(../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_HW'  and . = 'CDD_ADC_TRIGGER_SW_ONLY')" false="When the trigger source type is HW only HW trigger sources should be selected."/>
                              </a:da>                            
                            </v:var>
                            <v:ref name="CddAdcTrigRepeaterReference" type="REFERENCE">
                              <a:a name="DESC" 
                                    value="EN: Reference to the trigger repeater."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" type="XPath" expr="((../CddAdcGroupTrigSrc = 'CDD_ADC_TRIGGER_REPEATER1') or (../CddAdcGroupTrigSrc = 'CDD_ADC_TRIGGER_REPEATER2'))"/>
                              <a:da name="REF" value="ASPathDataOfSchema:/TI_F29H85x/Cdd_Adc/Cdd/CddAdcConfigSet/CddAdcHwUnit/CddAdcTriggerRepeater"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="node:when((../CddAdcGroupTrigSrc = 'CDD_ADC_TRIGGER_REPEATER1'),(node:value(concat(node:path(node:ref(.)),'/CddAdcRepeaterInstance')) = '0'),(node:value(concat(node:path(node:ref(.)),'/CddAdcRepeaterInstance')) = '1'))" 
                                  false="TriggerRepeater number and the referred trigger repeater ID should match. For CDD_ADC_TRIGGER_REPEATER1 trigger source the referred trigger repeater instance ID should be 0.
                                  Similarly,for CDD_ADC_TRIGGER_REPEATER2 trigger source the referred trigger repeater instance ID should be 1"/>
                                <a:tst expr="(node:value(../../../CddAdcHwInstance) = node:value(concat(node:path(node:ref(.)),'/../../CddAdcHwInstance')))" false="The referred trigger repeater should belong to the same hardware unit"/>
                              </a:da>
                            </v:ref>
                            <v:var name="CddAdcGroupAccessMode" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: This parameter defines the access mode of thegroup conversion results."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>                 
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_ACCESS_MODE_SINGLE</a:v>
                                <a:v>CDD_ADC_ACCESS_MODE_STREAMING</a:v>
                              </a:da>
                              <a:da name="EDITABLE" type="XPath" expr="not((../CddAdcGroupConversionMode = 'CDD_ADC_CONV_MODE_ONESHOT') and (../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_SW'))"/>  
                              <a:da name="DEFAULT" value="CDD_ADC_ACCESS_MODE_SINGLE"/>                              
                            </v:var>                                                       
                            <v:var name="CddAdcGroupHwTrigSignal" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: Configures on which edge of the hardware trigger signal the driver should react, i.e. start the conversion (only if supported by the ADC hardware)."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                    type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" value="true"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_HW_TRIG_BOTH_EDGES</a:v>
                                <a:v>CDD_ADC_HW_TRIG_FALLING_EDGE</a:v>
                                <a:v>CDD_ADC_HW_TRIG_RISING_EDGE</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_HW_TRIG_RISING_EDGE"/>
                              <a:da name="EDITABLE" value="false"/>
                            </v:var>
                            <v:var name="CddAdcGroupStreamingBufferMode" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: Configure streaming buffer as &quot;linear buffer&quot; (i.e. the ADC Driver stops the conversion as soon as the stream buffer is full) or as &quot;ring buffer&quot; (wraps around if the end of the stream buffer is reached)."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_STREAM_BUFFER_CIRCULAR</a:v>
                                <a:v>CDD_ADC_STREAM_BUFFER_LINEAR</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_STREAM_BUFFER_LINEAR"/>
                              <a:da name="EDITABLE" type="XPath" expr="(../CddAdcGroupAccessMode = 'CDD_ADC_ACCESS_MODE_STREAMING')"/>
                            </v:var>
                            <v:var name="CddAdcGroupStreamingNumSamples" type="INTEGER">
                              <a:a name="DESC" 
                                    value="EN: Number of ADC values to be acquired per channel in streaming access mode."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>                              
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=255"/>
                                <a:tst expr="&gt;=1"/>
                              </a:da>
                              <a:da name="EDITABLE" type="XPath" expr="(../CddAdcGroupAccessMode = 'CDD_ADC_ACCESS_MODE_STREAMING')"/>                            
                              <a:da name="DEFAULT" value="1"/>
                            </v:var>
                            <v:var name="CddAdcInterruptCategory" type="ENUMERATION">
                              <a:a name="DESC" value="EN: This parameters defines the category of the interrupt."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="ISR_CAT1_RTINT"/>
                              <a:da name="RANGE">
                                <a:v>ISR_CAT1_INT</a:v>
                                <a:v>ISR_CAT1_RTINT</a:v>
                                <a:v>ISR_CAT2_INT</a:v>
                              </a:da>
                            </v:var>                         
                            <v:var name="CddAdcGroupNotification" type="FUNCTION-NAME">
                              <a:a name="DESC" value="EN: Callback function for each group"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:a name="OPTIONAL" value="true"/>
                              <a:a name="DEFAULT" value="NULL_PTR"/>
                              <a:da name="INVALID" type="XPath" expr="(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcGeneral/CddAdcGrpNotifCapability)" 
                                false="To provide group notification function then group notification capability(CddAdcGrpNotifCapability parameter) should be enabled"/>
                            </v:var>
                            <v:var name="CddAdcInterruptSelect" type="ENUMERATION">
                              <a:a name="DESC" 
                                    value="EN: This parameter defines to which interrupt the group is linked."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Int')&quot;,'CDD_ADC_INT1')"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Int')[1]&quot;,'CDD_ADC_INT1')"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="text:uniq(../../.././/*[@name = 'CddAdcInterruptSelect'],node:value(.))" 
                                false="If the group is configured for the interrupt mode then the interrupt number should be unique among the same hardware unit."/>
                              </a:da>
                            </v:var>
                            <v:var name="CddAdcInterruptSocSelect" type="ENUMERATION">
                              <a:a name="DESC" 
                                  value="EN: This parameter allows interrupt as the trigger source of the group in addition to trigger select. This is applicable only for the interrupts CDD_ADC_INT1 and CDD_ADC_INT2."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_INT_SOC_TRIGGER_NONE</a:v>
                                <a:v>CDD_ADC_INT_SOC_TRIGGER_ADCINT1</a:v>
                                <a:v>CDD_ADC_INT_SOC_TRIGGER_ADCINT2</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_INT_SOC_TRIGGER_NONE"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="not(../CddAdcGroupTrigSrcType = 'CDD_ADC_TRIGG_SRC_SW' and . != 'CDD_ADC_INT_SOC_TRIGGER_NONE')" false="Groups with SW(software) trigger source shouldn't enable since it is considered as a hardware trigger." />
                              </a:da>
                            </v:var>                           
                            <v:var name="CddAdcContinueToInterruptMode" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters enables/disables the continue to interrupt mode for the specified interrupt."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:lst name="CddAdcChannel" type="MAP">
                              <a:da name="MIN" value="1"/>
                              <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Cdd_Adc_F29H85x_Channels')&quot;,num:i('32'))"/>
                              <v:ctr name="CddAdcChannel" type="IDENTIFIABLE">
                                <a:a name="DESC" 
                                  value="EN: This container contains the channel configuration (parameters) depending on the hardware capability."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                    <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>                            
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="INVALID" type="XPath">
                                  <a:tst expr="num:i(count(../../.././/*[@name = 'CddAdcChannelId'])) &lt;=ecu:get('Cdd_Adc_F29H85x_Channels')" false="Atmost only 32 channels are allowed in a hardware units."/>
                                </a:da>
                                <v:var name="CddAdcChannelId" type="INTEGER">
                                  <a:a name="DESC" value="EN: This parameter defines to the numeric ID of the channel on the ADC hardware unit. Only some channels are brought out on the deive.
                                          Some of the channels are connected internally. So,while confguring the channel IDs make sure the channels have pin out on the deivce and are configured in Port. "/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                   
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <a:da name="INVALID" type="Multi">
                                    <mt:range>
                                      <mt:tst expr="&lt;=31"/>
                                      <mt:tst expr="&gt;=0"/>
                                    </mt:range>
                                    <mt:xpath expr="not(../../../../../CddAdcHwUnitResolution = 'CDD_ADC_RESOLUTION_16BIT' and . ='20')"
                                      false="Channel Id 20 is a temperature sensor. When enabling temperature sensor the ADC hardware unit shouldn't be in 16-bit mode. Being in 16-bit mode might produce incorrect conversion results."/>
                                    <mt:xpath expr="node:when(((../../../../../CddAdcHwInstance = 'CDD_ADCA' or ../../../../../CddAdcHwInstance = 'CDD_ADCC') and . ='20'),(as:modconf('Cdd_Adc/Cdd')[1]/CddAdcConfigSet/CddAdcEnableTemperatureSensor),'true')" 
                                    false="When temperature sensor is used CddAdcEnableTemperatureSensor should be set to true." />
                                  </a:da>
                                  <a:da name="DEFAULT" value="0"/>
                                </v:var>
                                <v:var name="CddAdcSocNumber" type="INTEGER">
                                  <a:a name="DESC" 
                                    value="EN: This parameter defines the assignment of the channel to the physical ADC  hardware channel."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                   
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <a:a name="INVALID" type="Multi">
                                    <mt:range>
                                      <mt:tst expr="&lt;=31"/>
                                      <mt:tst expr="&gt;=0"/>
                                    </mt:range>
                                    <mt:xpath expr="text:uniq(../../../../.././/*[@name = 'CddAdcSocNumber'],node:value(.))" 
                                              false="Soc number should be unique among all the groups that belongs to the same ADC hardware unit."/>
                                    <mt:xpath expr="node:when((../../../CddAdcGroupPriority = 'CDD_ADC_ROUND_ROBIN'),(node:value(.)&gt;=node:value(../../../../../CddAdcSocPriorityMode)),'true')"
                                      false="The SOC number alloted to the channel should be equal to or higher than the SocPriorityMode value configured for the corresponding group when the group is in round robin mode"/>
                                    <mt:xpath expr="node:when((../../../CddAdcGroupPriority = 'CDD_ADC_HIGH_PRIORITY'),(node:value(.)&lt;node:value(../../../../../CddAdcSocPriorityMode)),'true')"
                                      false="The SOC number alloted to the channel should be less than/below the SocPriorityMode value configured for the corresponding group when the group is in high priority mode"/>
                                  </a:a>
                                  <a:da name="DEFAULT" value="0"/>
                                </v:var>                              
                                <v:var name="CddAdcSocExternalChannelSelect" type="INTEGER">
                                  <a:a name="DESC" 
                                    value="EN: This parameter defines the assignment of the external channel based on the digital output pins."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                   
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <a:da name="DEFAULT" value="0"/>
                                  <a:da name="INVALID" type="Range">
                                    <a:tst expr="&lt;=15" false="External channel ID should be within the range, below 15"/>
                                    <a:tst expr="&gt;=0" false="Minimum allowed external channel ID is 0"/>
                                  </a:da>
                                  <a:da name="EDITABLE" type="XPath" expr="(../../../../../CddAdcHwExternalMuxSelect = 'true')"/>
                                </v:var>
                                <v:var name="CddAdcChannelSampleWindow" type="INTEGER">
                                  <a:a name="DESC" 
                                    value="EN: Configuration of sampling time, i.e. the time during which the value is sampled, (in SYSCLK cycles) for each channel, if supported by hardware. Minimum value should be 15 to meet the minimum acquistsition window duration."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <a:da name="INVALID" type="Multi">
                                    <mt:xpath expr="node:fallback(&quot;->node:when((../../../../../CddAdcHwUnitResolution = 'CDD_ADC_RESOLUTION_16BIT'),.&gt;=64,.&gt;=15)&quot;,.&gt;=15)" false="For 16-bit ADCs sample window should be atleast 64 SYSCLK cycles and for 12-bit it should be atleast 15 SYSCLK cycles.Ckeck the hardware resolution and enter the value accordingly."/>
                                    <mt:range>
                                      <mt:tst expr="&lt;=511"/>
                                      <mt:tst expr="&gt;=15"/>
                                    </mt:range>
                                </a:da>
                                <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:when(num:i(../../../../../CddAdcHwUnitResolution = 'CDD_ADC_RESOLUTION_12BIT'),15,64)&quot;,num:i(15))"/>                              
                                </v:var>                                                                                                                                              
                              </v:ctr>                            
                            </v:lst>
                          </v:ctr>
                        </v:lst>
                        <v:lst name="CddAdcTriggerRepeater" type="MAP">
                          <a:da name="MIN" value="0"/>
                          <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Cdd_Adc_F29H85x_TrigRepeatersPerHw')&quot;,num:i(2))"/>
                          <v:ctr name="CddAdcTriggerRepeater" type="IDENTIFIABLE">
                            <a:a name="DESC" 
                              value="EN: This container contains the trigger repeater configuration (parameters) depending on the hardware capability. To have this container enabled trigger source type should be hardware, trigger source should be one of the repeaters and trigger repeater should be enabled in the CddAdcGeneral container."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>                          
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <v:var name="CddAdcRepeaterInstance" type="INTEGER">
                              <a:a name="DESC" 
                                  value="EN: Numeric ID of the trigger repeater instance."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=1" false="Trigger repeater ID should be within the range"/>
                                <a:tst expr="&gt;=0" false="Minimum allowed trigger repeater Id is 0"/>
                              </a:da>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:pos(../.)&quot;,num:i(0))"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="text:uniq(../.././/*[@name='CddAdcRepeaterInstance'],node:value(.))" false="Trigger repeater ID should be unique."/>
                              </a:da>                             
                            </v:var>
                            <v:var name="CddAdcRepeaterTriggerSrc" type="ENUMERATION">
                              <a:a name="DESC" 
                                  value="EN: Trigger source of the trigger repeater."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>    
                              <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Repeater_Trigger')&quot;,'CDD_ADC_TRIGGER_CPU1INT0')"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_Repeater_Trigger')[1]&quot;,'CDD_ADC_TRIGGER_CPU1INT0')"/>                             
                            </v:var>
                            <v:var name="CddAdcRepeaterMode" type="ENUMERATION">
                              <a:a name="DESC" 
                                value="EN: This parameter configures the trigger repeater mode. In oversampling mode (CddAdcTriggerCount+1) triggers are generated and in undersampling mode (CddAdcTriggerCount+1) triggers are suppressed. "/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"  type="IMPLEMENTATIONCONFIGCLASS">                                  
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>OVERSAMPLING_MODE</a:v>
                                <a:v>UNDERSAMPLING_MODE</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="OVERSAMPLING_MODE"/>
                            </v:var>
                            <v:var name="CddAdcTriggerCount" type="INTEGER">
                              <a:a name="DESC" value="EN: This parameter selects the number of triggers. When 0 is selected 1 trigger is generated (pass-through)."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"  type="IMPLEMENTATIONCONFIGCLASS">                                  
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=127" false="The trigger count should be within the range"/>
                                <a:tst expr="&gt;=0" false="The minimum trigger count should be 0"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>
                            <v:var name="CddAdcTriggerPhaseDelay" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: This parameter defines the number of SYSCLKs to delay the selected trigger before passing it onto the re-triggering logic."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"  type="IMPLEMENTATIONCONFIGCLASS">                                  
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>

                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=65535"/>
                              <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>
                            <v:var name="CddAdcTriggerSpreadDelay" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: This parameter defines the minimum number of SYSCLKs to wait before creating the next repeated trigger to the ADC.
                                            This parameter has no effect in undersampling mode or when the TriggerCount is set to 0"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"  type="IMPLEMENTATIONCONFIGCLASS">                                  
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="EDITABLE" type="XPath" expr="(../CddAdcRepeaterMode = 'OVERSAMPLING_MODE') and (../CddAdcTriggerCount != 0)"/>
                              <a:da name="INVALID" type="Range">
                              <a:tst expr="&lt;=65535"/>
                              <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>                                                                                                                                                                                                            
                          </v:ctr>
                        </v:lst>
                        <v:lst name="CddAdcPpbConfig" type="MAP">
                          <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_MaxPpbPerHw')&quot;,num:i(4))"/>
                          <v:ctr name="CddAdcPpbConfig" type="IDENTIFIABLE">
                            <a:a name="DESC" value="EN: This container contains the PPB configuration (parameters) of the PPB."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>                        
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <v:var name="CddAdcPpbId" type="INTEGER">
                              <a:a name="DESC" value="EN: Numeric ID of the PPB number assigned to the channel."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=3" false="Maximum allowed PPB ID is 3"/>
                                <a:tst expr="&gt;=0" false="Minimum allowed PPB ID is 0"/>
                              </a:da>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:pos(../.))&quot;,num:i(0))"/>
                              <a:da name="INVALID" type="XPath" expr="text:uniq(../.././/*[@name='CddAdcPpbId'],node:value(.))" false="PPB ID should be unique"/>
                            </v:var>                                                   
                            <v:ref name="CddAdcPpbChannel" type="REFERENCE">
                              <a:a name="DESC" value="EN: Numeric ID of the channel whose result is to be compared."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="REF" value="ASPathDataOfSchema:/TI_F29H85x/Cdd_Adc/Cdd/CddAdcConfigSet/CddAdcHwUnit/CddAdcGroup/CddAdcChannel"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="node:value(../../../CddAdcHwInstance) = node:value(concat(node:path(node:ref(.)),'/../../../../CddAdcHwInstance'))" 
                                    false="Channel selected should belong to the referred hardware unit."/>                                                                 
                              </a:da>
                            </v:ref>                                                   
                            <v:var name="CddAdcPpbSocNumber" type="INTEGER">
                              <a:a name="DESC" value="EN: Soc number of the selected channel. This is a calculated value, it can't be edited."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:value(concat(node:path(node:ref(../CddAdcPpbChannel)),'/CddAdcSocNumber')))&quot;,num:i(0))"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=31"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="EDITABLE" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbCalibrationOffset" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the offset calibration for the ADC channel.For values from 0 to 511,the configured value will be subtracted from the PPB result. 
                                For values from 512,(1024 - CddAdcPpbCalibrationOffset) value will be added to the PPB result. In case multiple PPBs point to the same SOC,
                                only the OFFCAL of the lowest PPB ID will be applied.
                                This offset value will be subtracted from the raw conversion result and stores the value in the ADC result register. 
                                The addition/subtraction satureated at o on the low ed and either 4095/65536 on the high end for 12-bit and 16-bit respectively."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                     
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=1024"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>
                            <v:var name="CddAdcPpbReferenceOffset" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the reference offset value for the ADC channel.In 12-bit mode the reference offset shouldn't exceed 
                                  4095 in 12-bit and 65535 in 16-bit mode."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="0"/>
                              <a:da name="INVALID" type="Multi">
                                  <mt:xpath expr="node:fallback(&quot;->node:when((../../../CddAdcHwUnitResolution = 'CDD_ADC_RESOLUTION_16BIT'),.&lt;=65535,.&lt;=4095)&quot;,.&lt;=4095)" false="In 12-bit mode the reference offset shouldn't exceed 12-bit(4095) whereas in 16-bit mode the offset can be upto 65535."/>
                                  <mt:range>
                                      <mt:tst expr="&lt;=65535"/>
                                      <mt:tst expr="&gt;=0"/>
                                  </mt:range>
                              </a:da>
                            </v:var>
                            <v:var name="CddAdcPpbDeltaEnable" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the bit to enable/disable delta enable."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var> 
                            <v:var name="CddAdcPpbEnableTwosComplement" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the bit to enable/disable two's complement."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbAbsoluteEnable" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the bit to enable/disable absolute value calculation.
                                    This is done before the two's complement logic, so enabling both CddAdcPpbEnableTwosComplement and CddAdcPpbAbsoluteEnable will always result in a negative PPB value."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                           
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>                         
                            </v:var>     
                            <v:var name="CddAdcPpbCyclebyCycleEnable" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the bit to enable/disable cycle by cycle enable."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>                                
                            </v:var>
                            <v:var name="CddAdcPpbCompareSource" type="ENUMERATION">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the PPB result type used for the zero-crossing detect logic and threshold compare."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="RANGE">
                                <a:v>CDD_ADC_COMPARE_PPBRESULT</a:v>
                                <a:v>CDD_ADC_COMPARE_PPBPSUM</a:v>
                                <a:v>CDD_ADC_COMPARE_PPBSUM</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_ADC_COMPARE_PPBRESULT"/>
                            </v:var>                            
                            <v:var name="CddAdcPpbTripHighLimit" type="INTEGER">
                              <a:a name="DESC" value="EN: High limit - used for limit checking for all types of PB results. 
                                When comparing to an ADCPPBxRESULT register, the upper bits will be ignored:TRIPHI[23:17] will be ignored in 16 bit mode and 
                                TRIPHI[23:13] will be ignored in 12 bit mode"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=8388607"/>
                                <a:tst expr="&gt;=-8388608"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>
                            <v:var name="CddAdcPpbExtendedTripLowEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: This parameters configures the extended trip limit low.This value can be used to compare any PPBRESULT.
                                                This is non-editable It is always enabled"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="true"/>
                              <a:da name="EDITABLE" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbTripLowLimit" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN:Extended trip low limit - used for limit checking.When comparing to an ADCPPBxRESULT register, the upper bits will be ignored: 
                                TRIPLO2[23:17] will be ignored in 16 bit mode and TRIPLO2[23:13] will be ignored in 12 bit mode"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=8388607"/>
                                <a:tst expr="&gt;=-8388608"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>
                            </v:var>                                                    
                            <v:var name="CddAdcPpbTripHighEventEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising trip high flag in the PPB to activate the event signal to the PWM blocks."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbTripLowEventEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising trip low flag in the PPB to activate the event signal to the PWM blocks."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                           
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>                           
                            <v:var name="CddAdcPpbZeroCrossingEventEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising zero crossing flag in the PPB to activate the event signal to the PWM blocks."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbTripHighInterruptEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising trip high flag in the PPB to activate the event signal to the PIE."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="CddAdcPpbTripLowInterruptEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising trip low flag in the PPB to activate the event signal to the PIE."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                           
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var> 
                            <v:var name="CddAdcPpbZeroCrossingInterruptEnable" type="BOOLEAN">
                              <a:a name="DESC" value="EN: Enabling this allows the corresponding rising zero crossing flag in the PPB to activate the event signal to the PIE."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:var name="CddAdcEventInterruptCategory" type="ENUMERATION">
                              <a:a name="DESC" value="EN: This parameters defines the category of the interrupt."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="ISR_CAT1_RTINT"/>
                              <a:da name="ENABLE" type="XPath" expr="(../CddAdcPpbTripHighInterruptEnable = 'true' or ../CddAdcPpbTripLowInterruptEnable = 'true' or ../CddAdcPpbZeroCrossingInterruptEnable = 'true')"/>
                              <a:da name="RANGE">
                                <a:v>ISR_CAT1_INT</a:v>
                                <a:v>ISR_CAT1_RTINT</a:v>
                                <a:v>ISR_CAT2_INT</a:v>
                              </a:da>
                              <a:da name="INVALID" type="XPath" expr="num:i(count(util:distinct(node:foreach(node:filter(../.././/*[@name='CddAdcEventInterruptCategory'],'node:exists(.)'),'val','$val')))) &lt;=1" 
                                false="All the PPBs of an ADC hardware unit share the same event interrupt. So the interrupt category should be same in all the the PPB container."/>
                            </v:var>                          
                            <v:var name="CddAdcPpbEventInterruptNotification" type="FUNCTION-NAME">
                              <a:a name="DESC" value="EN: Callback function for each PPB that generaterd the event interrupt"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:a name="OPTIONAL" value="true"/>
                              <a:a name="DEFAULT" value="NULL_PTR"/>
                              <a:da name="ENABLE" type="XPath" expr="(../CddAdcPpbTripHighInterruptEnable = 'true' or ../CddAdcPpbTripLowInterruptEnable = 'true' or ../CddAdcPpbZeroCrossingInterruptEnable = 'true')"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="node:when((../CddAdcPpbTripHighInterruptEnable = 'true' or ../CddAdcPpbTripLowInterruptEnable = 'true' or ../CddAdcPpbZeroCrossingInterruptEnable = 'true'),not(node:empty(.)),node:empty(.))" 
                                  false="When the CddAdcPpbEventInterruptNotification is enabled notification function must be provided."/>
                                <a:tst expr="not(not(node:empty(.)) and node:value(/AUTOSAR/TOP-LEVEL-PACKAGES/Cdd_Adc/ELEMENTS/Cdd/CddAdcGeneral/CddAdcGrpNotifCapability) = 'false')" 
                                  false="When the CddAdcPpbEventInterruptNotification is enabled the CddAdcGrpNotifCapability parameter under the CddAdcConfigSet container should be enabled."/>
                              </a:da>
                            </v:var>
                            <v:var name="CddAdcPpbAccumulationCountLimit" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: This parameters defines the oversampling limit Defines the number of conversion to accumulate before PSUM is automatically loaded into SUM.
                                          The minimum allowed value is zero. The maximum value allowed is the StreamingSamples value of the corresonding channel group.
                                          If the hardware unit is configured in 16-bit resolution mode with CddAdcPpbAccumulationCountLimit exceeding 128, it results in overflow in PPB partial sum register"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:value(node:path(concat(node:path(node:ref(../CddAdcPpbChannel)),'/../../CddAdcGroupStreamingNumSamples')))&quot;,num:i(0))"/>
                              <a:da name="EDITABLE" value="false"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=1024"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="WARNING" type="XPath" expr="not(../../../CddAdcHwUnitResolution = 'CDD_ADC_RESOLUTION_16BIT' and .&gt;128)" false="128 is the PPB count limit when ADC is configured in 16-bit mode"/>
                            </v:var>
                            <v:var name="CddAdcPpbRightShift" type="INTEGER">
                              <a:a name="DESC" 
                                value="EN: The parameter defines the number of bits to right shift partial ppb result(PSUM) before writing to the final PPB result register(SUM).
                                        For 0, no right shit."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=10"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                              <a:da name="DEFAULT" value="0"/>                                 
                            </v:var>                             
                            <v:var name="CddAdcPpbTripFilterEnable" type="BOOLEAN">
                              <a:a name="DESC" 
                                value="EN: This parameters configures the bit to enable/disable trip filter."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" value="false"/>
                            </v:var>
                            <v:ctr name="CddAdcTripFilterConfig" type="IDENTIFIABLE">
                              <a:a name="DESC" 
                                value="EN: This container contains the channel configuration (parameters) depending on the hardware capability."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                  <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>                          
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="ENABLE" type="XPath" expr="(../CddAdcPpbTripFilterEnable = 'true')"/>  
                              <v:var name="CddAdcTripFilterClk" type="INTEGER">
                                <a:a name="DESC" 
                                  value="EN: This parameters configures the bit to enable/disable trip filter.The effective prescale value is (CddAdcTripFilterClk + 1).
                                              This applies to the filter on both the high and low trips."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS"  type="IMPLEMENTATIONCONFIGCLASS">                               
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="DEFAULT" value="0"/>
                                <a:da name="EDITABLE" value="true"/>
                                <a:da name="INVALID" type="Range">
                                  <a:tst expr="&lt;=65535"/>
                                  <a:tst expr="&gt;=0"/>
                                </a:da>                                      
                              </v:var>
                              <v:var name="CddAdcTripFilterTreshold" type="INTEGER">
                                <a:a name="DESC"
                                  value="EN: This parameters configures the  trip filter."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="DEFAULT" value="0"/>
                                <a:da name="EDITABLE" value="true"/>
                                <a:da name="INVALID" type="Range">
                                  <a:tst expr="&lt;=63"/>
                                  <a:tst expr="&gt;=0"/>
                                </a:da>                                      
                              </v:var> 
                              <v:var name="CddAdcTripFilterSampleWindow" type="INTEGER">
                                <a:a name="DESC" 
                                  value="EN: This parameters configures the sample window for the digital trip filter."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="DEFAULT" value="0"/>
                                <a:da name="EDITABLE" value="true"/>
                                <a:da name="INVALID" type="Range">
                                  <a:tst expr="&lt;=63"/>
                                  <a:tst expr="&gt;=0"/>
                                </a:da>                                      
                              </v:var> 
                              <v:var name="CddAdcTripFilterLowEnable" type="BOOLEAN">
                                <a:a name="DESC" 
                                  value="EN: This parameters configures the bit to enable/disable trip filter."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="DEFAULT" value="false"/>                                    
                              </v:var>
                              <v:var name="CddAdcTripFilterHighEnable" type="BOOLEAN">
                                <a:a name="DESC" 
                                  value="EN: This parameters configures the bit to enable/disable trip filter."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" 
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                <a:da name="DEFAULT" value="false"/>                                    
                              </v:var>                                                                                                                                                                                                                                                                   
                            </v:ctr>                            
                          </v:ctr>
                        </v:lst>
                      </v:ctr>
                    </v:lst>
                    <v:lst name="CddAdcGlobalSwTrigger" type="MAP">
                      <a:da name="MIN" value="0"/>
                      <v:ctr name="CddAdcGlobalSwTrigger" type="IDENTIFIABLE">
                        <a:a name="DESC" 
                              value="EN: This container contains the global software triigger Id."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>                    
                        <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                        <v:var name="CddAdcGlbSwTrigId" type="INTEGER">
                          <a:a name="DESC" 
                                value="EN: Numeric ID of the safety result checker."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>                         
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:pos(../.))&quot;,num:i(0))"/>
                          <a:da name="EDITABLE" value="false"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=255"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                          
                        </v:var>
                        <v:lst name="CddAdcHwGroup" type="MAP">
                          <v:ctr name="CddAdcHwGroup" type="IDENTIFIABLE">
                            <a:a name="DESC" 
                            value="EN: This container contains the parameter for configuring the hardware for the global software trigger feature."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>                        
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <v:ref name="CddAdcHwGroupRef" type="REFERENCE">
                              <a:a name="DESC" 
                                  value="EN: This paramter refers to the group to select the SOC numners for the global software trigger."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>                         
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="REF" value="ASPathDataOfSchema:/TI_F29H85x/Cdd_Adc/Cdd/CddAdcConfigSet/CddAdcHwUnit/CddAdcGroup"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="(node:value(concat(node:path(node:ref(.)),'/CddAdcGroupTrigSrcType')) = 'CDD_ADC_TRIGG_SRC_SW')" false="Referred group trigger source must be software."/>
                                <a:tst expr="text:uniq(../.././/*[@name='CddAdcHwGroupRef'],node:value(.))" false="No group should be referred twice."/>
                              </a:da>
                            </v:ref>
                            <v:var name="CddAdcHwUnit" type="ENUMERATION">
                              <a:a name="DESC" 
                                  value="EN: This parameter refers to the hardware unit to which the group belongs."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>                         
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->node:value(concat(node:path(node:ref(../CddAdcHwGroupRef)),'/../../CddAdcHwInstance'))&quot;,'CDD_ADCA')"/>
                              <a:da name="EDITABLE" value="false"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="(node:value(concat(node:path(node:ref(../CddAdcHwGroupRef)),'/../../CddAdcHwInstance')) = node:value(.))" 
                                  false="Hardware unit ID is not matching with the actual hardware unit under which the group is configured ."/>
                              </a:da>
                            </v:var>
                            <v:var name="CddAdcSocMask" type="INTEGER">
                              <a:a name="DESC" 
                                  value="EN: This parameter refers to the hardware unit to which the group belongs."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>                         
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:value(concat(node:path(node:ref(../CddAdcHwGroupRef)),'/CddAdcGroupSocMask')))&quot;,num:i(0))"/>
                              <a:da name="EDITABLE" value="false"/>
                              <a:da name="INVALID" type="Range">
                                <a:tst expr="&lt;=4294967295"/>
                                <a:tst expr="&gt;=0"/>
                              </a:da>
                            </v:var>
                          </v:ctr>
                        </v:lst>
                      </v:ctr>
                    </v:lst>
                    <v:lst name="CddAdcResultCheckerUnit" type="MAP">
                      <a:da name="MIN" value="0"/>
                      <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Cdd_Adc_F29H85x_ResultChecker')&quot;,num:i(10))"/>
                      <v:ctr name="CddAdcResultCheckerUnit" type="IDENTIFIABLE">
                        <a:a name="DESC" 
                              value="EN: This container contains the safety result checker configuration (parameters)."/>
                        <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                        
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                        </a:a>                          
                        <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                        <v:var name="CddAdcCheckerId" type="INTEGER">
                          <a:a name="DESC" 
                                value="EN: Numeric ID of the safety result checker."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>                         
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->num:i(node:pos(../.))&quot;,num:i(0))"/>
                          <a:da name="INVALID" type="Multi">
                            <mt:range>
                              <mt:tst expr="&lt;=9" false="Maximum safety checker ID should be 9"/>
                              <mt:tst expr="&gt;=0" false="Minimum safety checker ID should be 0"/>
                            </mt:range>
                            <mt:xpath expr="text:uniq(../.././/*[@name = 'CddAdcCheckerId'],node:value(.))" false="Safety checker ID should be unique"/>
                          </a:da>
                        </v:var>
                        <v:var name="CddAdcCheckerTolerance" type="INTEGER">
                          <a:a name="DESC" 
                                value="EN: This paramter configures the tolerance for the difference between CHECKRESULT1 and CHECKRESULT2."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                            
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>                         
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="INVALID" type="Range">
                            <a:tst expr="&lt;=167777216"/>
                            <a:tst expr="&gt;=0"/>
                          </a:da>
                          <a:da name="DEFAULT" value="0"/>    
                        </v:var>  
                        <v:ctr name="CddAdcSelResConfig1" type="IDENTIFIABLE">
                          <a:a name="DESC" 
                            value="EN: This container contains the checker result1 configuration (parameters) whose results will be compared."/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>                                                                                                 
                          <v:var name="CddAdcCheckerResultType" type="ENUMERATION">
                            <a:a name="DESC" 
                              value="EN: This parameter defines thw type of result that is being accessed - a raw result or a processed result."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">                                                         
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <a:da name="ENABLE" value="true"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_CheckerResType')&quot;,'CDD_ADC_SAFETY_CHECKER_INPUT_SOC')"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Adc_F29H85x_CheckerResType')[1]&quot;,'CDD_ADC_SAFETY_CHECKER_INPUT_SOC')"/>
                            <a:da name="WARNING" type="XPath" expr="(../../CddAdcSelResConfig2/CddAdcCheckerResultType = .)" false="Result type is different for both checker results."/>                          
                          </v:var>
                          <v:ref name="CddAdcChannelReference" type="REFERENCE">
                            <a:a name="DESC" 
                              value="EN: Numeric ID of the channel whose result is to be compared."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                            <a:da name="REF" value="ASPathDataOfSchema:/TI_F29H85x/Cdd_Adc/Cdd/CddAdcConfigSet/CddAdcHwUnit/CddAdcGroup/CddAdcChannel"/>
                            <a:da name="ENABLE" type="XPath" expr="(../CddAdcCheckerResultType = 'CDD_ADC_SAFETY_CHECKER_INPUT_SOC')"/>
                            <a:da name="WARNING" type="XPath">
                              <a:tst expr="not(node:path(node:ref(.)) = node:path(node:ref(../../CddAdcSelResConfig2/CddAdcChannelReference)))" false="Same channel is provided for two results of the safety checker unit"/>
                            </a:da>
                          </v:ref>
                          <v:ref name="CddAdcPpbReference" type="REFERENCE">
                            <a:a name="DESC" 
                              value="EN: Numeric ID of the channel whose result is to be compared."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
