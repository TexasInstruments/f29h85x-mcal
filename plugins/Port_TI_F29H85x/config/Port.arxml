                        <ECUC-ENUMERATION-PARAM-DEF UUID="d9624588-76a3-46db-bb20-1e743f116d64">
                          <SHORT-NAME>PortPinQualificationMode</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Synchronization mode of the peripheral signals.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
