                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                          <DEFAULT-VALUE>1</DEFAULT-VALUE>
                          <!-- @Calculated /TI_F29H85x/Port/PortConfigSet/PortContainer/PortPin/PortPinQualificationPeriod: INVALID(XPath: (node:value(.)=1) or (node:value(.) mod 2 = 0 and node:value(.) &lt;= 510 and node:value(.) &gt; 1))-->
                          <MAX>9223372036854775807</MAX>
                          <MIN>-9223372036854775808</MIN>
                          <!-- @CalculatedEnd -->
                        </ECUC-INTEGER-PARAM-DEF>
