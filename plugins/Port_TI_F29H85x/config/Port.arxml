                          <SYMBOLIC-NAME-VALUE>true</SYMBOLIC-NAME-VALUE>
                          <DEFAULT-VALUE>0</DEFAULT-VALUE>
                          <!-- @Calculated /TI_F29H85x/Port/PortConfigSet/PortContainer/PortPin/PortPinId: INVALID(XPath: node:value(.) = node:fallback(&quot;-&gt; ecu:get(concat(concat(&apos;Port_&apos;,node:value(/AUTOSAR/TOP-LEVEL-PACKAGES/Port/ELEMENTS/Port/PortGeneral/PortDeviceVariant)),concat(concat(&apos;_PackagePin_&apos;,node:value(../PortPhysicalPinId)),&apos;.pinNumber&apos;)))&quot;,&apos;0&apos;))-->
                          <MAX>9223372036854775807</MAX>
                          <MIN>-9223372036854775808</MIN>
                          <!-- @CalculatedEnd -->
                        </ECUC-INTEGER-PARAM-DEF>
