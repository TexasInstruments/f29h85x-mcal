      <SHORT-NAME>TI_F29H85x</SHORT-NAME>
      <ELEMENTS>
        <ECUC-DEFINITION-COLLECTION UUID="34c6726d-03dc-4867-be63-640d1b815312">
          <SHORT-NAME>myEcuParameterDefinition</SHORT-NAME>
          <MODULE-REFS>
            <MODULE-REF DEST="ECUC-MODULE-DEF">/TI_F29H85x/Port</MODULE-REF>
          </MODULE-REFS>
        </ECUC-DEFINITION-COLLECTION>
        <ECUC-MODULE-DEF UUID="f69a46c0-6016-49bf-9f5c-0eaa39dc25bd">
          <SHORT-NAME>Port</SHORT-NAME>
          <DESC>
            <L-2 L="EN">Configuration of the Port module.</L-2>
          </DESC>
