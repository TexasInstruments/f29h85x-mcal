                        <a:a name="UUID" value="be604f60-471c-4f53-8b6d-15be7450f4a3"/>
                        <a:da name="DEFAULT" value="RESTART_MODE_STOP"/>
                        <a:da name="RANGE">
                          <a:v>RESTART_MODE_STOP</a:v>
                          <a:v>RESTART_MODE_NOSTOP</a:v>
                        </a:da>
                      </v:var>
                      <v:lst name="CddI2cSeqChList" type="MAP">
                        <a:da name="MIN" value="1"/>
                        <v:ctr name="CddI2cSeqChList" type="IDENTIFIABLE">
                          <a:a name="DESC" value="EN: References to I2c channels and their order within the Sequence."/>
                          <a:a name="UUID" value="6a4113e1-75fa-4cac-a818-cce8010ab1e2"/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <v:ref name="CddI2cSeqChAssignment" type="REFERENCE">
                            <a:a name="DESC" value="EN: A Sequence reference to a I2c channel."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v class="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
