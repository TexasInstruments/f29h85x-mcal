                      </VALUE-CONFIG-CLASSES>
                      <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                      <DEFAULT-VALUE>0.01</DEFAULT-VALUE>
                      <MAX>INF</MAX>
                      <MIN>1.0E-6</MIN>
                    </ECUC-FLOAT-PARAM-DEF>
                    <ECUC-FLOAT-PARAM-DEF UUID="944eac1a-0b70-499c-95d1-ea188f82da11">
                      <SHORT-NAME>CddIpcTimeoutDuration</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Timeout value for synchronization of cores in seconds, if synchronization didn&apos;t happen within this time frame, Cdd_Ipc_Sync will abort and returns E_NOT_OK</L-2>
                      </DESC>
                      <SCOPE>LOCAL</SCOPE>
                      <ORIGIN>Texas Instruments</ORIGIN>
                      <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                      <VALUE-CONFIG-CLASSES>
                        <ECUC-VALUE-CONFIGURATION-CLASS>
                          <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                          <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                        </ECUC-VALUE-CONFIGURATION-CLASS>
                      </VALUE-CONFIG-CLASSES>
                      <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                      <DEFAULT-VALUE>0.1</DEFAULT-VALUE>
                      <MAX>INF</MAX>
                      <MIN>1.0E-6</MIN>
                    </ECUC-FLOAT-PARAM-DEF>
                  </PARAMETERS>
                  <REFERENCES>
                    <ECUC-REFERENCE-DEF UUID="547b9083-1861-4fab-8cbd-9c6e4d8f8aac">
                      <SHORT-NAME>CddIpcCounterClockRef</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">This parameter contains a reference to the sysClock to calculate clock cycles for IPC free run counter, which is used by the CDD IPC driver.</L-2>
                      </DESC>
                      <SCOPE>LOCAL</SCOPE>
                      <ORIGIN>Texas Instruments</ORIGIN>
                      <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
