                      <MAX>INF</MAX>
                      <MIN>1.0E-6</MIN>
                    </ECUC-FLOAT-PARAM-DEF>
                    <ECUC-FLOAT-PARAM-DEF UUID="1fa835f8-ee9f-414b-a4be-56ef894a3e68">
                      <SHORT-NAME>CddIpcTimeoutDuration</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Timeout value for synchronization of cores in seconds, if synchronization didn&apos;t happen within this time frame, Cdd_Ipc_Sync will abort and returns E_NOT_OK</L-2>
                      </DESC>
