  <AR-PACKAGES>
    <AR-PACKAGE UUID="51cde142-03cb-4dba-bf95-e23a97084baf">
      <SHORT-NAME>TI_F29H85x</SHORT-NAME>
      <ELEMENTS>
        <ECUC-MODULE-DEF UUID="e04b8819-b5ea-45b3-9ac5-c3cca68e5ae1">
          <SHORT-NAME>ResourceAllocator</SHORT-NAME>
          <DESC>
            <L-2 L="EN">Configuration of the Resource Allocator which maps resources such as hardware instances, channels, memory etc. to each CPU within Mcu.</L-2>
          </DESC>
          <ADMIN-DATA>
            <DOC-REVISIONS>
              <DOC-REVISION>
                <REVISION-LABEL>4.3.1</REVISION-LABEL>
                <ISSUED-BY>AUTOSAR</ISSUED-BY>
              </DOC-REVISION>
            </DOC-REVISIONS>
          </ADMIN-DATA>
          <SUPPORTED-CONFIG-VARIANTS>
            <SUPPORTED-CONFIG-VARIANT>VARIANT-PRE-COMPILE</SUPPORTED-CONFIG-VARIANT>
          </SUPPORTED-CONFIG-VARIANTS>
          <CONTAINERS>
            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="4e899e5c-d224-4766-9802-de4f1278e2a5">
              <SHORT-NAME>ResourceAllocatorGeneral</SHORT-NAME>
              <DESC>
                <L-2 L="EN">General configuration (parameters) of the Resource Allocator module.</L-2>
              </DESC>
              <PARAMETERS>
                <ECUC-ENUMERATION-PARAM-DEF UUID="fa69d494-e36b-4f5b-ae35-aa24db88212f">
                  <SHORT-NAME>Mode</SHORT-NAME>
                  <DESC>
                    <L-2 L="FOR-ALL">&lt;html&gt;
                      &lt;h3&gt;Selects Mode being used:&lt;/h3&gt;
                      &lt;ul&gt;
                      &lt;li&gt;&lt;b&gt;SETUP mode:&lt;/b&gt; Board designers define system-level settings and allocate resources to cores&lt;/li&gt;
                      &lt;li&gt;&lt;b&gt;CONFIGURE mode:&lt;/b&gt; Application developers use only resources allocated to their core&lt;/li&gt;
                      &lt;/ul&gt;
                    &lt;/html&gt;</L-2>
                  </DESC>
                  <SCOPE>LOCAL</SCOPE>
                  <ORIGIN>Texas Instruments</ORIGIN>
                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                  <VALUE-CONFIG-CLASSES>
                    <ECUC-VALUE-CONFIGURATION-CLASS>
                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                    </ECUC-VALUE-CONFIGURATION-CLASS>
                  </VALUE-CONFIG-CLASSES>
                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                  <DEFAULT-VALUE>CONFIGURE</DEFAULT-VALUE>
                  <LITERALS>
                    <ECUC-ENUMERATION-LITERAL-DEF>
                      <SHORT-NAME>CONFIGURE</SHORT-NAME>
                      <ORIGIN>Texas Instruments</ORIGIN>
                    </ECUC-ENUMERATION-LITERAL-DEF>
                    <ECUC-ENUMERATION-LITERAL-DEF>
                      <SHORT-NAME>SETUP</SHORT-NAME>
                      <ORIGIN>Texas Instruments</ORIGIN>
                    </ECUC-ENUMERATION-LITERAL-DEF>
                  </LITERALS>
                </ECUC-ENUMERATION-PARAM-DEF>
