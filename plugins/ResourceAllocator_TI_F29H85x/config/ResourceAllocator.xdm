                  <v:lst name="ASysCtl" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>

                    <v:ctr name="ASysCtl" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for ASysCtl (Analog System Control) module. Controls analog subsystem initialization including temperature sensor, analog reference, voltage regulator, brown-out reset, internal test node, and CMPSS mux configuration."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="a1b2c3d4-e5f6-7890-abcd-ef1234567060"/>

                      <!-- ===== TemperatureSensor sub-container ===== -->
                      <v:ctr name="TemperatureSensor" type="IDENTIFIABLE">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:a name="DESC" value="EN: Configuration for the on-chip temperature sensor (TSNSCTL register)."/>
                        <a:a name="UUID" value="b2c3d4e5-f6a7-8901-bcde-f01234567061"/>

                        <v:var name="TemperatureSensorEnable" type="BOOLEAN">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Enables the on-chip temperature sensor. When enabled, the sensor monitors die temperature and provides readings that can be used by the ADC for temperature measurement. When disabled, the sensor is powered off to save power. Must be enabled before Adc can perform temperature measurements."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="c3d4e5f6-a7b8-9012-cdef-012345678062"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>

                      </v:ctr>

                      <!-- ===== AnalogReference sub-container ===== -->
                      <v:ctr name="AnalogReference" type="IDENTIFIABLE">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:a name="DESC" value="EN: Configuration for the analog reference control (ANAREFCTL register). Controls ADC reference source and voltage range for ADC-A/B and ADC-C/D/E groups."/>
                        <a:a name="UUID" value="e5f6a7b8-c9d0-1234-efab-234567890064"/>

                        <v:var name="AnalogRefABMode" type="ENUMERATION">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC"><a:v><![CDATA[
                          <html>
                            <h3>Selects the voltage reference source for ADC modules A and B:</h3>
                            <ul>
                            <li><b>INTERNAL:</b> Uses the on-chip bandgap reference for stable, self-contained operation. No external reference pin connection required.</li>
                            <li><b>EXTERNAL:</b> Allows connection of a precision external reference voltage on the VREFHI pin for higher accuracy measurements. AnalogRefABVoltage setting has no effect in this mode.</li>
                            </ul>
                          </html>
                          ]]></a:v></a:a>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="f6a7b8c9-d0e1-2345-fabc-345678901065"/>
                          <a:da name="RANGE">
                            <a:v>REFERENCE_INTERNAL</a:v>
                            <a:v>REFERENCE_EXTERNAL</a:v>
                          </a:da>
                          <a:da name="DEFAULT" value="REFERENCE_INTERNAL"/>
                        </v:var>

                        <v:var name="AnalogRefABVoltage" type="ENUMERATION">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP' and node:value(../AnalogRefABMode) != 'EXTERNAL'"/>
                          <a:a name="DESC"><a:v><![CDATA[
                          <html>
                            <h3>Selects the internal reference voltage level for ADC modules A and B:</h3>
                            <ul>
                            <li><b>REFERENCE_3_3V:</b> Selects the 1.65V internal reference, suitable for use with a 3.3V analog supply.</li>
                            <li><b>REFERENCE_2_5V:</b> Selects the 2.5V internal reference, suitable for use with a 2.5V analog supply.</li>
                            </ul>
                            <p>Only applicable when AnalogRefABMode is set to INTERNAL. Has no effect when external reference is selected.</p>
                          </html>
                          ]]></a:v></a:a>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="a7b8c9d0-e1f2-3456-abcd-456789012066"/>
                          <a:da name="RANGE">
                            <a:v>REFERENCE_3_3V</a:v>
                            <a:v>REFERENCE_2_5V</a:v>
                          </a:da>
                          <a:da name="DEFAULT" value="REFERENCE_3_3V"/>
                        </v:var>

                        <v:var name="AnalogRefCDEMode" type="ENUMERATION">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC"><a:v><![CDATA[
                          <html>
                            <h3>Selects the voltage reference source for ADC modules C, D, and E:</h3>
                            <ul>
                            <li><b>REFERENCE_INTERNAL:</b> Uses the on-chip bandgap reference for stable, self-contained operation. No external reference pin connection required.</li>
                            <li><b>REFERENCE_EXTERNAL:</b> Allows connection of a precision external reference voltage on the VREFHI pin for higher accuracy measurements. AnalogRefCDEVoltage setting has no effect in this mode.</li>
                            </ul>
                          </html>
                          ]]></a:v></a:a>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="b8c9d0e1-f2a3-4567-bcde-567890123067"/>
                          <a:da name="RANGE">
                            <a:v>REFERENCE_INTERNAL</a:v>
                            <a:v>REFERENCE_EXTERNAL</a:v>
                          </a:da>
                          <a:da name="DEFAULT" value="REFERENCE_INTERNAL"/>
                        </v:var>

                        <v:var name="AnalogRefCDEVoltage" type="ENUMERATION">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP' and node:value(../AnalogRefCDEMode) != 'EXTERNAL'"/>
                          <a:a name="DESC"><a:v><![CDATA[
                          <html>
                            <h3>Selects the internal reference voltage level for ADC modules C, D, and E:</h3>
                            <ul>
                            <li><b>REFERENCE_3_3V:</b> Selects the 1.65V internal reference, suitable for use with a 3.3V analog supply.</li>
                            <li><b>REFERENCE_2_5V:</b> Selects the 2.5V internal reference, suitable for use with a 2.5V analog supply.</li>
                            </ul>
                            <p>Only applicable when AnalogRefCDEMode is set to INTERNAL. Has no effect when external reference is selected.</p>
                          </html>
                          ]]></a:v></a:a>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="c9d0e1f2-a3b4-5678-cdef-678901234068"/>
                          <a:da name="RANGE">
                            <a:v>REFERENCE_3_3V</a:v>
                            <a:v>REFERENCE_2_5V</a:v>
                          </a:da>
                          <a:da name="DEFAULT" value="REFERENCE_3_3V"/>
                        </v:var>

                      </v:ctr>

                      <!-- ===== VoltageRegulator sub-container ===== -->
                      <v:ctr name="VoltageRegulator" type="IDENTIFIABLE">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:a name="DESC" value="EN: Configuration for the internal voltage regulator (VREGCTL register)."/>
                        <a:a name="UUID" value="e1f2a3b4-c5d6-7890-efab-890123456070"/>

                        <v:var name="VMONMaskEnable" type="BOOLEAN">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Enables the VMON function mask on a TRIM load. When true, masks the generation of POR/BOR for a fixed duration whenever TRIM bits are changed, preventing spurious resets during TRIM operations. When false, POR/BOR generation is not masked on a TRIM load."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="f2a3b4c5-d6e7-8901-fabc-901234567071"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>

                        <v:var name="VREGPowerDown" type="BOOLEAN">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Powers down the internal voltage regulator that provides the Core VDD supply for the device. When false (default), the internal regulator is enabled and regulates the Core VDD voltage. When true, the internal regulator is powered down and an external Core VDD supply must be provided. On devices where VREGENZ is not bonded out, this parameter must be used to disable the internal VREG when an external supply is used."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="a3b4c5d6-e7f8-9012-abcd-012345678072"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>

                      </v:ctr>

                      <!-- ===== BrownOutReset sub-container ===== -->
                      <v:ctr name="BrownOutReset" type="IDENTIFIABLE">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:a name="DESC" value="EN: Configuration for Brown-Out Reset Level (VMONCTL register)."/>
                        <a:a name="UUID" value="c5d6e7f8-a9b0-1234-cdef-234567890074"/>

                        <v:var name="BORLDisable" type="BOOLEAN">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Disables the brown-out reset level circuit that monitors the supply voltage. When false (default), the brown-out reset circuit is active and triggers a reset if the supply voltage drops below the brown-out threshold, preventing unpredictable behavior during power supply fluctuations. When true, the brown-out reset level monitor is disabled."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="d6e7f8a9-b0c1-2345-defa-345678901075"/>
                          <a:da name="DEFAULT" value="false"/>
                        </v:var>

                      </v:ctr>

                      <!-- ===== InternalTestNode sub-container ===== -->
                      <v:ctr name="InternalTestNode" type="IDENTIFIABLE">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:a name="DESC" value="EN: Configuration for the internal analog test node (INTERNALTESTCTL register). Key-protection sequence is applied automatically."/>
                        <a:a name="UUID" value="f8a9b0c1-d2e3-4567-fabc-567890123077"/>

                        <v:var name="InternalTestNodeSelect" type="ENUMERATION">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Selects which internal analog signal is routed to the analog test node for diagnostic purposes. Allows internal signals such as temperature sensor output, voltage references, and regulator outputs to be measured via the ADC for system verification and calibration. The selected signal is connected during Mcu_Init() and can be changed at runtime via Mcu_ASysCtl_SelectInternalTestNode()."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" value="a9b0c1d2-e3f4-5678-abcd-678901234078"/>
                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.ASysCtlInternalTestInput')&quot;,'MCU_ASYSCTL_TEST_NODE_NO_CONN')"/>
                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.ASysCtlInternalTestInput')[1]&quot;,'MCU_ASYSCTL_TEST_NODE_NO_CONN')"/>
                        </v:var>
                      </v:ctr>

                    </v:ctr>
                  </v:lst>
                  <v:lst name="Cdd_Xbar" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>
                    <v:ctr name="Cdd_Xbar" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for Cdd_Xbar module."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="31a19629-052c-4d10-a4a3-c438e121aef8"/>
                          
                      <v:lst name="CddXbarOutputXbarFlag" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" value="1"/>
                        <v:ctr name="CddXbarOutputXbarFlag" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a Cdd Xbar Output Xbar flag."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="9cae0d17-38e8-4635-ae26-a73132792ccf"/>
                          <v:var name="InstanceName" type="STRING">
                            <a:a name="DESC" value="EN: Cdd Xbar Output Xbar flag."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="fdfc768d-195d-49ed-95ca-88596283062a"/>
                            <a:a name="EDITABLE" value="false"/>
                            <a:da name="DEFAULT" value="OUTPUTXBARFlags"/>
                          </v:var>
                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="2f3c6b2e-2ec9-4844-acf0-5499d334050d"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                          <v:var name="BaseAddr" type="STRING">
                            <a:a name="DESC" value="EN: Base address of the Cdd_Xbar instance. This field represents the macro as defined in hw_memmap.h"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="UUID" value="61c43aa1-09cf-434b-9d30-3144572d4836"/>
                            <a:a name="EDITABLE" value="false"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat('OUTPUTXBAR1_FLAGS_BASE_FRAME(',substring-after(node:value(../Frame),'FRAME'),'U)')&quot;, 'OUTPUTXBAR1_FLAGS_BASE_FRAME(0U)')"/>
                            <a:da name="INVALID" type="XPath">
                                    <a:tst expr="(contains(node:value(.),concat('(', substring-after(node:value(../Frame),'FRAME'),'U)')))"
                                          false="Frame and Base address should match. Please run AutoCalc."/>
                    </a:da>
                          </v:var>
                        </v:ctr>
                      </v:lst>
                      <v:lst name="CddXbarInputFlag" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" value="1"/>
                        <v:ctr name="CddXbarInputFlag" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a Cdd_Xbar Input flags."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="925e0843-3808-4635-ae26-a73582722c1f"/>
                          <v:var name="InstanceName" type="STRING">
                            <a:a name="DESC" value="EN: Cdd Xbar Input flag."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="fdfc558d-195d-49ed-95ca-885962dd0aaa"/>
                            <a:a name="EDITABLE" value="false"/>
                            <a:da name="DEFAULT" value="INPUTXBARFlags"/>
                          </v:var>
                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="2eec6b2e-2ec9-4844-acf0-5499d334050d"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                              
                          <v:var name="BaseAddr" type="STRING">
                            <a:a name="DESC" value="EN: Base address of the Cdd_Xbar input flag. This field represents the macro as defined in hw_memmap.h"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="UUID" value="61c43aa1-09cf-434b-5733-3144572d4836"/>
                            <a:a name="EDITABLE" value="false"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat('XBAR_BASE_FRAME(',substring-after(node:value(../Frame),'FRAME'),'U)')&quot;, 'XBAR_BASE_FRAME(0U)')"/>
                            <a:da name="INVALID" type="XPath">
                                    <a:tst expr="(contains(node:value(.),concat('(', substring-after(node:value(../Frame),'FRAME'),'U)')))"
                                          false="Frame and Base address should match. Please run AutoCalc."/>
                    </a:da>
                          </v:var>
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:lst>
                  <v:lst name="Cdd_Dma" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>
                    <v:ctr name="Cdd_Dma" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for the Cdd_Dma module hardware resources. This defines the available RTDMA hardware instances and their channels that can be allocated to different CPU contexts in the system."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="45229629-052c-8623-a4a3-8106e6652ef8"/>
                      <v:lst name="CddDmaHwInstance" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->num:i(count(ecu:list('ResourceAllocator_F29H85x.Cdd_DmaInstanceName')))&quot;,'2')"/>
                        <v:ctr name="CddDmaHwInstance" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a RTDMA hardware instance. Each instance represents a physical RTDMA peripheral with its own set of channels. Multiple instances can be configured if the device supports multiple RTDMA peripherals."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="785e0834-2308-4635-ae44-723582722c10"/>
                          <v:var name="InstanceName" type="ENUMERATION">
                            <a:a name="DESC" value="EN: The RTDMA hardware instance. This identifies the physical DMA peripheral on the microcontroller. Each instance must be uniquely named and can only be configured once."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="5387558d-195d-49ed-95ca-50204428a91"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="DEFAULT" value="RTDMA1"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->node:when(node:value(../../../../../*[@name = 'CPU1_Lockstep']) = 'true', ecu:list('ResourceAllocator_F29H85x.Cdd_DmaInstanceName')[1], ecu:list('ResourceAllocator_F29H85x.Cdd_DmaInstanceName'))&quot;,'RTDMA1')"/>
                            <a:da name="INVALID" type="Multi">
                                  <mt:xpath expr="text:uniq(../../../../../.././/*[@name = 'InstanceName'],node:value(.))"
                                        false="Every Cdd Dma instance must be allocated only once."/>
                            </a:da>
                          </v:var>
                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="676a8622-3457-4f22-c4fc-9c6183fb014d"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                          <v:var name="CddDmaPriorityScheme" type="ENUMERATION">
                            <a:a name="DESC"
                                value="EN: Specifies the priority scheme round robin or software configured priority for channels.
                                If software configured priority is selected, the priority value shall be specified for every channel. "/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="bcb83f67-6345-4a01-bfdd-26529feb1eb9"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="RANGE">
                                <a:v>CDD_DMA_PRIORITY_ROUND_ROBIN</a:v>
                                <a:v>CDD_DMA_PRIORITY_SOFTWARE_CONFIG</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="CDD_DMA_PRIORITY_ROUND_ROBIN"/>
                          </v:var>
                          <v:var name="CddDmaEmulationMode" type="ENUMERATION">
                              <a:a name="DESC"
                                  value="EN: This parameter specifies the action when an emulation halt event occurs.
                                  CDD_DMA_EMULATION_STOP: The DMA completes the current read-write operation,then halts.
                                  CDD_DMA_EMULATION_FREE_RUN: The DMA continues running during an emulation halt."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="UUID" value="2838c86b-81be-4dc8-a76f-58a30b1b1a4d"/>
                              <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                              <a:da name="RANGE">
                                  <a:v>CDD_DMA_EMULATION_STOP</a:v>
                                  <a:v>CDD_DMA_EMULATION_FREE_RUN</a:v>
                              </a:da>
                              <a:da name="DEFAULT" value="CDD_DMA_EMULATION_STOP"/>
                          </v:var>
                          <v:var name="CddDmaMpuEnable" type="BOOLEAN">
                            <a:a name="DESC"
                                 value="EN: Enables/Disables Memory Protection Unit (MPU) which provides memory protection support
                                        and prevents illegal accesses."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                 type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="44cb4230-aab9-45fc-8624-5e312757268a"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="DEFAULT" value="false"/>
                          </v:var>
                          <v:lst name="CddDmaMpuRegion" type="MAP">
                            <a:da name="MIN" value="1"/>
                            <a:da name="MAX" value="16"/>
                            <a:da name="ENABLE" type="XPath" expr="(../CddDmaMpuEnable='true')"/>
                            <a:da name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <v:ctr name="CddDmaMpuRegion" type="IDENTIFIABLE">
                              <a:a name="DESC"
                                   value="EN: Configuration container for a DMA Memory Protection Unit (MPU) region. Each MPU region defines a protected memory address range with specific access permissions (read/write/no access) for selected DMA channels."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../Mode) = 'SETUP'"/>
                              <a:a name="UUID" value="4382b6f6-f2ca-496f-8104-212656d88f97"/>
                              <a:da name="INVALID" type="XPath">
                                <a:tst expr="text:uniq((../../../../CddDmaHwInstance/*/CddDmaMpuRegion/*/@name),@name)" false="CddDmaMpuRegion name has to be unique across all DMA instances"/>
                              </a:da>
                              <v:var name="CddDmaMpuRegionId" type="ENUMERATION">
                                <a:a name="DESC"
                                     value="EN: Specifies the MPU Region Id of RTDMA MPU instance."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="d0319405-5924-4b82-9467-51319cff2da8"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.Cdd_DmaMpuRegions')[1]&quot;,'CDD_DMA1_MPU1')"/>
                                <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.Cdd_DmaMpuRegions')&quot;,'CDD_DMA1_MPU1')"/>
                                <a:da name="INVALID" type="XPath"
                                      expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="MPU Region must be unique.">
                                </a:da>
                              </v:var>
                              <v:var name="CddDmaMpuStartAddress" type="INTEGER">
                                <a:a name="DESC"
                                     value="EN:DMA MPU Region Start Address. Granularity of 4KB is mandatory e.g., 0x1000, 0x2000, 0x3000,.."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="DEFAULT_RADIX" value="HEX" />
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="efa76654-5312-46fd-af04-8d8eb3e52d68"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="DEFAULT" value="0"/>
                                <a:da name="INVALID" type="Range">
                                  <a:tst expr="&lt;=4294967295"/>
                                  <a:tst expr="&gt;=0"/>
                                </a:da>
                                <a:da name="INVALID" type="XPath">
                                  <a:tst expr="(node:value(.) mod 4096) = 0" false="Start address must be aligned to 4KB boundary(e.g., 0x1000, 0x2000, 0x3000)"/>
                                </a:da>
                              </v:var>
                              <v:var name="CddDmaMpuEndAddress" type="INTEGER">
                                <a:a name="DESC"
                                     value="EN:DMA MPU Region End Address. Granularity of 4KB is mandatory e.g., 0x0FFF, 0x1FFF, 0x2FFF,.."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="DEFAULT_RADIX" value="HEX" />
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="2b7d2a43-782b-4d75-b082-6083410fa306"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="DEFAULT" value="0"/>
                                <a:da name="INVALID" type="Range">
                                  <a:tst expr="&lt;=4294967295"/>
                                  <a:tst expr="&gt;=0"/>
                                </a:da>
                                <a:da name="INVALID" type="XPath">
                                  <a:tst expr="((node:value(.)+1) mod 4096) = 0" false="End address must be aligned to 4KB boundary(e.g., 0x0FFF, 0x1FFF, 0x2FFF,..)"/>
                                  <a:tst expr="node:value(.) &gt;=node:value(../CddDmaMpuStartAddress)" false="Start address must be less than end address"/>
                                </a:da>
                              </v:var>
                              <v:var name="CddDmaMpuAccessPermission" type="ENUMERATION">
                                <a:a name="DESC"
                                     value="EN: Specifies the MPU Region access permissions of the RTDMA MPU instance."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="611359b3-d4dc-4221-833c-d51654257930"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="RANGE">
                                    <a:v>CDD_DMA_NO_ACCESS</a:v>
                                    <a:v>CDD_DMA_READ_ACCESS</a:v>
                                    <a:v>CDD_DMA_READ_WRITE_ACCESS</a:v>
                                </a:da>
                                <a:da name="DEFAULT" value="CDD_DMA_NO_ACCESS"/>
                              </v:var>
                              <v:lst name="CddDmaMpuChannelEnable">
                                <a:da name="MIN" value="1"/>
                                <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->num:i(count(ecu:list('ResourceAllocator_F29H85x.Cdd_DmaChannelName')))&quot;,'10')"/>
                                <a:da name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <v:ref name="CddDmaMpuChannelEnable" type="REFERENCE">
                                  <a:a name="DESC"
                                       value="EN: Reference to a DMA channel that will be granted access to this MPU region. Multiple channels can be associated with a single MPU region. Only channels listed here will be allowed to access the memory range defined by this region according to the specified access permissions."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                    <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="UUID" value="e99c03c1-30ed-4e7a-97ad-255cc4b13996"/>
                                  <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../../Mode) = 'SETUP'"/>
                                  <a:da name="REF"
                                      value="ASPathDataOfSchema:/TI_F29H85x/ResourceAllocator/ResourceAllocatorGeneral/Cdd_Dma/CddDmaHwInstance/CddDmaChannel"/>
                                  <a:da name="RANGE" type="XPath">
                                      <a:tst expr="node:paths(../../../../CddDmaChannel/*)"/>
                                  </a:da>
                                  <a:da name="INVALID" type="XPath">
                                    <a:tst expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Channel selection has to be unique in an MPU Region."/>
                                  </a:da>
                                </v:ref>
                              </v:lst>
                            </v:ctr>
                          </v:lst>
                          <v:lst name="CddDmaChannel" type="MAP">
                            <a:da name="MIN" value="1"/>
                            <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->num:i(count(ecu:list('ResourceAllocator_F29H85x.Cdd_DmaChannelName')))&quot;,'10')"/>
                            <a:da name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <v:ctr name="CddDmaChannel" type="IDENTIFIABLE">
                              <a:a name="DESC" value="EN: Configuration of a DMA channel within this RTDMA hardware instance. Each channel represents an independent DMA transfer engine that can move data between memory and peripherals. This container defines all available channels (e.g., CH1, CH2, ..., CH10) for the instance, which can then be allocated to specific CPU contexts."/>
                              <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../Mode) = 'SETUP'"/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="UUID" value="74ae0d00-15e8-4639-ae26-aa319f792c8f"/>
                            <v:var name="ChannelName" type="ENUMERATION">
                                <a:a name="DESC" value="EN: Selects the DMA channel identifier within this RTDMA instance (e.g., CH1, CH2, CH3, ..., CH10). Each channel provides an independent data transfer path and must be uniquely identified within the instance."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="3434778d-195d-6d78-95ca-884c623367aa"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.Cdd_DmaChannelName')&quot;,'CH1')"/>
                                <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.Cdd_DmaChannelName')[1]&quot;,'CH1')"/>
                                <a:da name="INVALID" type="XPath">
                                  <a:tst expr="text:uniq(../../.././/*[@name = 'ChannelName'],node:value(.))"
                                        false="Every ChannelName must be selected only once."/>
                                </a:da>
                              </v:var>
                              <v:var name="BaseAddr" type="STRING">
                                  <a:a name="DESC" value="EN: Base address of the RTDMA channel. This field represents the macro as defined in hw_memmap.h. The address is automatically calculated based on the instance name, channel name, and selected peripheral frame."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="UUID" value="8365651e-d645-4d80-9a60-559242a23e98"/>
                                  <a:a name="EDITABLE" value="false"/>
                                  <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat(node:value(../../../InstanceName), node:value(../ChannelName), '_BASE_FRAME(',substring-after(node:value(../../../Frame),'FRAME'),'U)')&quot;,'RTDMA1CH1_BASE_FRAME(0U)')"/>
                                  <a:da name="INVALID" type="XPath">
                                      <a:tst expr="(contains(node:value(.),concat('(', substring-after(node:value(../../../Frame),'FRAME'),'U)')))"
                                          false="Frame and Base address should match. Please run AutoCalc."/>
                                      <a:tst expr="(contains(node:value(.),node:value(../ChannelName)))"
                                          false="Channel name and Base address should match. Please run AutoCalc."/>
								                  </a:da>
                              </v:var>
                              <v:var name="CddDmaChannelPriority" type="INTEGER">
                                  <a:a name="DESC"
                                      value="EN: DMA channel priority level for software-configured priority arbitration. Valid values: CDD_DMA_CHPRIORITY0 (0x0 - special condition during arbitration), CDD_DMA_CHPRIORITY1 (0x1 - default priority), CDD_DMA_CHPRIORITY2 (0x2 - medium priority), CDD_DMA_CHPRIORITY3 (0x3 - highest priority). This setting is only used when the DMA instance is configured with software-configured priority scheme; it is ignored in round-robin mode."/>
                                  <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                  </a:a>
                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                  <a:a name="SCOPE" value="LOCAL"/>
                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                  <a:a name="UUID" value="4632d1cc-a811-4a84-9039-e1c64b9f42d6"/>
                                  <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                  <a:da name="DEFAULT" value="1"/>
                                  <a:da name="INVALID" type="Range">
                                      <a:tst expr="&lt;=3"/>
                                      <a:tst expr="&gt;=0"/>
                                  </a:da>
                              </v:var>
                            </v:ctr>
                          </v:lst>
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:lst>
                  <v:lst name="DLTFifoRegs" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>
                    
                    <v:ctr name="DLTFifoRegs" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for DLTFifoRegs module."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="f6a7b8c9-d0e1-2347-fabc-678901234567"/>
                      
                      <v:lst name="DLTFifoRegsAllocatedInstance" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" value="1"/>
                        
                        <v:ctr name="DLTFifoRegsAllocatedInstance" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a DLTFifoRegs instance."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="a7b8c9d0-e1f2-3458-abcd-789012345678"/>
                          
                          <v:var name="InstanceName" type="ENUMERATION">
                            <a:a name="DESC" value="EN: Selects the DLTFifoRegs instance to be allocated."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="b8c9d0e1-f2a3-4569-bcde-890123456789"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.DLTFifoRegsInstanceName')&quot;,'DLTFIFOREGS')"/>
                            <a:da name="DEFAULT" value="DLTFIFOREGS"/>
                          </v:var>

                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="c9d0e1f2-a3b4-5670-cdef-901234567890"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                          
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:lst>
                  <v:lst name="Error_Aggregator" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>
                    
                    <v:ctr name="Error_Aggregator" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for Error_Aggregator module."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="e1f2a3b4-c5d6-7892-efab-123456789012"/>
                      
                      <v:lst name="Error_AggregatorAllocatedInstance" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" value="1"/>
                        
                        <v:ctr name="Error_AggregatorAllocatedInstance" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a Error_Aggregator instance."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="f2a3b4c5-d6e7-8903-fabc-234567890123"/>
                          
                          <v:var name="InstanceName" type="ENUMERATION">
                            <a:a name="DESC" value="EN: Selects the Error_Aggregator instance to be allocated."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="a3b4c5d6-e7f8-9014-abcd-345678901234"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.Error_AggregatorInstanceName')&quot;,'ERROR_AGGREGATOR')"/>
                            <a:da name="DEFAULT" value="ERROR_AGGREGATOR"/>
                          </v:var>

                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="b4c5d6e7-f8a9-0125-bcde-456789012345"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                          
                          <v:var name="BaseAddr" type="STRING">
                            <a:a name="DESC" value="EN: Base address of the Error_Aggregator instance. This field represents the macro as defined in hw_memmap.h"/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="UUID" value="c5d6e7f8-a9b0-1236-cdef-567890123456"/>
                            <a:a name="EDITABLE" value="false"/>
                            <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat(translate(node:value(../InstanceName),'_',''),'_BASE_FRAME(',substring-after(node:value(../Frame),'FRAME'),'U)')&quot;,'ERRORAGGREGATOR_BASE_FRAME(0U)')"/>
                            <a:da name="INVALID" type="XPath">
                                <a:tst expr="(contains(node:value(.),concat('(', substring-after(node:value(../Frame),'FRAME'),'U)')))"
                                      false="Frame and Base address should match. Please run AutoCalc."/>
                            </a:da>
                          </v:var>
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:lst>
                  <v:lst name="ESM" type="MAP">
                    <a:a name="EDITABLE" type="XPath" expr="node:value(../Mode) = 'SETUP'"/>
                    <a:da name="MIN" value="0"/>
                    <a:da name="MAX" value="1"/>
                    
                    <v:ctr name="ESM" type="IDENTIFIABLE">
                      <a:a name="EDITABLE" type="XPath" expr="node:value(../../Mode) = 'SETUP'"/>
                      <a:a name="DESC" value="EN: Configuration container for ESM module."/>
                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                        <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                      </a:a>
                      <a:a name="UUID" value="d6e7f8a9-b0c1-2347-defa-678901234567"/>
                      
                      <v:lst name="ESMAllocatedInstance" type="MAP">
                        <a:a name="EDITABLE" type="XPath" expr="node:value(../../../Mode) = 'SETUP'"/>
                        <a:da name="MIN" value="0"/>
                        <a:da name="MAX" value="1"/>
                        
                        <v:ctr name="ESMAllocatedInstance" type="IDENTIFIABLE">
                          <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../Mode) = 'SETUP'"/>
                          <a:a name="DESC" value="EN: Configuration of a ESM instance."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="e7f8a9b0-c1d2-3458-efab-789012345678"/>
                          
                          <v:var name="InstanceName" type="ENUMERATION">
                            <a:a name="DESC" value="EN: Selects the ESM instance to be allocated."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="f8a9b0c1-d2e3-4569-fabc-890123456789"/>
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.ESMInstanceName')&quot;,'ESM')"/>
                            <a:da name="DEFAULT" value="ESM"/>
                          </v:var>

                          <v:var name="Frame" type="ENUMERATION">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:a name="DESC" value="EN: Selects the peripheral frame. Frames enable simultaneous access from different initiators to peripherals without arbitration stalls, each with its own base address."/>
                            <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                            </a:a>
                            <a:a name="ORIGIN" value="Texas Instruments"/>
                            <a:a name="SCOPE" value="LOCAL"/>
                            <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                            <a:a name="UUID" value="a9b0c1d2-e3f4-5670-abcd-901234567890"/>
                            <a:da name="RANGE">
                              <a:v>FRAME0</a:v>
                              <a:v>FRAME1</a:v>
                              <a:v>FRAME2</a:v>
                              <a:v>FRAME3</a:v>
                            </a:da>
                            <a:da name="DEFAULT" value="FRAME0"/>
                          </v:var>
                          
                        </v:ctr>
                      </v:lst>
                    </v:ctr>
                  </v:lst>
              </v:ctr>
            </v:ctr>
          </d:chc>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>

</datamodel>
