                          <a:a name="DESC" value="EN: Configuration container for Context specific settings for the FsiRx module."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                            <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="UUID" value="e1f2a3b4-c5d6-7891-efab-123456789012"/>
                          
                          <v:lst name="FsiRxAllocatedInstance" type="MAP">
                            <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../Mode) = 'SETUP'"/>
                            <a:da name="MIN" value="0"/>
                            <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->num:i(count(ecu:list('ResourceAllocator_F29H85x.FsiRxInstanceName')))&quot;,'4')"/>
                            
                            <v:ctr name="FsiRxAllocatedInstance" type="IDENTIFIABLE">
                              <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../Mode) = 'SETUP'"/>
                              <a:a name="DESC" value="EN: Configuration of a FsiRx instance allocated to this context."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                <icc:v mclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="UUID" value="f2a3b4c5-d6e7-8902-fabc-234567890123"/>
                              
                              <v:var name="InstanceName" type="ENUMERATION">
                                <a:a name="DESC" value="EN: Selects the FsiRx instance to be allocated."/>
                                <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                </a:a>
                                <a:a name="ORIGIN" value="Texas Instruments"/>
                                <a:a name="SCOPE" value="LOCAL"/>
                                <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                <a:a name="UUID" value="a3b4c5d6-e7f8-9013-abcd-345678901234"/>
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ResourceAllocator_F29H85x.FsiRxInstanceName')&quot;,'FSIRXA')"/>
                                <a:da name="DEFAULT" value="FSIRXA"/>
                                <a:da name="INVALID" type="XPath">
                                  <a:tst expr="text:uniq(../../../../../.././/*[@name = 'InstanceName'],node:value(.))"
                                        false="Every FsiRx instance must be allocated only once."/>
                                </a:da>
                              </v:var>

                              <v:var name="DebugHaltEnabled" type="BOOLEAN">
                                <a:a name="EDITABLE" type="XPath" expr="node:value(../../../../../../../Mode) = 'SETUP'"/>
                                <a:a name="DESC" value="EN: Controls whether the peripheral DBGHALT signal is activated when the CPU enters HALT mode"/>
