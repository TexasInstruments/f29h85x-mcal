                                <a:a name="EDITABLE" value="false"/>
                                <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->concat(node:value(../InstanceName),'_BASE_FRAME(',substring-after(node:value(../Frame),'FRAME'),'U)')&quot;,'FSIRXA_BASE_FRAME(0U)')"/>
                                <a:da name="INVALID" type="XPath">
                                    <a:tst expr="(contains(node:value(.),concat('(', substring-after(node:value(../Frame),'FRAME'),'U)')))"
