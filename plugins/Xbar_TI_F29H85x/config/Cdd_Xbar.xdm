                                                  <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list(concat('Icl_Xbar_Input_Lines', '.', ../../CddXbarIclXbarInputGroup))[1]&quot;,'CDD_XBAR_ICL_EPWM1A_MINDB')"/>
                                                  <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list(concat('Icl_Xbar_Input_Lines', '.', ../../CddXbarIclXbarInputGroup))&quot;,'CDD_XBAR_ICL_EPWM1A_MINDB')"/>
                                                  <a:da name="INVALID" type="XPath"
                                                      expr="text:uniq(../*[@name=node:name(.)], node:value(.))" false="Please make sure to select an Input Line value only once for Input configuration of ICL Crossbar.">
                                                  </a:da>
                                              </v:var>
                                          </v:lst>
                                      </v:ctr>
                                  </v:lst>
                                  <!-- Design: MCAL-25825 -->
                                  <v:var name="CddXbarIclXbarOutputLine" type="ENUMERATION">
                                    <a:a name="DESC"
                                        value="EN: Number of Output Line instance to be set for ICL Crossbar."/>
                                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                        type="IMPLEMENTATIONCONFIGCLASS">
                                        <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                    </a:a>
                                    <a:a name="ORIGIN" value="Texas Instruments"/>
                                    <a:a name="SCOPE" value="LOCAL"/>
                                    <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                    <a:a name="OPTIONAL" value="false"/>
                                    <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                    <a:da name="EDITABLE" value="true"/>
                                    <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('ICL_Xbar_Output_Lines')[1]&quot;,'CDD_XBAR_ICLXBAR1')"/>
                                    <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('ICL_Xbar_Output_Lines')&quot;,'CDD_XBAR_ICLXBAR1')"/>
                                    <a:da name="INVALID" type="XPath"
                                        expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Please make sure to select an output line value only once for ICL Crossbar.">
                                    </a:da>
                                  </v:var>
                                  <!-- Design: MCAL-25717 -->
                                  <v:var name="CddXbarIclXbarOutputInversion" type="BOOLEAN">
                                      <a:a name="DESC"
                                          value="EN: Option to invert the output signal for the selected output line of the ICL Crossbar instance."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:a name="DEFAULT" value="false"/>
                                      <a:a name="ENABLE" value="true"/>
                                  </v:var>
                              </v:ctr>
                          </v:lst>
                          <!-- Design: MCAL-25712 -->
                          <v:var name="CddXbarIclXbarConfigurationLock" type="BOOLEAN">
                              <a:a name="DESC"
                                  value="EN: Option to lock the ICL crossbar instance for any further configuration until System Reset. Cannot be unlocked once locked unless reset."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="OPTIONAL" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:a name="DEFAULT" value="false"/>
                              <a:a name="ENABLE" value="true"/>
                              <a:a name="TOOLTIP" value="Locks further Input selection and Output Inversion configuration for ICL Crossbar, once locked will remain the same unless system reset."/>
                          </v:var>
                      </v:ctr>
                  </v:ctr>
                  <v:ctr name="CddXbarGeneral" type="IDENTIFIABLE">
                      <a:a name="DESC"
                          value="EN: Contains the general configuration parameters of the module."/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <a:da name="ENABLE" value="true"/>
                      <!-- Design: MCAL-28133 -->
                      <v:var name="CddXbarDevErrorDetect" type="BOOLEAN">
                          <a:a name="DESC" value="EN: Switches the Development Error Detection and Reporting ON or OFF for this module."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v class="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="false"/>
                      </v:var>
                      <v:var name="CddXbarAPIEnable" type="BOOLEAN">
                          <a:a name="DESC" value="EN: Enables or Disables the APIs of this module."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v class="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="DEFAULT" value="true"/>
                      </v:var>
                      <!-- Design: MCAL-28134 -->
                      <v:var name="CddXbarVersionInfoApi" type="BOOLEAN">
                          <a:a name="DESC" value="EN: Switches the Cdd_Xbar_GetVersionInfo function ON or OFF."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v class="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="ENABLE" type="XPath" expr="(../CddXbarAPIEnable='true')"/>
                          <a:da name="DEFAULT" value="true"/>
                      </v:var>
                      <!-- Design: MCAL-28135 -->
                      <v:var name="CddXbarInputFlagApi" type="BOOLEAN">
                          <a:a name="DESC" value="EN: Switches Cdd_Xbar_InputFlagStatus() and Cdd_Xbar_InputFlagClear() ON or OFF."/>
                          <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                              <icc:v class="PreCompile">VariantPreCompile</icc:v>
                          </a:a>
                          <a:a name="ORIGIN" value="Texas Instruments"/>
                          <a:a name="SCOPE" value="LOCAL"/>
                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <a:da name="ENABLE" type="XPath" expr="(../CddXbarAPIEnable='true')"/>
                          <a:da name="DEFAULT" value="true"/>
                      </v:var>
                  </v:ctr>
                  <d:ref type="REFINED_MODULE_DEF"
                         value="ASPath:/AUTOSAR/EcucDefs/Cdd"/>
                </v:ctr>
              </d:chc>
              <d:chc name="myEcuParameterDefinition" type="AR-ELEMENT"
