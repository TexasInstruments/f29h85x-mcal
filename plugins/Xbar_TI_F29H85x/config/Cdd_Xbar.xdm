<?xml version='1.0'?>
<datamodel version="8.0"
           xmlns="http://www.tresos.de/_projects/DataModel2/18/root.xsd"
           xmlns:a="http://www.tresos.de/_projects/DataModel2/18/attribute.xsd"
           xmlns:v="http://www.tresos.de/_projects/DataModel2/06/schema.xsd"
           xmlns:d="http://www.tresos.de/_projects/DataModel2/06/data.xsd">

  <d:ctr type="AUTOSAR" factory="autosar"
         xmlns:ad="http://www.tresos.de/_projects/DataModel2/08/admindata.xsd"
         xmlns:ce="http://www.tresos.de/_projects/DataModel2/18/childenable.xsd"
         xmlns:cd="http://www.tresos.de/_projects/DataModel2/08/customdata.xsd"
         xmlns:f="http://www.tresos.de/_projects/DataModel2/14/formulaexpr.xsd"
         xmlns:icc="http://www.tresos.de/_projects/DataModel2/08/implconfigclass.xsd"
         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"
         xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="TI_F29H85x" type="AR-PACKAGE">
      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
        <d:lst type="TOP-LEVEL-PACKAGES">
          <d:ctr name="Cdd_Xbar" type="AR-PACKAGE">
          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
            <d:lst type="ELEMENTS">
              <d:chc name="Cdd" type="AR-ELEMENT" value="MODULE-DEF">
                <v:ctr type="MODULE-DEF">
                  <a:a name="ADMIN-DATA" type="ADMIN-DATA">
                    <ad:ADMIN-DATA>
                      <ad:DOC-REVISIONS>
                        <ad:DOC-REVISION>
                          <ad:REVISION-LABEL>4.3.1</ad:REVISION-LABEL>
                          <ad:ISSUED-BY>AUTOSAR</ad:ISSUED-BY>
                        </ad:DOC-REVISION>
                      </ad:DOC-REVISIONS>
                    </ad:ADMIN-DATA>
                  </a:a>
                  <a:a name="DESC"
                       value="EN: Configuration of the CddXbar module."/>
                  <a:a name="LOWER-MULTIPLICITY" value="1"/>
                  <a:a name="POSTBUILDVARIANTSUPPORT" value="false"/>
                  <a:a name="RELEASE" value="asc:4.3.1"/>
                  <a:a name="UPPER-MULTIPLICITY" value="1"/>
                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                  <a:a name="API-SERVICE-PREFIX" value="Cdd_Xbar"/>
                  <v:var name="IMPLEMENTATION_CONFIG_VARIANT"
                         type="ENUMERATION">
                    <a:a name="IMPLEMENTATIONCONFIGCLASS"
                         type="IMPLEMENTATIONCONFIGCLASS">
                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                    </a:a>
                    <a:a name="LABEL" value="Config Variant"/>
                    <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                    <a:da name="DEFAULT" value="VariantPreCompile"/>
                    <a:da name="RANGE">
                      <a:v>VariantPreCompile</a:v>
                    </a:da>
                  </v:var>
                  <v:ctr name="CddXbarConfiguration" type="IDENTIFIABLE">
                      <a:a name="DESC"
                          value="EN: This container contains the configuration parameters and sub containers of the CDD XBar module."/>
                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                      <v:ctr name="CddXbarInputXbarConfig" type="IDENTIFIABLE">
                          <a:a name="DESC" value="EN: Configuration for Input Crossbar"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <!-- Design: MCAL-25701 -->
                          <v:lst name="CddXbarInputXbarInstanceConfig" type="MAP">
                              <a:da name="MIN" value="0"/>
                              <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Input_Xbar_SelectCount')&quot;,num:i(64))"/>
                              <v:ctr name="CddXbarInputXbarInstanceConfig" type="IDENTIFIABLE">
                                  <a:a name="DESC" value="EN: Configuration for Input Crossbar instance, one per output line available"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <v:var name="CddXbarInputXbarInputSourceSelection" type="ENUMERATION">
                                      <a:a name="DESC"
                                          value="EN:Selects GPIO/AIO or LOGIC HIGH or LOGIC LOW as input to the input xbar."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="EDITABLE" value="true"/>
                                      <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Input_Xbar_Input_Sources')[1]&quot;,'CDD_XBAR_GPIO_AIO')"/>
                                      <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Input_Xbar_Input_Sources')&quot;,'CDD_XBAR_GPIO_AIO')"/>
                                  </v:var>
                                  <!-- Design: MCAL-25721 -->
                                  <v:ref name="CddXbarInputXbarInputSource" type="REFERENCE">
                                      <a:a name="DESC"
                                          value="EN: Reference to GPIO/AIO Pin, obtained from the configuration of PORT plugin."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="ENABLE" type="XPath" expr="(../CddXbarInputXbarInputSourceSelection='CDD_XBAR_GPIO_AIO')"/>
                                      <a:da name="REF"
                                          value="ASPathDataOfSchema:/TI_F29H85x/Port/PortConfigSet/PortContainer/PortPin"/>
                                      <a:da name="REF-TYPE" value="ASPath"/>
                                  </v:ref>
                                  <!-- Design: MCAL-25720 -->
                                  <v:var name="CddXbarInputXbarInput" type="ENUMERATION">
                                      <a:a name="DESC"
                                           value="EN:Input number of input crossbar."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                           type="IMPLEMENTATIONCONFIGCLASS">
                                           <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="EDITABLE" value="true"/>
                                      <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Input_Xbar_Inputs')[1]&quot;,'CDD_XBAR_INPUT1')"/>
                                      <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Input_Xbar_Inputs')&quot;,'CDD_XBAR_INPUT1')"/>
                                      <a:da name="INVALID" type="XPath"
                                          expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Please make sure to select an Input Select value only once for Input Crossbar.">
                                      </a:da>
                                  </v:var>
                                  <!-- Design: MCAL-25707 -->
                                  <v:var name="CddXbarInputXbarInputSelectConfigurationLock" type="BOOLEAN">
                                      <a:a name="DESC"
                                          value="EN: Option to lock the current Input Group for any further configuration on Input Crossbar until System Reset. Once locked, cannot be unlocked without reset."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:a name="DEFAULT" value="false"/>
                                      <a:a name="ENABLE" value="true"/>
                                      <a:a name="TOOLTIP" value="Locks further configuration for Input Crossbar, once locked will remain the same unless reset."/>
                                  </v:var>
                              </v:ctr>
                          </v:lst>
                      </v:ctr>
                      <!-- Design: MCAL-25702 -->
                      <v:ctr name="CddXbarOutputXbarConfig" type="IDENTIFIABLE">
                          <a:a name="DESC" value="EN: Configuration for Output Crossbar"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <v:lst name="CddXbarOutputXbarInstanceConfig" type="MAP">
                              <a:da name="MIN" value="0"/>
                              <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Output_Xbar_OutputLineCount')&quot;,num:i(16))"/>
                              <v:ctr name="CddXbarOutputXbarInstanceConfig" type="IDENTIFIABLE">
                                  <a:a name="DESC" value="EN: Configuration for Output Crossbar Instance, one per output line available"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <v:lst name="CddXbarOutputXbarInput" type="MAP">
                                      <a:da name="MIN" value="1"/>
                                      <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->count(ecu:list('Output_Xbar_InputGroups'))&quot;,num:i(10))"/>
                                      <v:ctr name="CddXbarOutputXbarInput" type="IDENTIFIABLE">
                                          <a:a name="DESC" value="EN: Configuration for Output Crossbar Instance inputs"/>
                                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                          <!-- Design: MCAL-25723 -->
                                          <v:var name="CddXbarOutputXbarInputGroup" type="ENUMERATION">
                                              <a:a name="DESC"
                                                  value="EN: Number of Input Group to be chosen for Output Crossbar."/>
                                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                  type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                              </a:a>
                                              <a:a name="ORIGIN" value="Texas Instruments"/>
                                              <a:a name="SCOPE" value="LOCAL"/>
                                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                              <a:a name="OPTIONAL" value="false"/>
                                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                              <a:da name="EDITABLE" value="true"/>
                                              <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_InputGroups')[1]&quot;,'CDD_XBAR_INPUT_GROUP_0')"/>
                                              <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_InputGroups')&quot;,'CDD_XBAR_INPUT_GROUP_0')"/>
                                              <a:da name="INVALID" type="XPath"
                                                  expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Please make sure to select an Input Group value only once for Input configuration of Output Crossbar.">
                                              </a:da>
                                          </v:var>
                                          <!-- Design: MCAL-25724 -->
                                          <v:lst name="CddXbarOutputXbarInputLine">
                                              <a:da name="MIN" value="1"/>
                                              <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Xbar_InputGroup_InputLines')&quot;,num:i(32))"/>
                                              <v:var name="CddXbarOutputXbarInputLine" type="ENUMERATION">
                                                  <a:a name="DESC"
                                                      value="EN: Number of Input Line from the Group selected to be chosen for Output Crossbar."/>
                                                  <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                      type="IMPLEMENTATIONCONFIGCLASS">
                                                      <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                                  </a:a>
                                                  <a:a name="ORIGIN" value="Texas Instruments"/>
                                                  <a:a name="SCOPE" value="LOCAL"/>
                                                  <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                                  <a:a name="OPTIONAL" value="false"/>
                                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                                  <a:da name="ENABLE" value="true"/>
                                                  <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list(concat('Output_Xbar_Input_Lines', '.', ../../CddXbarOutputXbarInputGroup))[1]&quot;,'CDD_XBAR_OUT_CMPSS1_CTRIPOUTH')"/>
                                                  <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list(concat('Output_Xbar_Input_Lines', '.', ../../CddXbarOutputXbarInputGroup))&quot;,'CDD_XBAR_OUT_CMPSS1_CTRIPOUTH')"/>
                                                  <a:da name="INVALID" type="XPath"
                                                      expr="text:uniq(../*[@name=node:name(.)], node:value(.))" false="Please make sure to select an Input Group value only once for Input configuration of Output Crossbar.">
                                                  </a:da>
                                              </v:var>
                                          </v:lst>
                                      </v:ctr>
                                  </v:lst>
                                  <!-- Design: MCAL-25722 -->
                                  <v:var name="CddXbarOutputXbarOutputLine" type="ENUMERATION">
                                      <a:a name="DESC"
                                          value="EN: Number of Output Line instance to be set for Output Crossbar."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="EDITABLE" value="true"/>
                                      <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_Output_Lines')[1]&quot;,'CDD_XBAR_OUTPUT1')"/>
                                      <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_Output_Lines')&quot;,'CDD_XBAR_OUTPUT1')"/>
                                      <a:da name="INVALID" type="XPath"
                                          expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Please make sure to select an output line value only once for Output Crossbar.">
                                      </a:da>
                                  </v:var>
                                  <!-- Design: MCAL-25719 -->
                                  <v:var name="CddXbarOutputXbarOutputPulseStretch" type="ENUMERATION">
                                      <a:a name="DESC"
                                          value="EN: Output Line pulse stretch in Sys Clock ticks for Output Crossbar."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                         <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="EDITABLE" value="true"/>
                                      <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_Stretch')[1]&quot;,'CDD_XBAR_SYSTICKS_STRETCH_OFF')"/>
                                      <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Output_Xbar_Stretch')&quot;,'CDD_XBAR_SYSTICKS_STRETCH_OFF')"/>
                                  </v:var>
                                  <!-- Design: MCAL-25713 -->
                                  <v:var name="CddXbarOutputXbarOutputInversion" type="BOOLEAN">
                                      <a:a name="DESC"
                                         value="EN: Option to invert the output signal for the selected output line of the Output Crossbar instance."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:a name="DEFAULT" value="false"/>
                                      <a:a name="ENABLE" value="true"/>
                                  </v:var>
                                  <!-- Design: MCAL-25718 -->
                                  <v:var name="CddXbarOutputXbarOutputLatch" type="BOOLEAN">
                                      <a:a name="DESC"
                                          value="EN: Option to select latch as output of selected output line for Output Crossbar instance."/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                          type="IMPLEMENTATIONCONFIGCLASS">
                                          <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                      </a:a>
                                      <a:a name="ORIGIN" value="Texas Instruments"/>
                                      <a:a name="SCOPE" value="LOCAL"/>
                                      <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                      <a:a name="OPTIONAL" value="false"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:a name="DEFAULT" value="false"/>
                                      <a:a name="ENABLE" value="true"/>
                                  </v:var>
                                  <v:ctr name="CddXbarOutputXbarOutputFlagConfig" type="IDENTIFIABLE">
                                      <a:a name="DESC" value="EN: Configuration for output crossbar output latch"/>
                                      <a:a name="IMPLEMENTATIONCONFIGCLASS" type="IMPLEMENTATIONCONFIGCLASS">
                                      </a:a>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <a:da name="EDITABLE" type="XPath" expr="(../CddXbarOutputXbarOutputLatch='true')" />
                                      <!-- Design: MCAL-25814 -->
                                      <v:var name="CddXbarOutputXbarInversionBeforeLatch" type="BOOLEAN">
                                          <a:a name="DESC"
                                              value="EN: Option to invert the signal before latching for the selected output line for Output Crossbar instance."/>
                                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                              type="IMPLEMENTATIONCONFIGCLASS">
                                             <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                          </a:a>
                                          <a:a name="ORIGIN" value="Texas Instruments"/>
                                          <a:a name="SCOPE" value="LOCAL"/>
                                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                          <a:a name="OPTIONAL" value="false"/>
                                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                          <a:a name="DEFAULT" value="false"/>
                                          <a:a name="ENABLE" value="true"/>
                                      </v:var>
                                      <!-- Design: MCAL-25813 -->
                                      <v:var name="CddXbarOutputXbarOutputLatchInitSts" type="ENUMERATION">
                                          <a:a name="DESC"
                                              value="Force or clear the output latch of individual output line for Output Crossbar during initialization"/>
                                         <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                              type="IMPLEMENTATIONCONFIGCLASS">
                                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                          </a:a>
                                          <a:a name="ORIGIN" value="Texas Instruments"/>
                                          <a:a name="SCOPE" value="LOCAL"/>
                                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                          <a:a name="OPTIONAL" value="false"/>
                                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Xbar_OutFlagInit')[1]&quot;,'CDD_XBAR_OUTPUTDEFAULT')"/>
                                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Cdd_Xbar_OutFlagInit')&quot;,'CDD_XBAR_OUTPUTDEFAULT')"/>
                                      </v:var>
                                  </v:ctr>
                              </v:ctr>
                          </v:lst>
                          <!-- Design: MCAL-25708 -->
                          <v:var name="CddXbarOutputXbarConfigurationLock" type="BOOLEAN">
                              <a:a name="DESC"
                                  value="EN: Option to lock the Output crossbar instance for any further input and output inversion configuration until System Reset. Cannot be unlocked once locked unless reset."/>
                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                  type="IMPLEMENTATIONCONFIGCLASS">
                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                              </a:a>
                              <a:a name="ORIGIN" value="Texas Instruments"/>
                              <a:a name="SCOPE" value="LOCAL"/>
                              <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                              <a:a name="OPTIONAL" value="false"/>
                              <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                              <a:a name="DEFAULT" value="false"/>
                              <a:a name="ENABLE" value="true"/>
                              <a:a name="TOOLTIP" value="Locks further Input selection and Output Inversion configuration for Output Crossbar, once locked will remain the same unless system reset."/>
                          </v:var>
                      </v:ctr>
                      <!-- Design: MCAL-25703 -->
                      <v:ctr name="CddXbarEpwmXbarConfig" type="IDENTIFIABLE">
                          <a:a name="DESC" value="EN: Configuration for EPWM Crossbar"/>
                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                          <v:lst name="CddXbarEpwmXbarInstanceConfig" type="MAP">
                              <a:da name="MIN" value="0"/>
                              <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('EPWM_Xbar_OutputLineCount')&quot;,num:i(16))"/>
                              <v:ctr name="CddXbarEpwmXbarInstanceConfig" type="IDENTIFIABLE">
                                  <a:a name="DESC" value="EN: Configuration for EPWM Crossbar Instance, one per output line available"/>
                                  <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                  <v:lst name="CddXbarEpwmXbarInput" type="MAP">
                                      <a:da name="MIN" value="1"/>
                                  <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->count(ecu:list('Epwm_Xbar_InputGroups'))&quot;,num:i(10))"/>
                                  <v:ctr name="CddXbarEpwmXbarInput" type="IDENTIFIABLE">
                                      <a:a name="DESC" value="EN: Configuration for EPWM Crossbar Instance inputs"/>
                                      <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                      <!-- Design: MCAL-25725 -->
                                      <v:var name="CddXbarEpwmXbarInputGroup" type="ENUMERATION">
                                          <a:a name="DESC"
                                              value="EN: Number of Input Group to be chosen for EPWM Crossbar."/>
                                          <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                              type="IMPLEMENTATIONCONFIGCLASS">
                                              <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                          </a:a>
                                          <a:a name="ORIGIN" value="Texas Instruments"/>
                                          <a:a name="SCOPE" value="LOCAL"/>
                                          <a:a name="SYMBOLICNAMEVALUE" value="false"/>
                                          <a:a name="OPTIONAL" value="false"/>
                                          <a:a name="UUID" type="XPath" expr="as:uuid()"/>
                                          <a:da name="EDITABLE" value="true"/>
                                          <a:da name="ENABLE" value="true"/>
                                          <a:da name="DEFAULT" type="XPath" expr="node:fallback(&quot;->ecu:list('Epwm_Xbar_InputGroups')[1]&quot;,'CDD_XBAR_INPUT_GROUP_0')"/>
                                          <a:da name="RANGE" type="XPath" expr="node:fallback(&quot;->ecu:list('Epwm_Xbar_InputGroups')&quot;,'CDD_XBAR_INPUT_GROUP_0')"/>
                                          <a:da name="INVALID" type="XPath"
                                              expr="text:uniq(../..//*[@name=node:name(.)], node:value(.))" false="Please make sure to select an Input Group value only once for Input configuration of EPWM Crossbar.">
                                          </a:da>
                                      </v:var>
                                      <!-- Design: MCAL-25726 -->
                                      <v:lst name="CddXbarEpwmXbarInputLine" type="">
                                          <a:da name="MIN" value="1"/>
                                          <a:da name="MAX" type="XPath" expr="node:fallback(&quot;->ecu:get('Xbar_InputGroup_InputLines')&quot;,num:i(32))"/>
                                          <v:var name="CddXbarEpwmXbarInputLine" type="ENUMERATION">
                                              <a:a name="DESC"
                                                  value="EN: Number of Input Line from the Group selected to be chosen for EPWM Crossbar."/>
                                              <a:a name="IMPLEMENTATIONCONFIGCLASS"
                                                  type="IMPLEMENTATIONCONFIGCLASS">
                                                  <icc:v vclass="PreCompile">VariantPreCompile</icc:v>
                                              </a:a>
                                              <a:a name="ORIGIN" value="Texas Instruments"/>
