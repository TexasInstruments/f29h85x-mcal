                    <ECUC-PARAM-CONF-CONTAINER-DEF UUID="de9dead4-49e4-4302-8a3c-d1a01a767bc6">
                      <SHORT-NAME>CddXbarClbXbarConfig</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Configuration for CLB Crossbar</L-2>
                      </DESC>
                      <PARAMETERS>
                        <ECUC-BOOLEAN-PARAM-DEF UUID="8d652603-dde6-42b7-8422-3e4a2bdcd2d9">
                          <SHORT-NAME>CddXbarClbXbarConfigurationLock</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Option to lock the CLB crossbar instance for any further configuration until System Reset. Cannot be unlocked once locked unless reset.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                          <DEFAULT-VALUE>false</DEFAULT-VALUE>
                        </ECUC-BOOLEAN-PARAM-DEF>
                      </PARAMETERS>
                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF UUID="eb4d6103-07ed-45da-9ab9-ca7f8bb3ef6b">
