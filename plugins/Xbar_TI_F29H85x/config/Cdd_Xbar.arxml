                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>CDD_XBAR_GPIO_AIO</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="e2d4d6b8-6254-4fde-acd2-262d2072c8a5">
                                  <SHORT-NAME>undefined</SHORT-NAME>
                                  <ORIGIN>unknown</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="f3ac081b-4517-4399-a29b-cc3c6680295f">
                              <SHORT-NAME>CddXbarInputXbarInput</SHORT-NAME>
                              <DESC>
