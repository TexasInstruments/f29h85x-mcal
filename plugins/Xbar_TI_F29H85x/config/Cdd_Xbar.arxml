                      <PARAMETERS>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="0a0b3d77-d82e-45db-99e3-ca35d208baeb">
                          <SHORT-NAME>CddXbarInputXbarInputSourceSelection</SHORT-NAME>
                          <DESC>
