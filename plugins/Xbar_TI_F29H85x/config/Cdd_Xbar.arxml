                        <ECUC-BOOLEAN-PARAM-DEF UUID="08bf5692-abb3-411c-9c9e-d99dc4317093">
                          <SHORT-NAME>CddXbarEpwmXbarConfigurationLock</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Option to lock the EPWM crossbar instance for any further configuration until System Reset. Cannot be unlocked once locked unless reset.</L-2>
                          </DESC>
