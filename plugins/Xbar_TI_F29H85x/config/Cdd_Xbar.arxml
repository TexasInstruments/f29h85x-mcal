                              <SHORT-NAME>CddXbarOutputXbarInputLine</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Number of Input Line from the Group selected to be chosen for Output Crossbar.</L-2>
                              </DESC>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
