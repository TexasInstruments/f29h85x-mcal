  <AR-PACKAGES>
    <AR-PACKAGE UUID="4a362edc-f890-4f90-bfe6-30fbb5810804">
      <SHORT-NAME>TI_F29H85x</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE UUID="221e4e06-a232-4788-ba11-69a86f3a5cda">
          <SHORT-NAME>Cdd_Xbar</SHORT-NAME>
          <ELEMENTS>
            <ECUC-DEFINITION-COLLECTION UUID="a1f9ce3b-41bb-4fe7-9e09-8479d10e44be">
              <SHORT-NAME>myEcuParameterDefinition</SHORT-NAME>
              <MODULE-REFS>
                <MODULE-REF DEST="ECUC-MODULE-DEF">/TI_F29H85x/Cdd_Xbar/Cdd</MODULE-REF>
              </MODULE-REFS>
            </ECUC-DEFINITION-COLLECTION>
            <ECUC-MODULE-DEF UUID="7198149c-ffa3-45a2-9dbc-3297b4aceacd">
              <SHORT-NAME>Cdd</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Configuration of the CddXbar module.</L-2>
              </DESC>
              <ADMIN-DATA>
                <DOC-REVISIONS>
                  <DOC-REVISION>
                    <REVISION-LABEL>4.3.1</REVISION-LABEL>
                    <ISSUED-BY>AUTOSAR</ISSUED-BY>
                  </DOC-REVISION>
                </DOC-REVISIONS>
              </ADMIN-DATA>
              <API-SERVICE-PREFIX>Cdd_Xbar</API-SERVICE-PREFIX>
              <POST-BUILD-VARIANT-SUPPORT>false</POST-BUILD-VARIANT-SUPPORT>
              <REFINED-MODULE-DEF-REF DEST="ECUC-MODULE-DEF">/AUTOSAR/EcucDefs/Cdd</REFINED-MODULE-DEF-REF>
              <SUPPORTED-CONFIG-VARIANTS>
                <SUPPORTED-CONFIG-VARIANT>VARIANT-PRE-COMPILE</SUPPORTED-CONFIG-VARIANT>
              </SUPPORTED-CONFIG-VARIANTS>
              <CONTAINERS>
                <ECUC-PARAM-CONF-CONTAINER-DEF UUID="405e20a7-b8e8-4e7c-be36-33f55ebc09a1">
                  <SHORT-NAME>CddXbarConfiguration</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">This container contains the configuration parameters and sub containers of the CDD XBar module.</L-2>
                  </DESC>
                  <SUB-CONTAINERS>
                    <ECUC-PARAM-CONF-CONTAINER-DEF UUID="e70682a2-a4ee-49fe-879b-533e97c45321">
                      <SHORT-NAME>CddXbarInputXbarConfig</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Configuration for Input Crossbar</L-2>
                      </DESC>
                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF UUID="2670de11-9b1c-4437-86e9-edffdbb6c78a">
                          <SHORT-NAME>CddXbarInputXbarInstanceConfig</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration for Input Crossbar instance, one per output line available</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>64</UPPER-MULTIPLICITY>
                          <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                          <PARAMETERS>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="277c0acf-21a5-4efd-960d-d02c19f53213">
                              <SHORT-NAME>CddXbarInputXbarInputSourceSelection</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Selects GPIO/AIO or LOGIC HIGH or LOGIC LOW as input to the input xbar.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>CDD_XBAR_GPIO_AIO</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="6450536e-e28d-4c00-906f-9d1ceba033d1">
                                  <SHORT-NAME>undefined</SHORT-NAME>
                                  <ORIGIN>unknown</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="440dc719-1eb1-4d55-af99-3cb16b9e63c8">
                              <SHORT-NAME>CddXbarInputXbarInput</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Input number of input crossbar.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>CDD_XBAR_INPUT1</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="5bc9bc6c-8983-44ee-b2e1-d721f89143c5">
                                  <SHORT-NAME>undefined</SHORT-NAME>
                                  <ORIGIN>unknown</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="2e61dd91-153d-4563-8a4f-679b901aca7b">
                              <SHORT-NAME>CddXbarInputXbarInputSelectConfigurationLock</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Option to lock the current Input Group for any further configuration on Input Crossbar until System Reset. Once locked, cannot be unlocked without reset.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>false</DEFAULT-VALUE>
                            </ECUC-BOOLEAN-PARAM-DEF>
                          </PARAMETERS>
                          <REFERENCES>
                            <ECUC-REFERENCE-DEF UUID="af79ce18-bd5a-4fe2-8c44-f488ec2eb4b1">
                              <SHORT-NAME>CddXbarInputXbarInputSource</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Reference to GPIO/AIO Pin, obtained from the configuration of PORT plugin.</L-2>
                              </DESC>
                              <!-- @Calculated /TI_F29H85x/Cdd_Xbar/Cdd/CddXbarConfiguration/CddXbarInputXbarConfig/CddXbarInputXbarInstanceConfig/CddXbarInputXbarInputSource: ENABLE(XPath: (../CddXbarInputXbarInputSourceSelection=&apos;CDD_XBAR_GPIO_AIO&apos;))-->
                              <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                              <!-- @CalculatedEnd -->
                              <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/TI_F29H85x/Port/PortConfigSet/PortContainer/PortPin</DESTINATION-REF>
                            </ECUC-REFERENCE-DEF>
                          </REFERENCES>
                        </ECUC-PARAM-CONF-CONTAINER-DEF>
                      </SUB-CONTAINERS>
                    </ECUC-PARAM-CONF-CONTAINER-DEF>
                    <ECUC-PARAM-CONF-CONTAINER-DEF UUID="8dbf4a28-3fac-4d93-87d3-d6fa23ed4974">
                      <SHORT-NAME>CddXbarOutputXbarConfig</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Configuration for Output Crossbar</L-2>
                      </DESC>
                      <PARAMETERS>
                        <ECUC-BOOLEAN-PARAM-DEF UUID="cdf0ad04-41f2-48bc-a9d9-3fbc2b4dadf8">
                          <SHORT-NAME>CddXbarOutputXbarConfigurationLock</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Option to lock the Output crossbar instance for any further input and output inversion configuration until System Reset. Cannot be unlocked once locked unless reset.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                          <DEFAULT-VALUE>false</DEFAULT-VALUE>
                        </ECUC-BOOLEAN-PARAM-DEF>
                      </PARAMETERS>
                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF UUID="6b5f9b75-98a5-455f-b9f6-c800325b7497">
                          <SHORT-NAME>CddXbarOutputXbarInstanceConfig</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration for Output Crossbar Instance, one per output line available</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>16</UPPER-MULTIPLICITY>
                          <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                          <PARAMETERS>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="29d2ab16-474a-4d86-8a6b-d5c3f9df3990">
                              <SHORT-NAME>CddXbarOutputXbarOutputLine</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Number of Output Line instance to be set for Output Crossbar.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>CDD_XBAR_OUTPUT1</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="2622b1de-b63c-4c3d-8955-21d3481050a7">
                                  <SHORT-NAME>undefined</SHORT-NAME>
                                  <ORIGIN>unknown</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="5750e6b4-a865-4c59-b5ff-65ec65e4fc8c">
                              <SHORT-NAME>CddXbarOutputXbarOutputPulseStretch</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Output Line pulse stretch in Sys Clock ticks for Output Crossbar.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>CDD_XBAR_SYSTICKS_STRETCH_OFF</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="4b05af9a-7d3e-497d-9297-d66ec68b9196">
                                  <SHORT-NAME>undefined</SHORT-NAME>
                                  <ORIGIN>unknown</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="f3ace6e4-9615-4ed6-8fd3-580bf58d44c3">
                              <SHORT-NAME>CddXbarOutputXbarOutputInversion</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Option to invert the output signal for the selected output line of the Output Crossbar instance.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>false</DEFAULT-VALUE>
                            </ECUC-BOOLEAN-PARAM-DEF>
                            <ECUC-BOOLEAN-PARAM-DEF UUID="585ff99f-e3e8-486a-95c6-6fb2e2214e6f">
                              <SHORT-NAME>CddXbarOutputXbarOutputLatch</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Option to select latch as output of selected output line for Output Crossbar instance.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                              <DEFAULT-VALUE>false</DEFAULT-VALUE>
                            </ECUC-BOOLEAN-PARAM-DEF>
                          </PARAMETERS>
                          <SUB-CONTAINERS>
                            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="def383fa-7fb2-4e2f-9b84-0ed096fef984">
                              <SHORT-NAME>CddXbarOutputXbarInput</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Configuration for Output Crossbar Instance inputs</L-2>
                              </DESC>
                              <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                              <UPPER-MULTIPLICITY>10</UPPER-MULTIPLICITY>
                              <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                              <PARAMETERS>
                                <ECUC-ENUMERATION-PARAM-DEF UUID="39ca3509-0471-448c-8463-63409b3885ce">
                                  <SHORT-NAME>CddXbarOutputXbarInputGroup</SHORT-NAME>
                                  <DESC>
                                    <L-2 L="EN">Number of Input Group to be chosen for Output Crossbar.</L-2>
                                  </DESC>
                                  <SCOPE>LOCAL</SCOPE>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                                  <VALUE-CONFIG-CLASSES>
                                    <ECUC-VALUE-CONFIGURATION-CLASS>
                                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                    </ECUC-VALUE-CONFIGURATION-CLASS>
                                  </VALUE-CONFIG-CLASSES>
                                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                                  <DEFAULT-VALUE>CDD_XBAR_INPUT_GROUP_0</DEFAULT-VALUE>
                                  <LITERALS>
                                    <ECUC-ENUMERATION-LITERAL-DEF UUID="23d30a8f-2d4b-453e-960a-7063a511be61">
                                      <SHORT-NAME>undefined</SHORT-NAME>
                                      <ORIGIN>unknown</ORIGIN>
                                    </ECUC-ENUMERATION-LITERAL-DEF>
                                  </LITERALS>
                                </ECUC-ENUMERATION-PARAM-DEF>
                                <ECUC-ENUMERATION-PARAM-DEF UUID="9d5d0ca0-544e-4d99-91c8-3bd949ccc21d">
                                  <SHORT-NAME>CddXbarOutputXbarInputLine</SHORT-NAME>
                                  <DESC>
                                    <L-2 L="EN">Number of Input Line from the Group selected to be chosen for Output Crossbar.</L-2>
                                  </DESC>
                                  <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                                  <UPPER-MULTIPLICITY>32</UPPER-MULTIPLICITY>
                                  <SCOPE>LOCAL</SCOPE>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                  <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                                  <VALUE-CONFIG-CLASSES>
                                    <ECUC-VALUE-CONFIGURATION-CLASS>
                                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                    </ECUC-VALUE-CONFIGURATION-CLASS>
                                  </VALUE-CONFIG-CLASSES>
                                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                                  <DEFAULT-VALUE>CDD_XBAR_OUT_CMPSS1_CTRIPOUTH</DEFAULT-VALUE>
                                  <LITERALS>
                                    <ECUC-ENUMERATION-LITERAL-DEF UUID="fbfe364e-633a-45fa-bb67-bc68553aeda7">
                                      <SHORT-NAME>undefined</SHORT-NAME>
                                      <ORIGIN>unknown</ORIGIN>
                                    </ECUC-ENUMERATION-LITERAL-DEF>
                                  </LITERALS>
                                </ECUC-ENUMERATION-PARAM-DEF>
                              </PARAMETERS>
                            </ECUC-PARAM-CONF-CONTAINER-DEF>
                            <ECUC-PARAM-CONF-CONTAINER-DEF UUID="24ef0986-adf4-484d-ad5e-234b79b3cac4">
                              <SHORT-NAME>CddXbarOutputXbarOutputFlagConfig</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Configuration for output crossbar output latch</L-2>
                              </DESC>
                              <PARAMETERS>
                                <ECUC-BOOLEAN-PARAM-DEF UUID="1b303ada-7bcd-4d15-b142-77e01169a0fe">
                                  <SHORT-NAME>CddXbarOutputXbarInversionBeforeLatch</SHORT-NAME>
                                  <DESC>
                                    <L-2 L="EN">Option to invert the signal before latching for the selected output line for Output Crossbar instance.</L-2>
                                  </DESC>
                                  <SCOPE>LOCAL</SCOPE>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                                  <VALUE-CONFIG-CLASSES>
                                    <ECUC-VALUE-CONFIGURATION-CLASS>
                                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                    </ECUC-VALUE-CONFIGURATION-CLASS>
                                  </VALUE-CONFIG-CLASSES>
                                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                                  <DEFAULT-VALUE>false</DEFAULT-VALUE>
                                </ECUC-BOOLEAN-PARAM-DEF>
                                <ECUC-ENUMERATION-PARAM-DEF UUID="07f19b01-5e1a-4f51-a05b-ca8f56d800ed">
                                  <SHORT-NAME>CddXbarOutputXbarOutputLatchInitSts</SHORT-NAME>
                                  <DESC>
                                    <L-2 L="FOR-ALL">Force or clear the output latch of individual output line for Output Crossbar during initialization</L-2>
                                  </DESC>
                                  <SCOPE>LOCAL</SCOPE>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                  <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                                  <VALUE-CONFIG-CLASSES>
                                    <ECUC-VALUE-CONFIGURATION-CLASS>
                                      <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                      <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                    </ECUC-VALUE-CONFIGURATION-CLASS>
                                  </VALUE-CONFIG-CLASSES>
                                  <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                                  <DEFAULT-VALUE>CDD_XBAR_OUTPUTDEFAULT</DEFAULT-VALUE>
                                  <LITERALS>
                                    <ECUC-ENUMERATION-LITERAL-DEF UUID="bd49a864-374e-445c-aa8b-6d6613333a4a">
                                      <SHORT-NAME>undefined</SHORT-NAME>
                                      <ORIGIN>unknown</ORIGIN>
                                    </ECUC-ENUMERATION-LITERAL-DEF>
                                  </LITERALS>
                                </ECUC-ENUMERATION-PARAM-DEF>
                              </PARAMETERS>
                            </ECUC-PARAM-CONF-CONTAINER-DEF>
                          </SUB-CONTAINERS>
                        </ECUC-PARAM-CONF-CONTAINER-DEF>
                      </SUB-CONTAINERS>
                    </ECUC-PARAM-CONF-CONTAINER-DEF>
                    <ECUC-PARAM-CONF-CONTAINER-DEF UUID="2e0336ba-5f6b-433c-8bb4-243a4d081ac5">
                      <SHORT-NAME>CddXbarEpwmXbarConfig</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Configuration for EPWM Crossbar</L-2>
                      </DESC>
                      <PARAMETERS>
                        <ECUC-BOOLEAN-PARAM-DEF UUID="057482a7-044c-4f66-a9e7-0c1c5605b9e2">
                          <SHORT-NAME>CddXbarEpwmXbarConfigurationLock</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Option to lock the EPWM crossbar instance for any further configuration until System Reset. Cannot be unlocked once locked unless reset.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                          <DEFAULT-VALUE>false</DEFAULT-VALUE>
                        </ECUC-BOOLEAN-PARAM-DEF>
                      </PARAMETERS>
                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF UUID="b6ed8b13-4075-4a40-9583-9ef67652f020">
                          <SHORT-NAME>CddXbarEpwmXbarInstanceConfig</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration for EPWM Crossbar Instance, one per output line available</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>16</UPPER-MULTIPLICITY>
                          <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                          <PARAMETERS>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="0f298f76-45df-46d6-aecb-ee7148202acf">
