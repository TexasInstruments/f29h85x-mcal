                                <ECUC-BOOLEAN-PARAM-DEF UUID="4fe0ed10-91c7-4c7f-8c0d-623ab59c643b">
                                  <SHORT-NAME>CddXbarOutputXbarInversionBeforeLatch</SHORT-NAME>
                                  <DESC>
