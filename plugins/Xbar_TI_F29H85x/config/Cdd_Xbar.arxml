                          <LITERALS>
                            <!-- @Calculated /TI_F29H85x/Cdd_Xbar/CddXbarConfiguration/CddXbarOutputXbarConfig/CddXbarOutputXbarInstanceConfig/CddXbarOutputXbarOutputPulseStretch: RANGE(XPath: ecu:list(&apos;Output_Xbar_Stretch&apos;))-->
                            <ECUC-ENUMERATION-LITERAL-DEF UUID="710dfcb6-45d6-4b57-94c8-5f9d824bc53b">
