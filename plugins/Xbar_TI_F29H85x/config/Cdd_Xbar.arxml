                          <PARAMETERS>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="63d5954c-3dc8-4b20-8096-6aa7ae47897a">
                              <SHORT-NAME>CddXbarOutputXbarInputGroup</SHORT-NAME>
                              <DESC>
