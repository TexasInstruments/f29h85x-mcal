                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <SYMBOLIC-NAME-VALUE>false</SYMBOLIC-NAME-VALUE>
                          <!-- @Calculated /TI_F29H85x/Cdd_Xbar/CddXbarConfiguration/CddXbarInputXbarConfig/CddXbarInputXbarInstanceConfig/CddXbarInputXbarInputSourceSelection: DEFAULT(XPath: ecu:list(&apos;Input_Xbar_Input_Sources&apos;)[1])-->
                          <LITERALS>
                            <!-- @Calculated /TI_F29H85x/Cdd_Xbar/CddXbarConfiguration/CddXbarInputXbarConfig/CddXbarInputXbarInstanceConfig/CddXbarInputXbarInputSourceSelection: RANGE(XPath: ecu:list(&apos;Input_Xbar_Input_Sources&apos;))-->
                            <ECUC-ENUMERATION-LITERAL-DEF UUID="59524a01-e7ab-422f-90a7-46e751a7f996">
                              <SHORT-NAME>undefined</SHORT-NAME>
