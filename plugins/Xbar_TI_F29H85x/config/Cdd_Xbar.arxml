            <ECUC-MODULE-DEF UUID="ed7b930b-7049-450f-b9f7-5c1dd87f2202">
              <SHORT-NAME>Cdd</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Configuration of the CddXbar module.</L-2>
              </DESC>
