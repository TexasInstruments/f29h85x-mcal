                              <DEFAULT-VALUE>CDD_XBAR_GPIO_AIO</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF UUID="13a2d873-c806-44e7-bf6a-ea10a502f142">
                                  <SHORT-NAME>undefined</SHORT-NAME>
