  <AR-PACKAGES>
    <AR-PACKAGE UUID="643439cd-1cc3-4b20-a37e-884fb2e81904">
      <SHORT-NAME>TI_F29H85x</SHORT-NAME>
      <AR-PACKAGES>
        <AR-PACKAGE UUID="d69ba4a1-6d4c-4eb0-b10f-b4a2e08e57df">
          <SHORT-NAME>Cdd_Pwm</SHORT-NAME>
          <ELEMENTS>
            <ECUC-DEFINITION-COLLECTION UUID="199ca158-9ec7-4597-b8ac-c087b782869a">
              <SHORT-NAME>ecuParameterDefinition</SHORT-NAME>
              <MODULE-REFS>
                <MODULE-REF DEST="ECUC-MODULE-DEF">/TI_F29H85x/Cdd_Pwm/Cdd</MODULE-REF>
              </MODULE-REFS>
            </ECUC-DEFINITION-COLLECTION>
            <ECUC-MODULE-DEF UUID="4e67f621-cf74-4a7b-98b8-67573512b585">
              <SHORT-NAME>Cdd</SHORT-NAME>
              <DESC>
                <L-2 L="EN">Configuration of Pwm (Pulse Width Modulation) module.</L-2>
              </DESC>
              <ADMIN-DATA>
                <DOC-REVISIONS>
                  <DOC-REVISION>
                    <REVISION-LABEL>4.3.1</REVISION-LABEL>
                    <ISSUED-BY>AUTOSAR</ISSUED-BY>
                  </DOC-REVISION>
                </DOC-REVISIONS>
              </ADMIN-DATA>
              <API-SERVICE-PREFIX>Cdd_Pwm</API-SERVICE-PREFIX>
              <REFINED-MODULE-DEF-REF DEST="ECUC-MODULE-DEF">/AUTOSAR/EcucDefs/Cdd</REFINED-MODULE-DEF-REF>
              <SUPPORTED-CONFIG-VARIANTS>
                <SUPPORTED-CONFIG-VARIANT>VARIANT-PRE-COMPILE</SUPPORTED-CONFIG-VARIANT>
              </SUPPORTED-CONFIG-VARIANTS>
              <CONTAINERS>
                <ECUC-PARAM-CONF-CONTAINER-DEF UUID="9eda3b11-aaf7-49fb-95c2-437232722d1e">
                  <SHORT-NAME>CddPwmConfigSet</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">This container contains the configuration parameters and sub containers of the AUTOSAR Pwm instance.</L-2>
                  </DESC>
                  <SUB-CONTAINERS>
                    <ECUC-PARAM-CONF-CONTAINER-DEF UUID="57750fe3-0710-4ce9-8820-9abfe4fd8ebd">
                      <SHORT-NAME>CddPwmHwUnitConfig</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Configuration of an individual PWM instance.</L-2>
                      </DESC>
                      <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                      <UPPER-MULTIPLICITY>18</UPPER-MULTIPLICITY>
                      <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                      <PARAMETERS>
                        <ECUC-INTEGER-PARAM-DEF UUID="d625e3af-424c-433f-a1d8-4811ec10f51f">
                          <SHORT-NAME>CddPwmInstanceId</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Pwm hardware instance.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>1</DEFAULT-VALUE>
                          <MAX>1</MAX>
                          <MIN>1</MIN>
                        </ECUC-INTEGER-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="49ceae13-5c90-4368-ae2b-3a2b6d456245">
                          <SHORT-NAME>CddPwmOutputClass</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Class of PWM Channel.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>CDD_PWM_VARIABLE_PERIOD</DEFAULT-VALUE>
                          <LITERALS>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_FIXED_PERIOD</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_VARIABLE_PERIOD</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="d0d31530-7e07-4b7f-ac1f-c75c992978a1">
                          <SHORT-NAME>CddPwmClockDivider</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Time base clock pre-scale value.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>CDD_PWM_CLK_DIVIDER_1</DEFAULT-VALUE>
                          <LITERALS>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_CLK_DIVIDER_1</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="da695e3c-b012-4751-8d37-4f362f8fe4e2">
                          <SHORT-NAME>CddPwmHighSpeedClockDivider</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">High speed clock divider for the PWM instance.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>CDD_PWM_HSCLK_DIVIDER_1</DEFAULT-VALUE>
                          <LITERALS>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_HSCLK_DIVIDER_1</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-FLOAT-PARAM-DEF UUID="faf0b96f-7044-4674-9a1c-5756d2304b6c">
                          <SHORT-NAME>CddPwmFrequency</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">This parameter defines the frequency of the PWM instance.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>1.0E8</DEFAULT-VALUE>
                        </ECUC-FLOAT-PARAM-DEF>
                        <ECUC-INTEGER-PARAM-DEF UUID="a6025430-4109-4ff1-a740-43fa401e4288">
                          <SHORT-NAME>CddPwmPeriod</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Value of period used for Initialization. This value will be written into the TBPRD register</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>0</DEFAULT-VALUE>
                          <MAX>65535</MAX>
                          <MIN>0</MIN>
                        </ECUC-INTEGER-PARAM-DEF>
                        <ECUC-BOOLEAN-PARAM-DEF UUID="c87bf68c-1d57-4f3e-b510-fef70a48a662">
                          <SHORT-NAME>CddPwmInterruptEnable</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Enables/disables the interrupt for the PWM instance.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>false</DEFAULT-VALUE>
                        </ECUC-BOOLEAN-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="ddba3139-074b-4d8b-b7e5-9f1d96131a30">
                          <SHORT-NAME>CddPwmInterruptCategory</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">This parameters defines the category of the interrupt.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>ISR_CAT1_RTINT</DEFAULT-VALUE>
                          <LITERALS>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>ISR_CAT1_INT</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>ISR_CAT1_RTINT</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>ISR_CAT2_INT</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-ENUMERATION-PARAM-DEF UUID="dad115c6-b840-4ac5-9935-69490031cf59">
                          <SHORT-NAME>CddPwmSymmetry</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">This parameter defines the symmetry of the generated waveform.</L-2>
                          </DESC>
                          <SCOPE>LOCAL</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DEFAULT-VALUE>CDD_PWM_ASYMMETRIC_WAVEFORM</DEFAULT-VALUE>
                          <LITERALS>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_ASYMMETRIC_WAVEFORM</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                            <ECUC-ENUMERATION-LITERAL-DEF>
                              <SHORT-NAME>CDD_PWM_SYMMETRIC_WAVEFORM</SHORT-NAME>
                              <ORIGIN>Texas Instruments</ORIGIN>
                            </ECUC-ENUMERATION-LITERAL-DEF>
                          </LITERALS>
                        </ECUC-ENUMERATION-PARAM-DEF>
                        <ECUC-FUNCTION-NAME-DEF UUID="6582b20c-d204-4698-b4dd-36047b3029a8">
                          <SHORT-NAME>CddPwmNotification</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Definition of the Callback function.</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>0</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>1</UPPER-MULTIPLICITY>
                          <SCOPE>LOCAL</SCOPE>
                          <MULTIPLICITY-CONFIG-CLASSES>
                            <ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-MULTIPLICITY-CONFIGURATION-CLASS>
                          </MULTIPLICITY-CONFIG-CLASSES>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <ECUC-FUNCTION-NAME-DEF-VARIANTS>
                            <ECUC-FUNCTION-NAME-DEF-CONDITIONAL>
                              <DEFAULT-VALUE>NULL_PTR</DEFAULT-VALUE>
                            </ECUC-FUNCTION-NAME-DEF-CONDITIONAL>
                          </ECUC-FUNCTION-NAME-DEF-VARIANTS>
                        </ECUC-FUNCTION-NAME-DEF>
                      </PARAMETERS>
                      <REFERENCES>
                        <ECUC-REFERENCE-DEF UUID="872dbc74-0406-486f-b659-fa932b666527">
                          <SHORT-NAME>CddPwmMcuClockReferencePoint</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">This parameter contains reference to the McuClockReferencePoint</L-2>
                          </DESC>
                          <SCOPE>ECU</SCOPE>
                          <ORIGIN>Texas Instruments</ORIGIN>
                          <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                          <VALUE-CONFIG-CLASSES>
                            <ECUC-VALUE-CONFIGURATION-CLASS>
                              <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                              <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                            </ECUC-VALUE-CONFIGURATION-CLASS>
                          </VALUE-CONFIG-CLASSES>
                          <DESTINATION-REF DEST="ECUC-PARAM-CONF-CONTAINER-DEF">/TI_F29H85x/Mcu/McuModuleConfiguration/McuClockSettingConfig/McuClockReferencePoint</DESTINATION-REF>
                        </ECUC-REFERENCE-DEF>
                      </REFERENCES>
                      <SUB-CONTAINERS>
                        <ECUC-PARAM-CONF-CONTAINER-DEF UUID="2661ac6d-c476-485d-8b60-b01f856ddb5c">
                          <SHORT-NAME>CddPwmOutputChannel</SHORT-NAME>
                          <DESC>
                            <L-2 L="EN">Configuration of output channel A.</L-2>
                          </DESC>
                          <LOWER-MULTIPLICITY>1</LOWER-MULTIPLICITY>
                          <UPPER-MULTIPLICITY>2</UPPER-MULTIPLICITY>
                          <POST-BUILD-VARIANT-MULTIPLICITY>false</POST-BUILD-VARIANT-MULTIPLICITY>
                          <PARAMETERS>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="171fdf09-89eb-43ca-a786-1f1681eacefe">
                              <SHORT-NAME>CddPwmChannel</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Defines the output channel for the PWM instance.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>CDD_PWM_OUTPUT_A</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_OUTPUT_A</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_OUTPUT_B</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="05c90895-9001-4250-a128-66ba586c6829">
                              <SHORT-NAME>CddPwmPolarity</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Defines the starting polarity of the PWM channel.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>CDD_PWM_LOW</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_HIGH</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_LOW</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-ENUMERATION-PARAM-DEF UUID="9874b69f-ef40-46b3-ac97-7f3b11bef2b1">
                              <SHORT-NAME>CddPwmIdleState</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">The parameter PWM_IDLE_STATE represents the output state of the channel after the signal is stopped (e.g.call of Pwm_SetOutputToIdle).</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>CDD_PWM_LOW</DEFAULT-VALUE>
                              <LITERALS>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_HIGH</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                                <ECUC-ENUMERATION-LITERAL-DEF>
                                  <SHORT-NAME>CDD_PWM_LOW</SHORT-NAME>
                                  <ORIGIN>Texas Instruments</ORIGIN>
                                </ECUC-ENUMERATION-LITERAL-DEF>
                              </LITERALS>
                            </ECUC-ENUMERATION-PARAM-DEF>
                            <ECUC-INTEGER-PARAM-DEF UUID="41ea7a9d-f1d8-4be3-8937-5af97ab335dc">
                              <SHORT-NAME>CddPwmDutyCycle</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">Value of duty cycle used for Initialization</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>16384</DEFAULT-VALUE>
                              <MAX>32768</MAX>
                              <MIN>0</MIN>
                            </ECUC-INTEGER-PARAM-DEF>
                            <ECUC-FLOAT-PARAM-DEF UUID="6ce28cce-54d2-4f5b-a5e6-0bd71a5c9eda">
                              <SHORT-NAME>CddPwmDutyCycleInPercentage</SHORT-NAME>
                              <DESC>
                                <L-2 L="EN">This parameter defines the configured duty cycle in percentage.</L-2>
                              </DESC>
                              <SCOPE>LOCAL</SCOPE>
                              <ORIGIN>Texas Instruments</ORIGIN>
                              <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                              <VALUE-CONFIG-CLASSES>
                                <ECUC-VALUE-CONFIGURATION-CLASS>
                                  <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                                  <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                                </ECUC-VALUE-CONFIGURATION-CLASS>
                              </VALUE-CONFIG-CLASSES>
                              <DEFAULT-VALUE>50.0</DEFAULT-VALUE>
                            </ECUC-FLOAT-PARAM-DEF>
                          </PARAMETERS>
                        </ECUC-PARAM-CONF-CONTAINER-DEF>
                      </SUB-CONTAINERS>
                    </ECUC-PARAM-CONF-CONTAINER-DEF>
                  </SUB-CONTAINERS>
                </ECUC-PARAM-CONF-CONTAINER-DEF>
                <ECUC-PARAM-CONF-CONTAINER-DEF UUID="ec2edb13-259e-4dae-b92c-7a06750b2471">
                  <SHORT-NAME>CddPwmGeneral</SHORT-NAME>
                  <DESC>
                    <L-2 L="EN">General configuration (parameters) of the PWM Driver software module.</L-2>
                  </DESC>
                  <PARAMETERS>
                    <ECUC-BOOLEAN-PARAM-DEF UUID="b55d093e-5ed0-4694-913c-2328547e3d9c">
                      <SHORT-NAME>CddPwmDevErrorDetect</SHORT-NAME>
                      <DESC>
                        <L-2 L="EN">Switches the development error detection on or off.</L-2>
                      </DESC>
                      <SCOPE>LOCAL</SCOPE>
                      <ORIGIN>Texas Instruments</ORIGIN>
                      <POST-BUILD-VARIANT-VALUE>false</POST-BUILD-VARIANT-VALUE>
                      <VALUE-CONFIG-CLASSES>
                        <ECUC-VALUE-CONFIGURATION-CLASS>
                          <CONFIG-CLASS>PRE-COMPILE</CONFIG-CLASS>
                          <CONFIG-VARIANT>VARIANT-PRE-COMPILE</CONFIG-VARIANT>
                        </ECUC-VALUE-CONFIGURATION-CLASS>
