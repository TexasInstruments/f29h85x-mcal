         xmlns:mt="http://www.tresos.de/_projects/DataModel2/11/multitest.xsd"  
         xmlns:variant="http://www.tresos.de/_projects/DataModel2/11/variant.xsd">
    <d:lst type="TOP-LEVEL-PACKAGES">
      <d:ctr name="ResourceAllocator" type="AR-PACKAGE">
        <d:lst type="ELEMENTS">
          <d:chc name="ResourceAllocator" type="AR-ELEMENT" 
                 value="MODULE-CONFIGURATION">
            <d:ctr type="MODULE-CONFIGURATION">
              <a:a name="DEF" value="ASPath:/TI_F29H85x/ResourceAllocator"/>
              <d:var name="IMPLEMENTATION_CONFIG_VARIANT" type="ENUMERATION" 
                     value="VariantPreCompile">
                <a:a name="IMPORTER_INFO" value="@DEF"/>
              </d:var>
              <d:ctr name="ResourceAllocatorGeneral" type="IDENTIFIABLE">
                <d:var name="Mode" type="ENUMERATION" value="SETUP"/>
                <d:var name="Device" type="ENUMERATION" value="F29H859TU_Q1"/>
                <d:var name="Variant" type="ENUMERATION" value="F29H859TU8_Q"/>
                <d:var name="Package" type="ENUMERATION" 
