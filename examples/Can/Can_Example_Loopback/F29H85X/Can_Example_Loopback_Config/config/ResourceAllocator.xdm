                <d:ref name="CurrentContext" type="REFERENCE" 
                       value="ASPath:/ResourceAllocator/ResourceAllocator/ResourceAllocatorGeneral/Context_0"/>
                <d:var name="CPU1_Lockstep" type="BOOLEAN" value="true">
                  <a:a name="IMPORTER_INFO">
                    <a:v>@CALC</a:v>
                    <a:v>@DEF</a:v>
                  </a:a>
                </d:var>
                <d:lst name="Context" type="MAP">
                  <d:ctr name="Context_0" type="IDENTIFIABLE">
                    <d:var name="Core" type="ENUMERATION" value="CPU1">
                      <a:a name="IMPORTER_INFO">
                        <a:v>@DEF</a:v>
                        <a:v>@CALC</a:v>
                      </a:a>
                    </d:var>
                    <d:lst name="Can" type="MAP">
                      <d:ctr name="Can_0" type="IDENTIFIABLE">
                        <d:lst name="CanAllocatedInstance" type="MAP">
                          <d:ctr name="MCANA" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCANA">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCANA_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                          <d:ctr name="MCANB" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCANB"/>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCANB_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                          <d:ctr name="MCANC" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCANC"/>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCANC_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                          <d:ctr name="MCAND" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCAND"/>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCAND_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                          <d:ctr name="MCANE" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCANE"/>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCANE_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                          <d:ctr name="MCANF" type="IDENTIFIABLE">
                            <d:var name="InstanceName" type="ENUMERATION" 
                                   value="MCANF"/>
                            <d:var name="Frame" type="ENUMERATION" 
                                   value="FRAME0">
                              <a:a name="IMPORTER_INFO" value="@DEF"/>
                            </d:var>
                            <d:var name="BaseAddr" type="STRING" 
                                   value="MCANF_DRIVER_BASE_FRAME(0)">
                              <a:a name="IMPORTER_INFO">
                                <a:v>@DEF</a:v>
                                <a:v>@CALC</a:v>
                              </a:a>
                            </d:var>
                          </d:ctr>
                        </d:lst>
                      </d:ctr>
                    </d:lst>
                    <d:ctr name="Wdg" type="IDENTIFIABLE"/>
                    <d:lst name="Spi" type="MAP"/>
                    <d:lst name="Lin" type="MAP"/>
                    <d:ctr name="Cdd_Adc" type="IDENTIFIABLE"/>
                    <d:ctr name="Cdd_Ecap" type="IDENTIFIABLE"/>
                    <d:ctr name="Cdd_Ipc" type="IDENTIFIABLE"/>
                    <d:ctr name="Cdd_Pwm" type="IDENTIFIABLE"/>
                    <d:lst name="Cdd_Sent" type="MAP"/>
                    <d:lst name="Cdd_Uart" type="MAP"/>
