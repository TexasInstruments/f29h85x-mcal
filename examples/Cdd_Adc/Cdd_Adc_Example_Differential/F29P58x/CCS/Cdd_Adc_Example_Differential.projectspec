    <file action="copy" path="../../../../DeviceSupport/makefile.defs"                          targetDirectory=""/>
    <file action="copy" path="../../Cdd_Adc_Example_Differential.c"                         targetDirectory="" />
    <file action="link" path="../../../../../drivers/Cdd_Adc/"                               targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/Port/"                                  targetDirectory="mcal" />
	  <file action="link" path="../../../../../drivers/Mcu/"                                   targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/Gpt/"                                   targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/Det/src/Det.c"                    targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/Dem/src/Dem.c"                    targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/Os/src/Os.c"                      targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/EcuM/src/EcuM.c"                  targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/SchM/Cdd_Adc/src/SchM_Cdd_Adc.c"  targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/SchM/Gpt/src/SchM_Gpt.c"          targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/SchM/Port/src/SchM_Port.c"        targetDirectory="mcal" />
    <file action="link" path="../../../../../drivers/BSW_Stubs/SchM/Mcu/src/SchM_Mcu.c"        targetDirectory="mcal" />
	  <file action="link" path="../../../../../drivers/Mcal_Lib/src/Mcal_Lib.c"                    targetDirectory="mcal" />
	  <file action="link" path="../../../../../drivers/Mcal_Lib/src/Mcal_Lib_BootRom.c"            targetDirectory="mcal" />
	  <file action="link" path="../../../../AppUtils/AppUtils.c"                                   targetDirectory="mcal" />
    <file action="link" path="../Cdd_Adc_Example_Differential_Config/"                    targetDirectory="mcal" />
  </project>
</projectSpec>