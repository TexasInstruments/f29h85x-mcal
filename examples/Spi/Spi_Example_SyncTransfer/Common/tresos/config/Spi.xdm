                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:var name="SpiDataWordDelay" type="INTEGER" value="0">
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                    <d:var name="SpiTimeClk2Cs" type="FLOAT" value="0.0">
                      <a:a name="IMPORTER_INFO" value="@DEF"/>
                    </d:var>
                  </d:ctr>
                </d:lst>
                <d:lst name="SpiHwUnitConfig" type="MAP">
                  <d:ctr name="SpiHwUnitConfig_0" type="IDENTIFIABLE">
                    <d:ref name="SpiHwUnitType" type="REFERENCE" 
