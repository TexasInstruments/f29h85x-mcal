                    <d:var name="SpiHighSpeedMode" type="BOOLEAN" value="false"/>
                    <d:var name="SpiLoopBackMode" type="BOOLEAN" value="true"/>
                    <d:var name="SpiFifoModeEnable" type="BOOLEAN" value="true">
