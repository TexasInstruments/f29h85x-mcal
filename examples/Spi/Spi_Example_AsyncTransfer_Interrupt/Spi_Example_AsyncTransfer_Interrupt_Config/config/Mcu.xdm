                      <d:var name="McuEnableWDWakeup" type="BOOLEAN" 
                             value="false">
                        <a:a name="IMPORTER_INFO" value="@REC"/>
                      </d:var>
                    </d:ctr>
                  </d:lst>
                  <d:lst name="McuRamSectorSettingConf" type="MAP"/>
                </d:ctr>
              </d:lst>
            </d:ctr>
          </d:chc>
        </d:lst>
      </d:ctr>
    </d:lst>
  </d:ctr>

</datamodel>
