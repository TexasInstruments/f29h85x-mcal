{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 30,
        "patch": 2
      },    
    "configurePresets": [
        {
            "name": "c2000-f29h85x",
            "binaryDir": "${sourceDir}/build/artefacts",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/toolchain/c2000-f29h85x.cmake",
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_FLAGS": "-cl-single-precision-constant -Wall -Werror",
                "CMAKE_C_FLAGS_DEBUG": "-g -O1  -DDEBUG -DASSERT_ENABLE ",
                "CMAKE_C_FLAGS_RELEASE": "-O2",
                "CMAKE_EXE_LINKER_FLAGS": "-Wl,--reread_libs -Wl,--diag_wrap=off -Wl,--display_error_number -Wl,--warn_sections -Wl,--rom_model"         
            }
        },
        {
            "name": "mingw-c2000-f29h85x",
            "inherits": "c2000-f29h85x",
            "displayName": "MinGW Makefiles Preset",
            "description": "Default build using MinGW generator",
            "generator": "MinGW Makefiles",
            "cacheVariables": {
                "CMAKE_MAKE_PROGRAM": "gmake"
            }            
        },
        {
            "name": "unix-c2000-f29h85x",
            "inherits": "c2000-f29h85x",
            "displayName": "Unix Makefiles Preset",
            "description": "Default build using Unix generator",
            "generator": "Unix Makefiles"
        },
        {
            "name": "ninja-c2000-f29h85x",
            "inherits": "c2000-f29h85x",
            "displayName": "Ninja Preset",
            "description": "Default build using Ninja generator",
            "generator": "Ninja"
        }
    ]
}